{
  "permissions": {
    "allow": [
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(npm run *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",

      // Editing sources files
      "Edit (/src/**)"
    ],
    "deny": [
      // Package installation
      "Bash(npm install*)",
      "Bash(npm uninstall*)",
      "Bash(npm ci*)",
      "Bash(yarn add*)",
      "Bash(yarn install*)",
      "Bash(pip install*)",
      "Bash(pnpm add*)",
      "Bash(pnpm install*)",

      // Deleting files or folders
      "Bash(rm*)",
      "Bash(rmdir*)",
      "Bash(del*)",
      "Bash(rd*)",
      "Bash(rimraf*)",

      // Internet access
      "Bash(curl*)",
      "Bash(wget*)",
      "Bash(ssh*)",
      "Bash(scp*)"
    ]
  }
}