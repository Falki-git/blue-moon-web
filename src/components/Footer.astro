---
const footerLinks = [
  { href: '/',             label: 'Home' },
  { href: '/apartment',    label: 'Apartment' },
  { href: '/gallery',      label: 'Gallery' },
  { href: '/pricelist',    label: 'Pricelist' },
  { href: '/about-mandre', label: 'About Mandre' },
  { href: '/about-us',     label: 'About Us' },
  { href: '/reviews',      label: 'Reviews' },
  { href: '/contact',      label: 'Contact' },
  { href: '/directions',   label: 'Directions' },
];
---

<footer class="footer">
  <!-- Wave top edge -->
  <div class="footer__wave">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,40 C360,80 720,0 1080,40 C1260,60 1380,20 1440,35 L1440,60 L0,60 Z" fill="#081628"/>
    </svg>
  </div>

  <div class="footer__body">
    <div class="container">
      <div class="footer__grid">

        <!-- Brand column -->
        <div class="footer__brand">
          <a href="/" aria-label="Blue Moon Apartment">
            <img src="/images/logo.png" alt="Blue Moon Apartment" width="80" height="80" class="footer__logo" />
          </a>
          <p class="footer__tagline">Your luxury family retreat on the Adriatic</p>
          <p class="footer__season">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            Open: 1 June – 30 September 2025
          </p>
        </div>

        <!-- Quick links -->
        <nav class="footer__nav" aria-label="Footer navigation">
          <h4>Quick Links</h4>
          <ul>
            {footerLinks.map(link => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </nav>

        <!-- Contact column -->
        <div class="footer__contact">
          <h4>Contact</h4>
          <ul>
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <a href="mailto:info@bluemoonapartment.com">info@bluemoonapartment.com</a>
            </li>
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              <a href="https://wa.me/385914691204" target="_blank" rel="noopener">WhatsApp: +385 91 469 1204</a>
            </li>
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>Mandre, Island of Pag, Croatia</span>
            </li>
          </ul>

          <div class="footer__booking">
            <p>Also find us on:</p>
            <a href="https://www.booking.com/hotel/hr/blue-moon-apartment-mandre.hr.html" target="_blank" rel="noopener" class="footer__booking-btn">
              booking.com
            </a>
          </div>
        </div>

      </div>

      <div class="footer__bottom">
        <p>© 2025 Blue Moon Apartment · Goran Falkoni. All rights reserved.</p>
        <p>Mandre, Island of Pag, Croatia</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer__wave {
    display: block;
    line-height: 0;
    margin-bottom: -1px;
  }
  .footer__wave svg { display: block; width: 100%; height: 60px; }

  .footer__body {
    background: var(--deep-navy);
    padding: 3.5rem 0 2rem;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1.4fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer__logo {
    border-radius: 50%;
    margin-bottom: 1rem;
    opacity: 0.95;
  }

  .footer__tagline {
    color: rgba(255,255,255,0.65);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 0.85rem;
    font-style: italic;
  }

  .footer__season {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--sunset-gold);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.03em;
  }
  .footer__season svg { stroke: var(--sunset-gold); flex-shrink: 0; }

  .footer__nav h4,
  .footer__contact h4 {
    font-family: 'Nunito', sans-serif;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sky-blue);
    margin-bottom: 1.25rem;
  }

  .footer__nav ul,
  .footer__contact ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .footer__nav a {
    color: rgba(255,255,255,0.65);
    font-size: 0.9rem;
    font-weight: 600;
    transition: color 0.2s;
    text-decoration: none;
  }
  .footer__nav a:hover { color: var(--white); }

  .footer__contact li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    color: rgba(255,255,255,0.65);
    font-size: 0.88rem;
  }
  .footer__contact li svg { stroke: var(--sky-blue); flex-shrink: 0; margin-top: 2px; }
  .footer__contact a {
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer__contact a:hover { color: var(--sky-blue); }

  .footer__booking {
    margin-top: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .footer__booking p {
    color: rgba(255,255,255,0.45);
    font-size: 0.8rem;
  }
  .footer__booking-btn {
    background: #003580;
    color: white !important;
    padding: 0.35rem 0.85rem;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.2s;
  }
  .footer__booking-btn:hover { background: #00458a; }

  .footer__bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .footer__bottom p {
    color: rgba(255,255,255,0.35);
    font-size: 0.78rem;
  }

  @media (max-width: 860px) {
    .footer__grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .footer__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 520px) {
    .footer__grid { grid-template-columns: 1fr; }
    .footer__bottom { flex-direction: column; text-align: center; }
  }
</style>
