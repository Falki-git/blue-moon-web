---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import type { Translations } from '../../i18n/utils';
import heroCover from '../../assets/gallery/hot-tub.png';
import livingRoom from '../../assets/gallery/livingroom-1.jpg';
import aptBedroom from '../../assets/gallery/bedroom1-1.jpg';
import aptTerrace13 from '../../assets/gallery/terrace-13.jpg';
import aptKitchen from '../../assets/gallery/kitchen1-2.jpg';
import aptBathroom from '../../assets/gallery/bathroom1-1.jpg';
import aptHotTub2 from '../../assets/gallery/hot-tub-2.jpg';
import aptTerrace12 from '../../assets/gallery/terrace-12.jpg';
import aptTerrace4 from '../../assets/gallery/terrace-4.jpg';
import mandreAerial from '../../assets/gallery/mandre-aerial.jpg';

interface Props {
  lang: string;
  T: Translations;
}

const { lang, T } = Astro.props;
const prefix = lang === 'en' ? '' : `/${lang}`;
---

<BaseLayout
  title={T.home.metaTitle}
  description={T.home.metaDescription}
  lang={lang}
>

  <!-- ═══════════════════════════════════════════════════════════════ HERO -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true">
      <Image src={heroCover} alt="" widths={[800, 1280, 1920]} sizes="100vw" style="width:100%; height:100%; object-fit:cover; object-position:center 20%;" loading="eager" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content container">
      <h1 class="hero__title fade-up fade-up-1">{T.home.heroTitle}<br /><em>{T.home.heroTitleEm}</em></h1>
      <p class="hero__subtitle fade-up fade-up-2">{T.home.heroSubtitle}</p>
      <div class="hero__ctas fade-up fade-up-3">
        <a href={`${prefix}/booking`} class="btn btn-gold">{T.home.heroCta}</a>
        <a href={`${prefix}/apartment`} class="btn btn-white">{T.home.heroCtaSecondary}</a>
      </div>
    </div>
    <!-- Scroll cue -->
    <div class="hero__scroll" aria-hidden="true">
      <span></span>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ FEATURE STRIP -->
  <section class="features-strip">
    <div class="container">
      <ul class="features-strip__list">
        <li class="features-strip__item"><span class="feat-icon">🌊</span><span>{T.home.feat1}</span></li>
        <li class="features-strip__item"><span class="feat-icon">🛏️</span><span>{T.home.feat2}</span></li>
        <li class="features-strip__item"><span class="feat-icon">🛀</span><span>{T.home.feat3}</span></li>
        <li class="features-strip__item"><span class="feat-icon">♨️</span><span>{T.home.feat4}</span></li>
        <li class="features-strip__item"><span class="feat-icon">🌅</span><span>{T.home.feat5}</span></li>
        <li class="features-strip__item"><span class="feat-icon">🅿️</span><span>{T.home.feat6}</span></li>
      </ul>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ APARTMENT HIGHLIGHT -->
  <section class="section apt-highlight">
    <div class="container">
      <div class="apt-highlight__grid">
        <div class="apt-highlight__image">
          <div class="carousel" id="apt-highlight-carousel">
            <div class="carousel__track">
              <div class="carousel__slide"><Image src={livingRoom} alt="Living room" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={aptBedroom} alt="Bedroom" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={aptTerrace13} alt="Terrace view" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={aptKitchen} alt="Kitchen" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={aptBathroom} alt="Bathroom" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={aptHotTub2} alt="Hot tub on terrace" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={aptTerrace12} alt="Terrace" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={aptTerrace4} alt="Terrace" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
            </div>
            <button class="carousel__btn carousel__btn--prev" aria-label="Previous image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 1L1 8L8 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button class="carousel__btn carousel__btn--next" aria-label="Next image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L8 8L1 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="carousel__dots">
              <button class="carousel__dot carousel__dot--active" aria-label="Slide 1"></button>
              <button class="carousel__dot" aria-label="Slide 2"></button>
              <button class="carousel__dot" aria-label="Slide 3"></button>
              <button class="carousel__dot" aria-label="Slide 4"></button>
              <button class="carousel__dot" aria-label="Slide 5"></button>
              <button class="carousel__dot" aria-label="Slide 6"></button>
              <button class="carousel__dot" aria-label="Slide 7"></button>
              <button class="carousel__dot" aria-label="Slide 8"></button>
            </div>
          </div>
          <div class="apt-highlight__badge">92 m²</div>
        </div>
        <div class="apt-highlight__text">
          <span class="section-label">{T.home.aptLabel}</span>
          <h2>{T.home.aptTitle}</h2>
          <p>{T.home.aptBody}</p>
          <ul class="apt-highlight__bullets">
            <li>{T.home.aptBullet1}</li>
            <li>{T.home.aptBullet2}</li>
            <li>{T.home.aptBullet3}</li>
            <li>{T.home.aptBullet4}</li>
            <li>{T.home.aptBullet5}</li>
          </ul>
          <a href={`${prefix}/apartment`} class="btn btn-primary">{T.home.aptCta}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Wave -->
  <div class="wave" aria-hidden="true">
    <svg viewBox="0 0 1440 56" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,28 C240,56 480,0 720,28 C960,56 1200,8 1440,28 L1440,56 L0,56 Z" fill="#F7EDD8"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════ WHY BOOK DIRECT -->
  <section class="section direct-section" style="background: var(--warm-sand);">
    <div class="container">
      <div class="direct-section__header text-center">
        <span class="section-label">{T.home.directLabel}</span>
        <h2>{T.home.directTitle}</h2>
        <p class="direct-section__intro">{T.home.directIntro}</p>
      </div>
      <div class="grid-3 direct-cards">
        <div class="direct-card card">
          <div class="direct-card__icon">💰</div>
          <h3>{T.home.directCard1Title}</h3>
          <p>{T.home.directCard1Body}</p>
        </div>
        <div class="direct-card card">
          <div class="direct-card__icon">💬</div>
          <h3>{T.home.directCard2Title}</h3>
          <p>{T.home.directCard2Body}</p>
        </div>
        <div class="direct-card card">
          <div class="direct-card__icon">📅</div>
          <h3>{T.home.directCard3Title}</h3>
          <p>{T.home.directCard3Body}</p>
        </div>
      </div>
      <div class="text-center" style="margin-top: 2.5rem;">
        <a href={`${prefix}/contact`} class="btn btn-primary">{T.home.directCta}</a>
      </div>
    </div>
  </section>

  <!-- Wave -->
  <div class="wave" aria-hidden="true" style="background: var(--warm-sand);">
    <svg viewBox="0 0 1440 56" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,28 C240,0 480,56 720,28 C960,0 1200,56 1440,28 L1440,56 L0,56 Z" fill="#FFFFFF"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════ PRICELIST TEASER -->
  <section class="section price-teaser">
    <div class="container">
      <div class="text-center" style="margin-bottom: 2rem;">
        <span class="section-label">{T.home.priceLabel}</span>
        <h2>{T.home.priceTitle}</h2>
      </div>
      <div class="price-teaser__cards">
        <div class="price-card price-card--early">
          <div class="price-card__badge">{T.home.earlySummer}</div>
          <div class="price-card__icon">🌿</div>
          <div class="price-card__dates">{T.pricelist.earlySummerDates}</div>
          <div class="price-card__amount"><span class="price-card__currency">€</span><span data-rate-month="6">199</span></div>
          <div class="price-card__unit">{T.home.perNight}</div>
          <a href={`${prefix}/booking?month=6`} class="btn btn-sky btn-sm">{T.home.priceRequestBooking}</a>
        </div>
        <div class="price-card price-card--peak">
          <div class="price-card__badge">{T.home.peakSeason}</div>
          <div class="price-card__icon">☀️</div>
          <div class="price-card__dates">{T.pricelist.peakSeasonDates}</div>
          <div class="price-card__amount"><span class="price-card__currency">€</span><span data-rate-month="7">279</span></div>
          <div class="price-card__unit">{T.home.perNight}</div>
          <a href={`${prefix}/booking?month=7`} class="btn btn-gold btn-sm">{T.home.priceRequestBooking}</a>
        </div>
        <div class="price-card price-card--golden">
          <div class="price-card__badge">{T.home.goldenSep}</div>
          <div class="price-card__icon">🍂</div>
          <div class="price-card__dates">{T.pricelist.goldenSepDates}</div>
          <div class="price-card__amount"><span class="price-card__currency">€</span><span data-rate-month="9">199</span></div>
          <div class="price-card__unit">{T.home.perNight}</div>
          <a href={`${prefix}/booking?month=8`} class="btn btn-primary btn-sm">{T.home.priceRequestBooking}</a>
        </div>
      </div>
      <p class="price-teaser__note">{T.home.priceNote}</p>
      <p class="price-teaser__link"><a href={`${prefix}/pricelist`}>{T.home.priceLinkText}</a></p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ ABOUT MANDRE TEASER -->
  <section class="mandre-teaser">
    <Image class="mandre-teaser__bg" src={mandreAerial} alt="" aria-hidden="true" />
    <div class="mandre-teaser__overlay"></div>
    <div class="container mandre-teaser__content">
      <blockquote class="mandre-teaser__quote" set:html={`"${T.home.mandreQuote}"`}></blockquote>
      <p>{T.home.mandreBody}</p>
      <a href={`${prefix}/about-mandre`} class="btn btn-white" style="margin-top: 1.5rem;">{T.home.mandreCta}</a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ REVIEWS TEASER -->
  <section class="section" style="background: var(--soft-sky);">
    <div class="container">
      <div class="text-center" style="margin-bottom: 2.5rem;">
        <span class="section-label">{T.home.reviewsLabel}</span>
        <h2>{T.home.reviewsTitle}</h2>
      </div>
      <div class="grid-3 reviews-grid">
        <article class="review-card card">
          <div class="stars">★★★★★</div>
          <blockquote>"A beautiful apartment, very comfortable. Very clean, close to the beach and restaurants, small shop right across the street. The sea view from the terrace is gorgeous — and the jacuzzi is a fairy tale."</blockquote>
          <footer>
            <strong>Tomasz</strong>
            <span>🇵🇱 Poland · September 2025</span>
          </footer>
        </article>
        <article class="review-card card">
          <div class="stars">★★★★★</div>
          <blockquote>"The penthouse has everything you need. Bruno welcomed us warmly and the kitchen even had fresh fruit and drinks waiting in the fridge. Goran arranged an early check-in for us — a seamless, thoughtful touch."</blockquote>
          <footer>
            <strong>Alex</strong>
            <span>🇩🇪 Germany · June 2025</span>
          </footer>
        </article>
        <article class="review-card card">
          <div class="stars">★★★★★</div>
          <blockquote>"A beautiful brand-new apartment, spotlessly clean, two bathrooms, large terrace with sunbeds. The wonderful Bruno welcomed us with a bowl of fresh fruit and chilled drinks. Thank you Goran for a superb stay!"</blockquote>
          <footer>
            <strong>Iveta</strong>
            <span>🇸🇰 Slovakia · August 2024</span>
          </footer>
        </article>
      </div>
      <div class="text-center" style="margin-top: 2.5rem;">
        <a href={`${prefix}/reviews`} class="btn btn-primary">{T.home.reviewsCta}</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ CTA BANNER -->
  <section class="cta-banner" style="background: var(--ocean-blue);">
    <div class="container cta-banner__inner">
      <div>
        <h2 style="color: white; margin-bottom: 0.5rem;">{T.home.ctaTitle}</h2>
        <p style="color: rgba(255,255,255,0.8);">{T.home.ctaBody}</p>
      </div>
      <div class="cta-banner__btns">
        <a href={`${prefix}/booking`} class="btn btn-white">{T.home.ctaBook}</a>
        <a href={`${prefix}/contact`} class="btn" style="color:white; border: 2px solid rgba(255,255,255,0.5);">{T.home.ctaContact}</a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  document.querySelectorAll<HTMLElement>('.carousel').forEach(carousel => {
    const track = carousel.querySelector('.carousel__track') as HTMLElement;
    const dots = carousel.querySelectorAll('.carousel__dot');
    const prevBtn = carousel.querySelector('.carousel__btn--prev');
    const nextBtn = carousel.querySelector('.carousel__btn--next');
    const total = dots.length;
    let current = 0;

    function goTo(index: number) {
      current = ((index % total) + total) % total;
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((dot, i) => dot.classList.toggle('carousel__dot--active', i === current));
    }

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    let touchStartX = 0;
    carousel.addEventListener('touchstart', (e: TouchEvent) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    carousel.addEventListener('touchend', (e: TouchEvent) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 40) goTo(dx < 0 ? current + 1 : current - 1);
    });
  });
</script>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LodgingBusiness",
  "name": "Blue Moon Apartment",
  "description": "Luxury 2-bedroom family apartment in Mandre, island of Pag, Croatia. 92m², private hot tub terrace, sea views, 200m from the beach. Open June–September.",
  "url": "https://bluemoonmandre.eu",
  "image": "https://bluemoonmandre.eu/images/og-image.jpg",
  "email": "bluemoon.mandre@gmail.com",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Mandre",
    "addressRegion": "Zadar County",
    "addressCountry": "HR"
  },
  "numberOfRooms": 2,
  "maximumAttendeeCapacity": 6,
  "checkinTime": "15:00",
  "checkoutTime": "10:00",
  "priceRange": "€€€",
  "tourBookingPage": "https://bluemoonmandre.eu/booking",
  "amenityFeature": [
    {"@type": "LocationFeatureSpecification", "name": "Private hot tub", "value": true},
    {"@type": "LocationFeatureSpecification", "name": "Sea view", "value": true},
    {"@type": "LocationFeatureSpecification", "name": "Air conditioning", "value": true},
    {"@type": "LocationFeatureSpecification", "name": "Private parking", "value": true},
    {"@type": "LocationFeatureSpecification", "name": "BBQ grill", "value": true},
    {"@type": "LocationFeatureSpecification", "name": "WiFi", "value": true},
    {"@type": "LocationFeatureSpecification", "name": "Fully equipped kitchen", "value": true},
    {"@type": "LocationFeatureSpecification", "name": "Beachfront proximity (200 m)", "value": true}
  ]
})} />

<script>
  fetch('/api/availability')
    .then(r => r.json() as Promise<{ ok: boolean; pricing: Record<string, number> }>)
    .then(data => {
      if (!data.ok) return;
      document.querySelectorAll<HTMLElement>('[data-rate-month]').forEach(el => {
        const rate = data.pricing[el.getAttribute('data-rate-month')!];
        if (typeof rate === 'number') el.textContent = String(rate);
      });
    })
    .catch(() => { /* keep static fallback */ });
</script>

<style>
  /* ─── Hero ───────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: min(90vh, 700px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: 0 !important;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(8,22,40,0.15) 0%,
      rgba(8,22,40,0.45) 60%,
      rgba(8,22,40,0.65) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 4rem 2rem;
  }

  .hero__title {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    font-weight: 900;
    color: white;
    text-shadow: 0 3px 20px rgba(8,22,40,0.5);
    margin-bottom: 0.75rem;
    line-height: 1.1;
  }
  .hero__title em {
    font-style: italic;
    color: var(--sunset-gold);
  }

  .hero__subtitle {
    font-family: 'Nunito', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: rgba(255,255,255,0.85);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 2.5rem;
  }

  .hero__ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero__scroll {
    position: absolute;
    bottom: 1.75rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }
  .hero__scroll span {
    display: block;
    width: 24px;
    height: 36px;
    border: 2px solid rgba(255,255,255,0.6);
    border-radius: 12px;
    position: relative;
  }
  .hero__scroll span::after {
    content: '';
    position: absolute;
    top: 5px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 8px;
    background: rgba(255,255,255,0.8);
    border-radius: 2px;
    animation: scrollBounce 1.6s ease infinite;
  }
  @keyframes scrollBounce {
    0%, 100% { transform: translateX(-50%) translateY(0); opacity: 1; }
    50%       { transform: translateX(-50%) translateY(8px); opacity: 0.5; }
  }

  /* ─── Feature strip ─────────────────────────────────────────────── */
  .features-strip {
    background: var(--white);
    border-bottom: 1px solid rgba(74,159,212,0.12);
    padding: 1.5rem 0;
  }
  .features-strip__list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 2rem;
  }
  .features-strip__item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 0.88rem;
    color: var(--text-dark);
    white-space: nowrap;
  }
  .feat-icon { font-size: 1.2rem; }

  /* ─── Apartment highlight ────────────────────────────────────────── */
  .apt-highlight__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .apt-highlight__image { position: relative; }
  .apt-highlight__badge {
    position: absolute;
    bottom: 0.75rem;
    left: 0.75rem;
    background: var(--ocean-blue);
    color: white;
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
  }
  .apt-highlight__text h2 { margin-bottom: 1rem; }
  .apt-highlight__text p  { margin-bottom: 1.25rem; color: var(--text-muted); }
  .apt-highlight__bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 2rem;
  }
  .apt-highlight__bullets li {
    font-weight: 600;
    color: var(--text-dark);
    font-size: 0.92rem;
  }

  /* ─── Carousel ───────────────────────────────────────────────────── */
  .carousel {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4/3;
    width: 100%;
  }
  .carousel__track {
    display: flex;
    height: 100%;
    transition: transform 0.4s ease;
  }
  .carousel__slide {
    min-width: 100%;
    height: 100%;
  }
  .carousel__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .carousel__btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.85);
    border: none;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: background var(--transition);
    color: var(--ocean-blue);
  }
  .carousel__btn:hover { background: white; }
  .carousel__btn--prev { left: 0.75rem; }
  .carousel__btn--next { right: 0.75rem; }
  .carousel__dots {
    position: absolute;
    bottom: 0.75rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
    z-index: 2;
  }
  .carousel__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.5);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background var(--transition);
  }
  .carousel__dot--active { background: white; }

  /* ─── Why book direct ────────────────────────────────────────────── */
  .direct-section__header { margin-bottom: 2.5rem; }
