---
import PageLayout from '../../layouts/PageLayout.astro';
import BookingCalendar from '../BookingCalendar.astro';
import type { Translations, SupportedLang } from '../../i18n/utils';
import { INTL_LOCALE_MAP } from '../../i18n/utils';
import heroImg from '../../assets/gallery/terrace-14.jpg';

interface Props {
  lang: string;
  T: Translations;
}

const { lang, T } = Astro.props;
const b = T.booking;
const locale = INTL_LOCALE_MAP[lang as SupportedLang] ?? 'en-GB';
---

<PageLayout
  title={b.metaTitle}
  description={b.metaDescription}
  pageTitle={b.pageTitle}
  pageSubtitle={b.pageSubtitle}
  label={b.label}
  bgImage={heroImg}
  heroObjectPosition="center 36.3%"
  showHeroLogo={true}
  lang={lang}
>

  <!-- i18n data for client-side JS -->
  <div id="bookingI18n" hidden
    data-locale={locale}
    data-nights-singular={b.nightsSingular}
    data-nights-plural={b.nightsPlural}
    data-select-dates-placeholder={b.selectDatesPlaceholder}
    data-error-generic={b.errorGeneric}
    data-error-field-required={b.errorFieldRequired}
    data-error-email-invalid={b.errorEmailInvalid}
    data-error-country-required={b.errorCountryRequired}
    data-error-select-dates={b.errorSelectDates}
    data-no-countries={b.countrySearchPlaceholder}
  ></div>

  <!-- ═══ PRICING STRIP ═══ -->
  <section class="section-sm" style="background: var(--soft-sky);">
    <div class="container">
      <div class="text-center" style="margin-bottom:1.75rem;">
        <span class="section-label">{b.pricingLabel}</span>
        <h2 style="font-size: clamp(1.4rem, 2.8vw, 2rem);">{b.pricingTitle}</h2>
        <p style="color:var(--text-muted);font-size:0.9rem;margin-top:0.25rem;">{b.pricingSubtext}</p>
      </div>
      <div class="bk-prices">
        <div class="bk-price-card bk-price-card--early">
          <div class="bk-price-card__season">{b.earlySummer}</div>
          <div class="bk-price-card__dates">{T.pricelist.earlySummerDates}</div>
          <div class="bk-price-card__amount" data-rate-month="6"><span class="bk-price-card__currency">€</span>199</div>
          <div class="bk-price-card__per">{b.perNight}</div>
        </div>
        <div class="bk-price-card bk-price-card--peak">
          <div class="bk-price-card__season">{b.peakSeason}</div>
          <div class="bk-price-card__dates">{T.pricelist.peakSeasonDates}</div>
          <div class="bk-price-card__amount" data-rate-month="7"><span class="bk-price-card__currency">€</span>279</div>
          <div class="bk-price-card__per">{b.perNight}</div>
        </div>
        <div class="bk-price-card bk-price-card--golden">
          <div class="bk-price-card__season">{b.goldenSep}</div>
          <div class="bk-price-card__dates">{T.pricelist.goldenSepDates}</div>
          <div class="bk-price-card__amount" data-rate-month="9"><span class="bk-price-card__currency">€</span>199</div>
          <div class="bk-price-card__per">{b.perNight}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CALENDAR + SUMMARY ═══ -->
  <section class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom:2.5rem;">
        <span class="section-label">{b.step1Label}</span>
        <h2>{b.step1Title}</h2>
        <p style="color:var(--text-muted);font-size:0.95rem;margin-top:0.5rem;">{b.step1Hint}</p>
      </div>

      <div class="bk-pick">
        <div class="bk-pick__cal">
          <BookingCalendar T={T} />
        </div>

        <aside class="bk-pick__sum" id="bkSum">
          <div class="bk-sum-card">
            <h3 class="bk-sum__title">{b.yourStay}</h3>

            <div class="bk-sum__empty" id="bkSumEmpty">
              <p>{b.selectDatesHint}</p>
            </div>

            <div class="bk-sum__filled" id="bkSumFilled" hidden>
              <div class="bk-sum__dates">
                <div>
                  <div class="bk-sum__label">{b.checkIn}</div>
                  <div class="bk-sum__value" id="bkSumCheckin">—</div>
                  <div class="bk-sum__sub">{b.from4pm}</div>
                </div>
                <div class="bk-sum__arrow">→</div>
                <div>
                  <div class="bk-sum__label">{b.checkOut}</div>
                  <div class="bk-sum__value" id="bkSumCheckout">—</div>
                  <div class="bk-sum__sub">{b.by10am}</div>
                </div>
              </div>

              <div class="bk-sum__nights" id="bkSumNights">—</div>

              <details class="bk-sum__breakdown">
                <summary>{b.nightsBreakdown}</summary>
                <ul id="bkSumBreakdown"></ul>
              </details>

              <div class="bk-sum__totals">
                <div class="bk-sum__row"><span>{b.rowTotal}</span><strong id="bkSumTotal">—</strong></div>
                <div class="bk-sum__row"><span>{b.rowDeposit}</span><strong id="bkSumDeposit">—</strong></div>
                <div class="bk-sum__row bk-sum__row--muted"><span>{b.rowRemainder}</span><span id="bkSumRemainder">—</span></div>
              </div>

              <a href="#bkForm" class="btn btn-primary bk-sum__cta">{b.continueCta}</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══ BOOKING FORM ═══ -->
  <section class="section" style="background: var(--warm-sand);" id="bkForm">
    <div class="container">
      <div class="text-center" style="margin-bottom:2rem;">
        <span class="section-label">{b.step2Label}</span>
        <h2>{b.step2Title}</h2>
        <p style="color:var(--text-muted);font-size:0.95rem;margin-top:0.5rem;">{b.step2Hint}</p>
      </div>

      <div class="bk-form-wrap">
        <div class="bk-form-card">
          <form id="bookingForm" class="bk-form" novalidate>
            <p class="hidden" aria-hidden="true">
              <label>Don't fill this out: <input name="bot-field" /></label>
            </p>

            <input type="hidden" name="lang" value={lang} />

            <div class="bk-form__locked" id="bkLocked">
              <span class="bk-form__locked-label">{b.selectedDates}</span>
              <span id="bkLockedDates">{b.selectDatesPlaceholder}</span>
            </div>

            <input type="hidden" id="bkCheckin" name="checkin" />
            <input type="hidden" id="bkCheckout" name="checkout" />

            <div class="form-row">
              <div class="form-group">
                <label for="bk-fullName">{b.labelFullName} <span class="required">*</span></label>
                <input type="text" id="bk-fullName" name="fullName" placeholder={b.fullNamePlaceholder} required autocomplete="name" />
                <span class="form-error" aria-live="polite"></span>
              </div>
              <div class="form-group">
                <label for="bk-email">{b.labelEmail} <span class="required">*</span></label>
                <input type="email" id="bk-email" name="email" placeholder={b.emailPlaceholder} required autocomplete="email" />
                <span class="form-error" aria-live="polite"></span>
              </div>
            </div>

            <div class="form-row" style="margin-top: -1rem;">
              <div class="form-group">
                <label for="bk-phone">{b.labelPhone} <span class="required">*</span></label>
                <input type="tel" id="bk-phone" name="phone" placeholder={b.phonePlaceholder} required autocomplete="tel" />
                <span class="form-error" aria-live="polite"></span>
              </div>
              <div class="form-group">
                <label for="bk-country-trigger">{b.labelCountry} <span class="required">*</span></label>
                <input type="hidden" name="country" id="bk-country" />
                <div class="cs-wrap" id="bk-country-wrap">
                  <button type="button" class="cs-trigger" id="bk-country-trigger" aria-haspopup="listbox" aria-expanded="false" aria-controls="bk-country-panel">
                    <span class="cs-trigger__text" id="bk-country-display">{b.selectCountryPlaceholder}</span>
                    <svg class="cs-trigger__arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                  </button>
                  <div class="cs-panel" id="bk-country-panel" hidden>
                    <input type="text" class="cs-search" id="bk-country-search" placeholder={b.countrySearchPlaceholder} autocomplete="off" spellcheck="false" />
                    <ul class="cs-list" id="bk-country-list" role="listbox" aria-label={b.labelCountry}></ul>
                  </div>
                </div>
                <span class="form-error" id="bk-country-error" aria-live="polite"></span>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="bk-guests">{b.labelGuests} <span class="required">*</span></label>
                <input type="number" id="bk-guests" name="guests" min="1" max="6" required />
                <span class="form-hint">{b.guestsHint}</span>
              </div>
              <div class="form-group">
                <label for="bk-children">{b.labelChildren}</label>
                <input type="text" id="bk-children" name="children" placeholder={b.childrenPlaceholder} />
              </div>
            </div>

            <div class="form-group">
              <label for="bk-address">{b.labelAddress} <span class="optional">({b.labelAddressOptional})</span></label>
              <input type="text" id="bk-address" name="address" placeholder={b.addressPlaceholder} autocomplete="street-address" />
            </div>

            <div class="form-group">
              <label for="bk-source">{b.labelSource}</label>
              <select id="bk-source" name="source">
                <option value="">{b.sourceDefault}</option>
                <option value="returning">{b.sourceReturning}</option>
                <option value="friend">{b.sourceFriend}</option>
                <option value="booking">{b.sourceBooking}</option>
                <option value="google">{b.sourceGoogle}</option>
                <option value="social">{b.sourceSocial}</option>
                <option value="other">{b.sourceOther}</option>
              </select>
            </div>

            <div class="form-group">
              <label for="bk-message">{b.labelMessage}</label>
              <textarea id="bk-message" name="message" rows="4" placeholder={b.messagePlaceholder}></textarea>
            </div>

            <div class="cf-turnstile-wrap">
              <div class="cf-turnstile" data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY} data-theme="light" data-appearance="interaction-only"></div>
            </div>

            <div class="form-group form-group--submit">
              <button type="submit" class="btn btn-primary btn-submit" id="bkSubmit" disabled>
                <span class="btn-label">{b.submitBtn}</span>
                <span class="btn-loading" aria-hidden="true" style="display:none;">{b.submitting}</span>
                <svg class="btn-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              </button>
              <p class="form-privacy">
                🔒 {b.privacyNote}
              </p>
              <p class="form-submit-error" id="bkFormError" hidden></p>
            </div>
          </form>

          <div class="form-success" id="bkSuccess" hidden role="alert" aria-live="polite">
            <span class="form-success__icon">🌊</span>
            <h3>{b.successTitle}</h3>
            <p>{b.successBody1}</p>
            <p>{b.successBody2}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ POLICIES ═══ -->
  <section class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom:2.5rem;">
        <span class="section-label">{b.policiesLabel}</span>
        <h2>{b.policiesTitle}</h2>
      </div>
      <div class="policies-grid">
        <div class="policy-item">
          <div class="policy-icon">🔑</div>
          <h4>{b.policyCheckinTitle}</h4>
          <p set:html={b.policyCheckinBody}></p>
        </div>
        <div class="policy-item">
          <div class="policy-icon">🚪</div>
          <h4>{b.policyCheckoutTitle}</h4>
          <p set:html={b.policyCheckoutBody}></p>
        </div>
        <div class="policy-item">
          <div class="policy-icon">📅</div>
          <h4>{b.policyMinStayTitle}</h4>
          <p set:html={b.policyMinStayBody}></p>
        </div>
        <div class="policy-item">
          <div class="policy-icon">💳</div>
          <h4>{b.policyDepositTitle}</h4>
          <p set:html={b.policyDepositBody}></p>
        </div>
        <div class="policy-item">
          <div class="policy-icon">↩️</div>
          <h4>{b.policyCancelTitle}</h4>
          <p set:html={b.policyCancelBody}></p>
        </div>
        <div class="policy-item">
          <div class="policy-icon">🐾</div>
          <h4>{b.policyPetsTitle}</h4>
          <p set:html={b.policyPetsBody}></p>
        </div>
        <div class="policy-item">
          <div class="policy-icon">🚭</div>
          <h4>{b.policySmokingTitle}</h4>
          <p set:html={b.policySmokingBody}></p>
        </div>
        <div class="policy-item">
          <div class="policy-icon">👥</div>
          <h4>{b.policyOccupancyTitle}</h4>
          <p set:html={b.policyOccupancyBody}></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="section" style="background: var(--soft-sky);">
    <div class="container">
      <div class="text-center" style="margin-bottom:2.5rem;">
        <span class="section-label">{b.faqLabel}</span>
        <h2>{b.faqTitle}</h2>
      </div>
      <div class="faq-grid">
        <div class="faq-item">
          <h4>{b.faq1Q}</h4>
          <p>{b.faq1A}</p>
        </div>
        <div class="faq-item">
          <h4>{b.faq2Q}</h4>
          <p>{b.faq2A}</p>
        </div>
        <div class="faq-item">
          <h4>{b.faq3Q}</h4>
          <p>{b.faq3A}</p>
        </div>
        <div class="faq-item">
          <h4>{b.faq4Q}</h4>
          <p>{b.faq4A}</p>
        </div>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  /* Pricing strip */
  .bk-prices {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    max-width: 880px;
    margin: 0 auto;
  }
  .bk-price-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1rem;
    text-align: center;
    box-shadow: var(--shadow-xs);
    border-top: 4px solid var(--sky-blue);
  }
  .bk-price-card--peak   { border-top-color: var(--sunset-gold); }
  .bk-price-card--golden { border-top-color: var(--ocean-blue); }
  .bk-price-card__season {
    font-family: 'Nunito', sans-serif;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ocean-blue);
  }
  .bk-price-card__dates  { color: var(--text-muted); font-size: 0.78rem; margin-top: 0.2rem; }
  .bk-price-card__amount {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: 2rem;
    color: var(--ocean-blue);
    margin-top: 0.5rem;
    line-height: 1;
  }
  .bk-price-card--peak .bk-price-card__amount   { color: var(--sunset-gold); }
  .bk-price-card--golden .bk-price-card__amount { color: var(--ocean-blue); }
  :global(.bk-price-card__currency) { font-size: 0.6em; }
  .bk-price-card__per { font-size: 0.78rem; color: var(--text-muted); }

  /* Calendar + summary layout */
  .bk-pick {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  .bk-pick__sum { position: sticky; top: calc(var(--nav-height) + 1rem); }

  .bk-sum-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    padding: 1.75rem;
  }
  .bk-sum__title {
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }
  .bk-sum__empty p {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .bk-sum__dates {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 1rem;
  }
  .bk-sum__label {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .bk-sum__value {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    color: var(--ocean-blue);
    font-size: 1.05rem;
    margin-top: 0.15rem;
  }
  .bk-sum__sub { color: var(--text-light); font-size: 0.72rem; }
  .bk-sum__arrow { color: var(--sky-blue); font-size: 1.2rem; font-weight: 700; }

  .bk-sum__nights {
    background: var(--soft-sky);
    color: var(--ocean-blue);
    font-weight: 800;
    font-size: 0.85rem;
    padding: 0.5rem 0.85rem;
    border-radius: var(--radius);
    text-align: center;
    margin-bottom: 1rem;
  }

  .bk-sum__breakdown {
    margin-bottom: 1rem;
    font-size: 0.85rem;
  }
  .bk-sum__breakdown summary {
    cursor: pointer;
    color: var(--sky-blue);
    font-weight: 700;
    font-size: 0.78rem;
  }
  .bk-sum__breakdown ul {
    list-style: none;
    padding: 0.5rem 0 0;
    max-height: 220px;
    overflow-y: auto;
  }
  :global(#bkSumBreakdown li) {
    display: flex;
    justify-content: space-between;
    padding: 0.2rem 0;
    color: var(--text-muted);
    font-size: 0.78rem;
    width: 100%;
  }
  :global(#bkSumBreakdown li strong) { color: var(--text-dark); margin-left: auto; }

  .bk-sum__totals {
    border-top: 1px solid rgba(74,159,212,0.15);
    padding-top: 0.85rem;
    margin-bottom: 1.25rem;
  }
  .bk-sum__row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.25rem 0;
    font-size: 0.92rem;
    color: var(--text-dark);
    font-weight: 700;
  }
  .bk-sum__row strong {
    font-family: 'Playfair Display', serif;
    color: var(--ocean-blue);
    font-size: 1.05rem;
  }
  .bk-sum__row--muted { color: var(--text-muted); font-weight: 600; font-size: 0.82rem; }
  .bk-sum__row--muted span:last-child { color: var(--text-muted); }

  .bk-sum__cta { width: 100%; justify-content: center; }

  /* Form */
  .bk-form-wrap { max-width: 760px; margin: 0 auto; }
  .bk-form-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: 2.25rem;
    box-shadow: var(--shadow-md);
  }
  .bk-form { display: flex; flex-direction: column; gap: 1.25rem; }

  .bk-form__locked {
    background: var(--soft-sky);
    color: var(--ocean-blue);
    border-radius: var(--radius);
    padding: 0.85rem 1rem;
    font-size: 0.88rem;
    font-weight: 700;
    text-align: center;
  }
  .bk-form__locked-label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 800;
    margin-bottom: 0.2rem;
  }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
  .form-group label { font-size: 0.82rem; font-weight: 800; color: var(--text-dark); letter-spacing: 0.03em; }
  .required { color: var(--ocean-blue); }
  .optional { color: var(--text-light); font-weight: 600; font-size: 0.78rem; }

  .bk-form input,
  .bk-form select,
  .bk-form textarea {
    font-family: 'Nunito', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-dark);
    background: var(--soft-sky);
    border: 2px solid transparent;
    border-radius: var(--radius);
    padding: 0.75rem 1rem;
    transition: border-color 0.2s, background 0.2s;
    outline: none;
    width: 100%;
  }
  .bk-form input:focus,
  .bk-form select:focus,
  .bk-form textarea:focus { border-color: var(--sky-blue); background: var(--white); }
  .bk-form input.is-error, .bk-form select.is-error { border-color: #e05c5c; }
  .bk-form textarea { resize: vertical; min-height: 100px; }
  .bk-form select { cursor: pointer; }

  .form-hint { font-size: 0.75rem; color: var(--text-muted); font-style: italic; }
  .form-error { font-size: 0.75rem; color: #e05c5c; font-weight: 700; min-height: 1rem; }
  .form-group--submit { gap: 0.85rem; }
  .form-submit-error { font-size: 0.82rem; color: #e05c5c; font-weight: 700; text-align: center; line-height: 1.5; }
  .btn-submit { width: 100%; justify-content: center; font-size: 1rem; padding: 1rem 2rem; }
  .btn-submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }
  .form-privacy { font-size: 0.78rem; color: var(--text-muted); text-align: center; line-height: 1.5; }

  .hidden { display: none !important; }

  .form-success { text-align: center; padding: 2rem 1rem; }
  .form-success__icon { font-size: 3rem; display: block; margin-bottom: 1rem; }
  .form-success h3 { color: var(--ocean-blue); margin-bottom: 0.75rem; }
  .form-success p { color: var(--text-muted); margin-bottom: 0.5rem; }

  /* Policies */
  .policies-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .policy-item {
    background: var(--white);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow-xs);
    transition: transform 0.25s ease;
  }
  .policy-item:hover { transform: translateY(-3px); }
  .policy-icon { font-size: 1.8rem; margin-bottom: 0.75rem; }
  .policy-item h4 {
    font-family: 'Nunito', sans-serif; font-size: 0.875rem; font-weight: 800;
    color: var(--ocean-blue); margin-bottom: 0.5rem;
  }
  .policy-item p { font-size: 0.85rem; color: var(--text-dark); line-height: 1.5; }
  :global(.policy-item strong) { color: var(--ocean-blue); }

  /* FAQ */
  .faq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .faq-item {
    background: var(--white);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow-xs);
    border-left: 3px solid var(--sky-blue);
  }
  .faq-item h4 { font-family:'Nunito',sans-serif; font-size:0.9rem; font-weight:800; color:var(--ocean-blue); margin-bottom:0.5rem; }
  .faq-item p { font-size:0.88rem; color:var(--text-muted); }
  .faq-item a { color: var(--sky-blue); font-weight: 700; }

  /* Prevent the Turnstile iframe from overflowing its container */
  .cf-turnstile-wrap { overflow: hidden; border-radius: var(--radius); }

  /* Country combobox */
  .cs-wrap { position: relative; }
  .cs-trigger {
    width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.5rem;
    font-family: 'Nunito', sans-serif; font-size: 0.95rem; font-weight: 600; text-align: left;
    color: var(--text-dark); background: var(--soft-sky);
    border: 2px solid transparent; border-radius: var(--radius);
    padding: 0.75rem 1rem; cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .cs-trigger:hover { border-color: var(--sky-blue); }
  .cs-trigger[aria-expanded="true"] { border-color: var(--sky-blue); background: var(--white); }
  .cs-trigger.is-error { border-color: #e05c5c; }
  .cs-trigger__text { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .cs-trigger__text.placeholder { color: var(--text-light); font-weight: 500; }
  .cs-trigger__arrow { flex-shrink: 0; color: var(--text-muted); transition: transform 0.2s; }
  .cs-trigger[aria-expanded="true"] .cs-trigger__arrow { transform: rotate(180deg); }
  .cs-panel {
    position: absolute; top: calc(100% + 4px); left: 0; right: 0; z-index: 100;
    background: var(--white); border: 2px solid var(--sky-blue);
    border-radius: var(--radius); box-shadow: var(--shadow-md);
    overflow: hidden;
  }
  .cs-search {
    width: 100%; box-sizing: border-box;
    font-family: 'Nunito', sans-serif; font-size: 0.9rem; font-weight: 600;
    color: var(--text-dark); background: var(--soft-sky);
    border: none; border-bottom: 2px solid var(--sky-blue);
    padding: 0.6rem 0.9rem; outline: none;
  }
  .cs-list {
    list-style: none; margin: 0; padding: 0.25rem 0;
    max-height: 220px; overflow-y: auto;
  }
  .cs-list li {
    padding: 0.55rem 0.9rem; font-size: 0.9rem; font-weight: 600;
    color: var(--text-dark); cursor: pointer;
  }
  .cs-list li:hover, .cs-list li.cs-highlighted { background: var(--soft-sky); cursor: pointer; }
  .cs-list li.cs-selected { background: var(--ocean-blue); color: var(--white); }
  .cs-list li.cs-selected:hover { background: var(--sky-blue); }
  .cs-no-results { padding: 0.6rem 0.9rem; font-size: 0.88rem; color: var(--text-muted); font-style: italic; }

  @media (max-width: 980px) {
    .bk-pick { grid-template-columns: 1fr; }
    .bk-pick > * { min-width: 0; }
    .bk-pick__sum { position: static; }
  }
  @media (max-width: 720px) {
    .bk-prices { grid-template-columns: 1fr; max-width: 360px; }
    .policies-grid { grid-template-columns: 1fr 1fr; }
    .faq-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 540px) {
    .form-row { grid-template-columns: 1fr; }
    .bk-form-card { padding: 1.5rem; }
    .policies-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 420px) {
    .bk-sum-card { padding: 1.25rem; }
    .bk-sum__dates { grid-template-columns: 1fr; gap: 0.75rem; }
    .bk-sum__arrow { display: none; }
    .bk-sum__value { font-size: 0.9rem; }
  }
</style>

<script>
  type RangeDetail = {
    checkIn: string; checkOut: string; nights: number; totalEur: number;
    breakdown: { date: string; eur: number }[];
  } | null;

  const i18nEl   = document.getElementById('bookingI18n')!;
  const locale   = i18nEl.getAttribute('data-locale') ?? 'en-GB';
  const nightsSingular = i18nEl.getAttribute('data-nights-singular') ?? 'night';
  const nightsPlural   = i18nEl.getAttribute('data-nights-plural')   ?? 'nights';
  const selectDatesPlaceholder = i18nEl.getAttribute('data-select-dates-placeholder')!;
  const errorGeneric          = i18nEl.getAttribute('data-error-generic')!;
  const errorFieldRequired    = i18nEl.getAttribute('data-error-field-required')!;
  const errorEmailInvalid     = i18nEl.getAttribute('data-error-email-invalid')!;
  const errorCountryRequired  = i18nEl.getAttribute('data-error-country-required')!;
  const errorSelectDates      = i18nEl.getAttribute('data-error-select-dates')!;

  const empty   = document.getElementById('bkSumEmpty')!;
  const filled  = document.getElementById('bkSumFilled')!;
  const inEl    = document.getElementById('bkSumCheckin')!;
  const outEl   = document.getElementById('bkSumCheckout')!;
  const nightsEl = document.getElementById('bkSumNights')!;
  const breakdownEl = document.getElementById('bkSumBreakdown')!;
  const totalEl    = document.getElementById('bkSumTotal')!;
  const depositEl  = document.getElementById('bkSumDeposit')!;
  const remainderEl = document.getElementById('bkSumRemainder')!;
  const lockedDates = document.getElementById('bkLockedDates')!;
  const checkinHidden  = document.getElementById('bkCheckin') as HTMLInputElement;
  const checkoutHidden = document.getElementById('bkCheckout') as HTMLInputElement;
  const submitBtn = document.getElementById('bkSubmit') as HTMLButtonElement;

  let currentRange: RangeDetail = null;

  function fmtDate(iso: string): string {
    const [y, m, d] = iso.split('-').map(Number);
    return new Date(y, m - 1, d).toLocaleDateString(locale, {
      weekday: 'short', day: 'numeric', month: 'short', year: 'numeric',
    });
  }

  function fmtEur(n: number): string {
    return `€${n.toLocaleString('en-GB')}`;
  }

  document.addEventListener('booking-range-change', (e) => {
    const d = (e as CustomEvent).detail as RangeDetail;
    currentRange = d;
    if (!d) {
      empty.style.display = '';
      filled.hidden = true;
      lockedDates.textContent = selectDatesPlaceholder;
      checkinHidden.value = '';
      checkoutHidden.value = '';
      submitBtn.disabled = true;
      return;
    }
    empty.style.display = 'none';
    filled.hidden = false;
    inEl.textContent  = fmtDate(d.checkIn);
    outEl.textContent = fmtDate(d.checkOut);
    const nightWord = d.nights === 1 ? nightsSingular : nightsPlural;
    nightsEl.textContent = `${d.nights} ${nightWord}`;
    breakdownEl.innerHTML = d.breakdown
      .map(b => `<li><span>${fmtDate(b.date)}</span><strong>${fmtEur(b.eur)}</strong></li>`).join('');
    totalEl.textContent = fmtEur(d.totalEur);
    const deposit = Math.round(d.totalEur * 0.3);
    depositEl.textContent = fmtEur(deposit);
    remainderEl.textContent = fmtEur(d.totalEur - deposit);
    lockedDates.textContent = `${fmtDate(d.checkIn)}  →  ${fmtDate(d.checkOut)} · ${d.nights} ${nightWord} · Total ${fmtEur(d.totalEur)}`;
    checkinHidden.value = d.checkIn;
    checkoutHidden.value = d.checkOut;
    submitBtn.disabled = false;
  });

  // Update price strip from /api/availability
  fetch('/api/availability')
    .then(r => r.json() as Promise<{ ok: boolean; pricing: Record<string, number> }>)
    .then(data => {
      if (!data.ok) return;
      document.querySelectorAll<HTMLElement>('[data-rate-month]').forEach(el => {
        const m = el.getAttribute('data-rate-month')!;
        const rate = data.pricing[m];
        if (typeof rate === 'number') el.innerHTML = `<span class="bk-price-card__currency">€</span>${rate}`;
      });
    })
    .catch(() => { /* keep static fallback */ });

  // Form
  const form = document.getElementById('bookingForm') as HTMLFormElement;
  const formError = document.getElementById('bkFormError') as HTMLElement;
  const formSuccess = document.getElementById('bkSuccess') as HTMLElement;

  // ── Country combobox ────────────────────────────────────────────────────
  const COUNTRIES = [
    'Afghanistan','Albania','Algeria','Andorra','Angola','Antigua and Barbuda',
    'Argentina','Armenia','Australia','Austria','Azerbaijan','Bahamas','Bahrain',
    'Bangladesh','Barbados','Belarus','Belgium','Belize','Benin','Bhutan',
    'Bolivia','Bosnia and Herzegovina','Botswana','Brazil','Brunei','Bulgaria',
    'Burkina Faso','Burundi','Cabo Verde','Cambodia','Cameroon','Canada',
    'Central African Republic','Chad','Chile','China','Colombia','Comoros',
    'Congo','Costa Rica','Croatia','Cuba','Cyprus','Czech Republic','Denmark',
    'Djibouti','Dominica','Dominican Republic','DR Congo','Ecuador','Egypt',
    'El Salvador','Equatorial Guinea','Eritrea','Estonia','Eswatini','Ethiopia',
    'Fiji','Finland','France','Gabon','Gambia','Georgia','Germany','Ghana',
    'Greece','Grenada','Guatemala','Guinea','Guinea-Bissau','Guyana','Haiti',
    'Honduras','Hungary','Iceland','India','Indonesia','Iran','Iraq','Ireland',
    'Israel','Italy','Ivory Coast','Jamaica','Japan','Jordan','Kazakhstan',
    'Kenya','Kiribati','Kosovo','Kuwait','Kyrgyzstan','Laos','Latvia','Lebanon',
    'Lesotho','Liberia','Libya','Liechtenstein','Lithuania','Luxembourg',
    'Madagascar','Malawi','Malaysia','Maldives','Mali','Malta','Marshall Islands',
    'Mauritania','Mauritius','Mexico','Micronesia','Moldova','Monaco','Mongolia',
    'Montenegro','Morocco','Mozambique','Myanmar','Namibia','Nauru','Nepal',
    'Netherlands','New Zealand','Nicaragua','Niger','Nigeria','North Korea',
    'North Macedonia','Norway','Oman','Pakistan','Palau','Palestine','Panama',
    'Papua New Guinea','Paraguay','Peru','Philippines','Poland','Portugal',
    'Qatar','Romania','Russia','Rwanda','Saint Kitts and Nevis','Saint Lucia',
    'Saint Vincent and the Grenadines','Samoa','San Marino','Sao Tome and Principe',
    'Saudi Arabia','Senegal','Serbia','Seychelles','Sierra Leone','Singapore',
    'Slovakia','Slovenia','Solomon Islands','Somalia','South Africa','South Korea',
    'South Sudan','Spain','Sri Lanka','Sudan','Suriname','Sweden','Switzerland',
    'Syria','Taiwan','Tajikistan','Tanzania','Thailand','Timor-Leste','Togo',
    'Tonga','Trinidad and Tobago','Tunisia','Turkey','Turkmenistan','Tuvalu',
    'Uganda','Ukraine','United Arab Emirates','United Kingdom','United States',
    'Uruguay','Uzbekistan','Vanuatu','Vatican City','Venezuela','Vietnam',
    'Yemen','Zambia','Zimbabwe',
  ];

  const csHidden   = document.getElementById('bk-country') as HTMLInputElement;
  const csTrigger  = document.getElementById('bk-country-trigger') as HTMLButtonElement;
  const csDisplay  = document.getElementById('bk-country-display') as HTMLSpanElement;
  const csPanel    = document.getElementById('bk-country-panel') as HTMLDivElement;
  const csSearch   = document.getElementById('bk-country-search') as HTMLInputElement;
  const csList     = document.getElementById('bk-country-list') as HTMLUListElement;
  const csError    = document.getElementById('bk-country-error') as HTMLSpanElement;
  let csHighlighted = -1;

  function csRender(filter = '') {
    const q = filter.toLowerCase();
    const matches = COUNTRIES.filter(c => c.toLowerCase().includes(q));
    csList.innerHTML = '';
    csHighlighted = -1;
    if (matches.length === 0) {
      csList.innerHTML = '<li class="cs-no-results" aria-disabled="true">' + (i18nEl.getAttribute('data-no-countries') ?? 'No countries found') + '</li>';
      return;
    }
    matches.forEach((c) => {
      const li = document.createElement('li');
      li.textContent = c;
      li.setAttribute('role', 'option');
      li.dataset.value = c;
      const isSelected = c === csHidden.value;
      li.style.cssText = `padding: 0.55rem 0.9rem; font-size: 0.9rem; font-weight: 600; cursor: pointer; color: ${isSelected ? 'var(--white)' : 'var(--text-dark)'}; background: ${isSelected ? 'var(--ocean-blue)' : ''};`;
      if (isSelected) li.classList.add('cs-selected');
      li.addEventListener('mouseover', () => {
        if (!li.classList.contains('cs-selected')) li.style.background = 'var(--soft-sky)';
      });
      li.addEventListener('mouseout', () => {
        if (!li.classList.contains('cs-selected')) li.style.background = '';
      });
      li.addEventListener('mousedown', (e) => { e.preventDefault(); csSelect(c); });
      csList.appendChild(li);
    });
  }

  function csOpen() {
    csPanel.hidden = false;
    csTrigger.setAttribute('aria-expanded', 'true');
    csSearch.value = '';
    csRender();
    csSearch.focus();
    const sel = csList.querySelector('.cs-selected') as HTMLElement | null;
    if (sel) sel.scrollIntoView({ block: 'nearest' });
  }

  function csClose() {
    csPanel.hidden = true;
    csTrigger.setAttribute('aria-expanded', 'false');
    csHighlighted = -1;
  }

  function csSelect(value: string) {
    csHidden.value = value;
    csDisplay.textContent = value;
    csDisplay.classList.remove('placeholder');
    csTrigger.classList.remove('is-error');
    csError.textContent = '';
    csClose();
    csTrigger.focus();
  }

  function csHighlight(idx: number) {
    const items = csList.querySelectorAll<HTMLElement>('li[data-value]');
    items.forEach(li => {
      li.classList.remove('cs-highlighted');
      if (!li.classList.contains('cs-selected')) li.style.background = '';
    });
    csHighlighted = Math.max(0, Math.min(idx, items.length - 1));
    if (items[csHighlighted]) {
      items[csHighlighted].classList.add('cs-highlighted');
      items[csHighlighted].style.background = 'var(--soft-sky)';
      items[csHighlighted].scrollIntoView({ block: 'nearest' });
    }
  }

  function validateCountry(): boolean {
    if (!csHidden.value) {
      csTrigger.classList.add('is-error');
      csError.textContent = errorCountryRequired;
      return false;
    }
    csTrigger.classList.remove('is-error');
    csError.textContent = '';
    return true;
  }

  csDisplay.classList.add('placeholder');
  csTrigger.addEventListener('click', () => csPanel.hidden ? csOpen() : csClose());

  csTrigger.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      if (csPanel.hidden) csOpen(); else csClose();
    } else if (e.key.length === 1 && !e.ctrlKey && !e.metaKey) {
      e.preventDefault();
      csOpen();
      csSearch.value = e.key;
      csRender(e.key);
    } else if (e.key === 'Escape') {
      csClose();
    }
  });

  csSearch.addEventListener('input', () => csRender(csSearch.value));

  csSearch.addEventListener('keydown', (e) => {
    const items = csList.querySelectorAll<HTMLElement>('li[data-value]');
    if (e.key === 'ArrowDown') { e.preventDefault(); csHighlight(csHighlighted + 1); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); csHighlight(csHighlighted - 1); }
    else if (e.key === 'Enter') {
      e.preventDefault();
      if (csHighlighted >= 0 && items[csHighlighted]) csSelect(items[csHighlighted].dataset.value!);
    }
    else if (e.key === 'Escape') { csClose(); csTrigger.focus(); }
  });

  document.addEventListener('mousedown', (e) => {
    if (!csTrigger.closest('.cs-wrap')?.contains(e.target as Node)) csClose();
  });
  // ── End country combobox ─────────────────────────────────────────────────

  function validateField(input: HTMLInputElement) {
    const errorEl = input.parentElement?.querySelector('.form-error');
    if (input.required && !input.value.trim()) {
      input.classList.add('is-error');
      if (errorEl) errorEl.textContent = errorFieldRequired;
      return false;
    }
    if (input.type === 'email' && input.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value)) {
      input.classList.add('is-error');
      if (errorEl) errorEl.textContent = errorEmailInvalid;
      return false;
    }
    input.classList.remove('is-error');
    if (errorEl) errorEl.textContent = '';
    return true;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!currentRange) {
      if (formError) {
        formError.textContent = errorSelectDates;
        formError.hidden = false;
      }
      return;
    }
    const inputs = form.querySelectorAll<HTMLInputElement>('input[required], select[required]');
    let valid = true;
    inputs.forEach(input => { if (!validateField(input)) valid = false; });
    if (!validateCountry()) valid = false;
    if (!valid) return;

    const label = submitBtn.querySelector('.btn-label') as HTMLElement;
    const loading = submitBtn.querySelector('.btn-loading') as HTMLElement;
    label.style.display = 'none';
    loading.style.display = 'inline';
    submitBtn.disabled = true;
    formError.hidden = true;

    try {
      const fd = new FormData(form);
      const payload: Record<string, string> = {};
      fd.forEach((val, key) => { payload[key] = String(val); });

      const res  = await fetch('/api/booking', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json() as { ok: boolean; error?: string };

      if (data.ok) {
        form.style.display = 'none';
        formSuccess.hidden = false;
        document.getElementById('bkForm')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } else {
        throw new Error(data.error ?? errorGeneric);
      }
    } catch (err: unknown) {
      const msg = err instanceof Error ? err.message : errorGeneric;
      label.style.display = 'inline';
      loading.style.display = 'none';
      submitBtn.disabled = false;
      (window as unknown as { turnstile?: { reset: () => void } }).turnstile?.reset();
      formError.textContent = `${msg} If the problem persists, email us at bluemoon.mandre@gmail.com`;
      formError.hidden = false;
    }
  });
</script>

<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
