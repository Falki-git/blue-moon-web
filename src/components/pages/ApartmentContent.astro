---
import { Image } from 'astro:assets';
import PageLayout from '../../layouts/PageLayout.astro';
import type { Translations } from '../../i18n/utils';
import heroBg from '../../assets/gallery/livingroom-8.jpg';
import hotTub from '../../assets/gallery/hot-tub.png';
import bedroom1 from '../../assets/gallery/bedroom1-1.jpg';
import bedroom1b from '../../assets/gallery/bedroom1-2.jpg';
import bedroom1c from '../../assets/gallery/bedroom1-4.jpg';
import bedroom2b from '../../assets/gallery/bedroom2-2.jpg';
import bedroom2c from '../../assets/gallery/bedroom2-4.jpg';
import bedroom2d from '../../assets/gallery/bedroom2-5.jpg';
import kitchen from '../../assets/gallery/kitchen1-1.jpg';
import kitchen2 from '../../assets/gallery/kitchen1-2.jpg';
import kitchen3 from '../../assets/gallery/kitchen1-3.jpg';
import livingroom1 from '../../assets/gallery/livingroom-1.jpg';
import bathroom from '../../assets/gallery/bathroom1-1.jpg';
import bathroom1b from '../../assets/gallery/bathroom1-2.jpg';
import bathroom2 from '../../assets/gallery/Bathroom2.jpg';
import carouselImg1 from '../../assets/gallery/livingroom-5.jpg';
import carouselImg2 from '../../assets/gallery/livingroom-3.jpg';
import carouselImg3 from '../../assets/gallery/terrace-13.jpg';
import carouselImg4 from '../../assets/gallery/bedroom1-5.jpg';
import carouselImg5 from '../../assets/gallery/reviews-1.jpg';
import terrace12 from '../../assets/gallery/terrace-12.jpg';
import terrace11 from '../../assets/gallery/terrace-11.jpg';
import terrace6 from '../../assets/gallery/terrace-6.jpg';
import hotTub2 from '../../assets/gallery/hot-tub-2.jpg';
import livingroom7 from '../../assets/gallery/livingroom-7.jpg';

interface Props {
  lang: string;
  T: Translations;
}

const { lang, T } = Astro.props;
const prefix = lang === 'en' ? '' : `/${lang}`;
---

<PageLayout
  title={T.apartment.metaTitle}
  description={T.apartment.metaDescription}
  pageTitle={T.apartment.pageTitle}
  pageSubtitle={T.apartment.pageSubtitle}
  label={T.apartment.label}
  bgClass="ph-terrace"
  bgImage={heroBg}
  lang={lang}
>

  <!-- ═══ OVERVIEW ═══ -->
  <section class="section">
    <div class="container">
      <div class="apt-grid">
        <div>
          <span class="section-label">{T.apartment.overviewLabel}</span>
          <h2>{T.apartment.overviewTitle}</h2>
          <p>{T.apartment.overviewBody1}</p>
          <p style="margin-top:1rem;">{T.apartment.overviewBody2}</p>
          <div class="overview-stats">
            <div class="stat"><span class="stat__num">92</span><span class="stat__label">{T.apartment.statM2}</span></div>
            <div class="stat"><span class="stat__num">2</span><span class="stat__label">{T.apartment.statBedrooms}</span></div>
            <div class="stat"><span class="stat__num">2</span><span class="stat__label">{T.apartment.statBathrooms}</span></div>
            <div class="stat"><span class="stat__num">6</span><span class="stat__label">{T.apartment.statGuests}</span></div>
          </div>
        </div>
        <div>
          <div class="carousel" id="overview-carousel">
            <div class="carousel__track">
              <div class="carousel__slide"><Image src={carouselImg1} alt="Living room" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={carouselImg2} alt="Living room" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={carouselImg3} alt="Terrace view" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" style="object-position: 30% center;" /></div>
              <div class="carousel__slide"><Image src={carouselImg4} alt="Bedroom" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" style="object-position: 10% center;" /></div>
              <div class="carousel__slide"><Image src={carouselImg5} alt="Guest review" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
            </div>
            <button class="carousel__btn carousel__btn--prev" aria-label="Previous image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 1L1 8L8 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button class="carousel__btn carousel__btn--next" aria-label="Next image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L8 8L1 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="carousel__dots">
              <button class="carousel__dot carousel__dot--active" aria-label="Slide 1"></button>
              <button class="carousel__dot" aria-label="Slide 2"></button>
              <button class="carousel__dot" aria-label="Slide 3"></button>
              <button class="carousel__dot" aria-label="Slide 4"></button>
              <button class="carousel__dot" aria-label="Slide 5"></button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ THE TERRACE ═══ -->
  <section class="section" style="background: var(--soft-sky);">
    <div class="container">
      <div class="apt-grid apt-grid--reverse">
        <div>
          <div class="carousel" id="terrace-carousel">
            <div class="carousel__track">
              <div class="carousel__slide"><Image src={terrace11} alt="Terrace" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={hotTub} alt="Hot tub on terrace" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={hotTub2} alt="Hot tub on terrace" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={terrace6} alt="Terrace view" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={terrace12} alt="Terrace" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={livingroom7} alt="Living room" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
            </div>
            <button class="carousel__btn carousel__btn--prev" aria-label="Previous image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 1L1 8L8 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button class="carousel__btn carousel__btn--next" aria-label="Next image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L8 8L1 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="carousel__dots">
              <button class="carousel__dot carousel__dot--active" aria-label="Slide 1"></button>
              <button class="carousel__dot" aria-label="Slide 2"></button>
              <button class="carousel__dot" aria-label="Slide 3"></button>
              <button class="carousel__dot" aria-label="Slide 4"></button>
              <button class="carousel__dot" aria-label="Slide 5"></button>
              <button class="carousel__dot" aria-label="Slide 6"></button>
            </div>
          </div>
        </div>
        <div>
          <span class="section-label">{T.apartment.terraceLabel}</span>
          <h2>{T.apartment.terraceTitle}</h2>
          <p>{T.apartment.terraceBody1}</p>
          <p style="margin-top:1rem;">{T.apartment.terraceBody2}</p>
          <div class="highlight-box" style="margin-top:1.5rem;" set:html={T.apartment.terraceHotTubNote}></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ BEDROOMS ═══ -->
  <section class="section">
    <div class="container">
      <div class="apt-grid apt-grid--reverse">
        <div>
          <div class="carousel" id="bedroom-carousel" style="aspect-ratio: 16/9;">
            <div class="carousel__track">
              <div class="carousel__slide"><Image src={bedroom1} alt="Bedroom" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={bedroom1b} alt="Bedroom" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={bedroom1c} alt="Bedroom" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={bedroom2b} alt="Bedroom" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={bedroom2c} alt="Bedroom" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={bedroom2d} alt="Bedroom" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
            </div>
            <button class="carousel__btn carousel__btn--prev" aria-label="Previous image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 1L1 8L8 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button class="carousel__btn carousel__btn--next" aria-label="Next image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L8 8L1 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="carousel__dots">
              <button class="carousel__dot carousel__dot--active" aria-label="Slide 1"></button>
              <button class="carousel__dot" aria-label="Slide 2"></button>
              <button class="carousel__dot" aria-label="Slide 3"></button>
              <button class="carousel__dot" aria-label="Slide 4"></button>
              <button class="carousel__dot" aria-label="Slide 5"></button>
              <button class="carousel__dot" aria-label="Slide 6"></button>
            </div>
          </div>
        </div>
        <div>
          <span class="section-label">{T.apartment.bedroomsLabel}</span>
          <h2>{T.apartment.bedroomsTitle}</h2>
          <p>{T.apartment.bedroomsBody}</p>
          <p style="margin-top:1rem;">{T.apartment.bedroomsBody2}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ KITCHEN ═══ -->
  <section class="section" style="background: var(--warm-sand);">
    <div class="container">
      <div class="apt-grid apt-grid--reverse">
        <div>
          <div class="carousel" id="kitchen-carousel">
            <div class="carousel__track">
              <div class="carousel__slide"><Image src={kitchen3} alt="Kitchen" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={kitchen2} alt="Kitchen" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={kitchen} alt="Kitchen" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={livingroom1} alt="Living room" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
            </div>
            <button class="carousel__btn carousel__btn--prev" aria-label="Previous image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 1L1 8L8 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button class="carousel__btn carousel__btn--next" aria-label="Next image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L8 8L1 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="carousel__dots">
              <button class="carousel__dot carousel__dot--active" aria-label="Slide 1"></button>
              <button class="carousel__dot" aria-label="Slide 2"></button>
              <button class="carousel__dot" aria-label="Slide 3"></button>
              <button class="carousel__dot" aria-label="Slide 4"></button>
            </div>
          </div>
        </div>
        <div>
          <span class="section-label">{T.apartment.kitchenLabel}</span>
          <h2>{T.apartment.kitchenTitle}</h2>
          <p>{T.apartment.kitchenBody}</p>
          <ul class="feat-list">
            <li>{T.apartment.kitchenFeat1}</li>
            <li>{T.apartment.kitchenFeat2}</li>
            <li>{T.apartment.kitchenFeat3}</li>
            <li>{T.apartment.kitchenFeat4}</li>
            <li>{T.apartment.kitchenFeat5}</li>
            <li>{T.apartment.kitchenFeat6}</li>
          </ul>
          <p style="margin-top:1rem;">{T.apartment.kitchenBBQ}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ BATHROOMS ═══ -->
  <section class="section">
    <div class="container">
      <div class="apt-grid apt-grid--reverse">
        <div>
          <div class="carousel" id="bathroom-carousel">
            <div class="carousel__track">
              <div class="carousel__slide"><Image src={bathroom} alt="Bathroom" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={bathroom1b} alt="Bathroom" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={bathroom2} alt="Bathroom" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
            </div>
            <button class="carousel__btn carousel__btn--prev" aria-label="Previous image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 1L1 8L8 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button class="carousel__btn carousel__btn--next" aria-label="Next image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L8 8L1 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="carousel__dots">
              <button class="carousel__dot carousel__dot--active" aria-label="Slide 1"></button>
              <button class="carousel__dot" aria-label="Slide 2"></button>
              <button class="carousel__dot" aria-label="Slide 3"></button>
            </div>
          </div>
        </div>
        <div>
          <span class="section-label">{T.apartment.bathroomsLabel}</span>
          <h2>{T.apartment.bathroomsTitle}</h2>
          <p>{T.apartment.bathroomsBody}</p>
          <ul class="feat-list" style="margin-top:1rem;">
            <li>{T.apartment.bathroomsFeat1}</li>
            <li>{T.apartment.bathroomsFeat2}</li>
            <li>{T.apartment.bathroomsFeat3}</li>
            <li>{T.apartment.bathroomsFeat4}</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ AMENITIES GRID ═══ -->
  <section class="section" style="background: var(--soft-sky);">
    <div class="container">
      <div class="text-center" style="margin-bottom:2.5rem;">
        <span class="section-label">{T.apartment.amenitiesLabel}</span>
        <h2>{T.apartment.amenitiesTitle}</h2>
      </div>
      <div class="amenity-grid">
        <div class="amenity-group">
          <h4>{T.apartment.amenityBedroomTitle}</h4>
          <ul>
            <li>{T.apartment.amenityBedroomItem1}</li>
            <li>{T.apartment.amenityBedroomItem2}</li>
            <li>{T.apartment.amenityBedroomItem3}</li>
            <li>{T.apartment.amenityBedroomItem4}</li>
            <li>{T.apartment.amenityBedroomItem5}</li>
            <li>{T.apartment.amenityBedroomItem6}</li>
          </ul>
        </div>
        <div class="amenity-group">
          <h4>{T.apartment.amenityKitchenTitle}</h4>
          <ul>
            <li>{T.apartment.amenityKitchenItem1}</li>
            <li>{T.apartment.amenityKitchenItem2}</li>
            <li>{T.apartment.amenityKitchenItem3}</li>
            <li>{T.apartment.amenityKitchenItem4}</li>
            <li>{T.apartment.amenityKitchenItem5}</li>
            <li>{T.apartment.amenityKitchenItem6}</li>
            <li>{T.apartment.amenityKitchenItem7}</li>
          </ul>
        </div>
        <div class="amenity-group">
          <h4>{T.apartment.amenityEntertainmentTitle}</h4>
          <ul>
            <li>{T.apartment.amenityEntertainmentItem1}</li>
            <li>{T.apartment.amenityEntertainmentItem2}</li>
            <li>{T.apartment.amenityEntertainmentItem3}</li>
          </ul>
        </div>
        <div class="amenity-group">
          <h4>{T.apartment.amenityOutdoorTitle}</h4>
          <ul>
            <li>{T.apartment.amenityOutdoorItem1}</li>
            <li>{T.apartment.amenityOutdoorItem2}</li>
            <li>{T.apartment.amenityOutdoorItem3}</li>
            <li>{T.apartment.amenityOutdoorItem4}</li>
            <li>{T.apartment.amenityOutdoorItem5}</li>
          </ul>
        </div>
        <div class="amenity-group">
          <h4>{T.apartment.amenityParkingTitle}</h4>
          <ul>
            <li>{T.apartment.amenityParkingItem1}</li>
            <li>{T.apartment.amenityParkingItem2}</li>
          </ul>
        </div>
        <div class="amenity-group">
          <h4>{T.apartment.amenityLocationTitle}</h4>
          <ul>
            <li>{T.apartment.amenityLocationItem1}</li>
            <li>{T.apartment.amenityLocationItem2}</li>
            <li>{T.apartment.amenityLocationItem3}</li>
            <li>{T.apartment.amenityLocationItem4}</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FAMILY CALLOUT ═══ -->
  <section class="section-sm">
    <div class="container">
      <div class="family-callout">
        <div class="family-callout__icon">👨‍👩‍👧‍👦</div>
        <div>
          <h3>{T.apartment.familyCalloutTitle}</h3>
          <p set:html={T.apartment.familyCalloutBody}></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section style="background: var(--ocean-blue); padding: 3.5rem 0;">
    <div class="container" style="text-align:center;">
      <h2 style="color:white; margin-bottom:0.75rem;">{T.apartment.ctaTitle}</h2>
      <p style="color:rgba(255,255,255,0.8); margin-bottom:2rem;">{T.apartment.ctaBody}</p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href={`${prefix}/booking`} class="btn btn-white">{T.apartment.bookCta}</a>
        <a href={`${prefix}/gallery`} class="btn" style="color:white; border:2px solid rgba(255,255,255,0.5);">{T.apartment.ctaViewGallery}</a>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  .apt-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .apt-grid--reverse > *:first-child { order: 2; }
  .apt-grid--reverse > *:last-child  { order: 1; }

  .overview-stats {
    display: grid;
    grid-template-columns: repeat(4, auto);
    justify-content: center;
    align-items: end;
    gap: 2rem;
    margin-top: 2rem;
  }
  .stat { display: flex; flex-direction: column; align-items: center; }
  .stat__num {
    font-family: 'Playfair Display', serif;
    font-size: 2.8rem;
    font-weight: 700;
    color: var(--ocean-blue);
    line-height: 1;
  }
  .stat__label {
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    white-space: nowrap;
    text-align: center;
  }

  .feat-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }
  .feat-list li {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text-dark);
  }

  .amenity-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .amenity-group {
    background: var(--white);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow-xs);
  }
  .amenity-group h4 {
    font-family: 'Nunito', sans-serif;
    font-size: 0.9rem;
    font-weight: 800;
    color: var(--ocean-blue);
    margin-bottom: 0.85rem;
  }
  .amenity-group ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .amenity-group li {
    font-size: 0.88rem;
    color: var(--text-dark);
    padding-left: 0.9rem;
    position: relative;
  }
  .amenity-group li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--sky-blue);
    font-size: 0.75rem;
    font-weight: 800;
    top: 1px;
  }

  .family-callout {
    background: var(--warm-sand);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    border-left: 4px solid var(--ocean-blue);
  }
  .family-callout__icon { font-size: 3rem; flex-shrink: 0; }
  .family-callout h3 { margin-bottom: 0.75rem; }
  .family-callout p { color: var(--text-muted); }
  .family-callout :global(strong) { color: var(--ocean-blue); }

  .carousel {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4/3;
    width: 100%;
  }
  .carousel__track {
    display: flex;
    height: 100%;
    transition: transform 0.4s ease;
  }
  .carousel__slide {
    min-width: 100%;
    height: 100%;
  }
  .carousel__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .carousel__btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.85);
    border: none;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: background var(--transition);
    color: var(--ocean-blue);
  }
  .carousel__btn:hover { background: white; }
  .carousel__btn--prev { left: 0.75rem; }
  .carousel__btn--next { right: 0.75rem; }
  .carousel__dots {
    position: absolute;
    bottom: 0.75rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
    z-index: 2;
  }
  .carousel__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.5);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background var(--transition);
  }
  .carousel__dot--active { background: white; }

  @media (max-width: 860px) {
    .apt-grid { grid-template-columns: 1fr; gap: 2rem; }
    .apt-grid--reverse > * { order: unset !important; }
    .amenity-grid { grid-template-columns: 1fr 1fr; }
    .feat-list { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .amenity-grid { grid-template-columns: 1fr; }
    .overview-stats {
      grid-template-columns: repeat(2, auto);
      gap: 1.5rem;
    }
    .family-callout { flex-direction: column; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.carousel').forEach(carousel => {
    const track = carousel.querySelector('.carousel__track') as HTMLElement;
    const dots = carousel.querySelectorAll('.carousel__dot');
    const prevBtn = carousel.querySelector('.carousel__btn--prev');
    const nextBtn = carousel.querySelector('.carousel__btn--next');
    const total = dots.length;
    let current = 0;

    function goTo(index: number) {
      current = ((index % total) + total) % total;
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((dot, i) => dot.classList.toggle('carousel__dot--active', i === current));
    }

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    let touchStartX = 0;
    carousel.addEventListener('touchstart', (e: TouchEvent) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    carousel.addEventListener('touchend', (e: TouchEvent) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 40) goTo(dx < 0 ? current + 1 : current - 1);
    });
  });
</script>
