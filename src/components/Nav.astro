---
const navLinks = [
  { href: '/',             label: 'Home' },
  { href: '/apartment',    label: 'Apartment' },
  { href: '/gallery',      label: 'Gallery' },
  { href: '/pricelist',    label: 'Pricelist' },
  { href: '/about-mandre', label: 'About Mandre' },
  { href: '/about-us',     label: 'About Us' },
  { href: '/reviews',      label: 'Reviews' },
  { href: '/contact',      label: 'Contact' },
];

const languages = [
  { code: 'en', flag: '🇬🇧', label: 'EN', active: true },
  { code: 'hr', flag: '🇭🇷', label: 'HR' },
  { code: 'de', flag: '🇩🇪', label: 'DE' },
  { code: 'si', flag: '🇸🇮', label: 'SI' },
  { code: 'it', flag: '🇮🇹', label: 'IT' },
  { code: 'pl', flag: '🇵🇱', label: 'PL' },
  { code: 'cz', flag: '🇨🇿', label: 'CZ' },
];

const currentPath = Astro.url.pathname;
---

<nav class="nav">
  <div class="nav__inner container">

    <a href="/" class="nav__logo" aria-label="Blue Moon Apartment - Home">
      <img src="/images/logo.png" alt="Blue Moon Apartment" width="56" height="56" />
    </a>

    <button class="nav__burger" id="navBurger" aria-label="Open navigation menu" aria-expanded="false" aria-controls="navMenu">
      <span></span><span></span><span></span>
    </button>

    <div class="nav__menu" id="navMenu" role="navigation">
      <ul class="nav__links">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={`nav__link ${currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? 'is-active' : ''}`}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <div class="nav__lang" role="navigation" aria-label="Language switcher">
        <button class="nav__lang-trigger" aria-haspopup="true" aria-expanded="false" id="langBtn">
          🇬🇧 <span>EN</span> <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <ul class="nav__lang-menu" role="listbox" aria-label="Select language" id="langMenu">
          {languages.map(lang => (
            <li role="option">
              <a href={lang.code === 'en' ? '/' : `/${lang.code}`} class={`nav__lang-item ${lang.active ? 'is-active' : ''}`}>
                {lang.flag} {lang.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</nav>

<style>
  .nav {
    background: var(--white);
    border-bottom: 1px solid rgba(74,159,212,0.15);
    position: relative;
    z-index: 200;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 78px;
    gap: 1.5rem;
  }

  .nav__logo img {
    height: 52px;
    width: auto;
    display: block;
    transition: transform 0.25s ease, opacity 0.25s ease;
    border-radius: 50%;
  }
  .nav__logo:hover img { transform: scale(1.06); opacity: 0.9; }

  .nav__menu {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex: 1;
    justify-content: flex-end;
  }

  .nav__links {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0;
    flex-wrap: wrap;
  }

  .nav__link {
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--text-dark);
    text-decoration: none;
    padding: 0.45rem 0.7rem;
    border-radius: 7px;
    transition: all 0.2s ease;
    letter-spacing: 0.01em;
    white-space: nowrap;
    display: block;
  }
  .nav__link:hover, .nav__link.is-active {
    color: var(--ocean-blue);
    background: rgba(74,159,212,0.1);
  }

  /* Language switcher */
  .nav__lang { position: relative; }

  .nav__lang-trigger {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    font-size: 0.82rem;
    background: var(--soft-sky);
    border: 1px solid rgba(74,159,212,0.25);
    border-radius: 8px;
    padding: 0.42rem 0.8rem;
    cursor: pointer;
    color: var(--ocean-blue);
    transition: background 0.2s;
    white-space: nowrap;
  }
  .nav__lang-trigger:hover { background: rgba(74,159,212,0.18); }

  .nav__lang-menu {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    background: var(--white);
    border: 1px solid rgba(74,159,212,0.18);
    border-radius: var(--radius);
    list-style: none;
    box-shadow: var(--shadow-md);
    min-width: 105px;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 300;
  }
  .nav__lang-menu.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .nav__lang-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1rem;
    font-family: 'Nunito', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-dark);
    text-decoration: none;
    transition: background 0.15s;
  }
  .nav__lang-item:hover, .nav__lang-item.is-active {
    background: var(--soft-sky);
    color: var(--ocean-blue);
  }

  /* Burger */
  .nav__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 8px;
    transition: background 0.2s;
  }
  .nav__burger:hover { background: var(--soft-sky); }
  .nav__burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ocean-blue);
    border-radius: 2px;
    transition: all 0.3s ease;
    transform-origin: center;
  }
  .nav__burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav__burger.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .nav__burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile */
  @media (max-width: 980px) {
    .nav__link { font-size: 0.8rem; padding: 0.4rem 0.55rem; }
  }

  @media (max-width: 820px) {
    .nav__burger { display: flex; }

    .nav__menu {
      position: absolute;
      top: 78px;
      left: 0; right: 0;
      background: var(--white);
      flex-direction: column;
      align-items: flex-start;
      padding: 1.25rem 1.5rem 1.5rem;
      gap: 1rem;
      border-bottom: 2px solid var(--soft-sky);
      box-shadow: var(--shadow-md);
      display: none;
    }
    .nav__menu.is-open { display: flex; }

    .nav__links {
      flex-direction: column;
      align-items: flex-start;
      width: 100%;
      gap: 0;
    }
    .nav__link { display: block; width: 100%; padding: 0.7rem 0.8rem; font-size: 0.95rem; }

    .nav__lang { width: auto; }
    .nav__lang-menu {
      top: auto;
      bottom: calc(100% + 8px);
      right: auto;
      left: 0;
    }
  }
</style>

<script>
  const burger  = document.getElementById('navBurger');
  const menu    = document.getElementById('navMenu');
  const langBtn = document.getElementById('langBtn');
  const langMenu= document.getElementById('langMenu');

  burger?.addEventListener('click', () => {
    const open = menu?.classList.toggle('is-open');
    burger.classList.toggle('is-open', open);
    burger.setAttribute('aria-expanded', String(open));
  });

  langBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = langMenu?.classList.toggle('is-open');
    langBtn.setAttribute('aria-expanded', String(open));
  });

  document.addEventListener('click', () => {
    langMenu?.classList.remove('is-open');
    langBtn?.setAttribute('aria-expanded', 'false');
  });
</script>
