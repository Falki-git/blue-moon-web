---
import type { Translations } from '../i18n/utils';

interface Props {
  lang: string;
  T: Translations;
}

const { lang, T } = Astro.props;

const languages = [
  { code: 'en', flag: '🇬🇧', label: 'EN' },
  { code: 'hr', flag: '🇭🇷', label: 'HR' },
  { code: 'de', flag: '🇩🇪', label: 'DE' },
  { code: 'si', flag: '🇸🇮', label: 'SI' },
  { code: 'it', flag: '🇮🇹', label: 'IT' },
  { code: 'pl', flag: '🇵🇱', label: 'PL' },
  { code: 'cz', flag: '🇨🇿', label: 'CZ' },
];

const prefix = lang === 'en' ? '' : `/${lang}`;

const navLinks = [
  { href: `${prefix}/`,             label: T.nav.home },
  { href: `${prefix}/apartment`,    label: T.nav.apartment },
  { href: `${prefix}/gallery`,      label: T.nav.gallery },
  { href: `${prefix}/pricelist`,    label: T.nav.pricelist },
  { href: `${prefix}/booking`,      label: T.nav.booking },
  { href: `${prefix}/reviews`,      label: T.nav.reviews },
  { href: `${prefix}/about-mandre`, label: T.nav.aboutMandre },
  { href: `${prefix}/contact`,      label: T.nav.contact },
];

const currentPath = Astro.url.pathname;
const activeLang = languages.find(l => l.code === lang) ?? languages[0];

// For active link detection, check against both slug and prefixed paths
function isActive(href: string): boolean {
  if (href === `${prefix}/`) {
    return currentPath === `${prefix}/` || currentPath === prefix || currentPath === '/';
  }
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<nav class="nav" id="siteNav">
  <div class="nav__inner container">

    <div class="nav__left">
    <a href={`${prefix}/`} class="nav__logo" aria-label="Blue Moon Apartment - Home">
      <img src="/images/nav-logo.svg" alt="Blue Moon Apartment" width="120" height="60" />
    </a>

    <a
      href={`${prefix}/directions`}
      class="nav__address"
      aria-label="Directions to Blue Moon Apartment"
    >
      <svg class="nav__address-pin" width="14" height="20" viewBox="0 0 336 496" fill="currentColor" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
        <path d="M167.946 0C75.0262 0 0 75.2072 0 167.97C0 197.138 7.44304 224.582 20.4906 248.493L167.954 495.702L315.417 248.493C328.464 224.582 335.907 197.138 335.907 167.97C335.907 75.2035 260.879 0 167.961 0H167.946ZM166.078 97.6169C166.702 97.6011 167.319 97.6169 167.946 97.6169C208.086 97.6169 240.624 130.201 240.624 170.395C240.624 210.589 208.085 243.172 167.946 243.172C127.807 243.172 95.2683 210.589 95.2683 170.395C95.2683 130.829 126.806 98.6139 166.078 97.6169Z"/>
      </svg>
      <span class="nav__address-street">Riječka ulica 30, Mandre</span>
    </a>
    </div>

    <button class="nav__burger" id="navBurger" aria-label={T.nav.openMenu} aria-expanded="false" aria-controls="navMenu">
      <span></span><span></span><span></span>
    </button>

    <div class="nav__menu" id="navMenu" role="navigation">
      <ul class="nav__links">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={`nav__link ${isActive(link.href) ? 'is-active' : ''}`}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <div class="nav__lang" role="navigation" aria-label={T.nav.langSwitcherLabel}>
        <button class="nav__lang-trigger" aria-haspopup="true" aria-expanded="false" id="langBtn">
          {activeLang.flag} <span>{activeLang.label}</span> <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <ul class="nav__lang-menu" role="listbox" aria-label={T.nav.langSwitcherLabel} id="langMenu">
          {languages.map(l => {
            // Build the target URL: strip current lang prefix, add new lang prefix
            const targetHref = l.code === 'en' ? '/' : `/${l.code}`;
            return (
              <li role="option">
                <a
                  href={targetHref}
                  class={`nav__lang-item ${l.code === lang ? 'is-active' : ''}`}
                  data-lang={l.code}
                >
                  {l.flag} {l.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </div>
  </div>
</nav>

<style>
  .nav {
    background: var(--white);
    border-bottom: 1px solid rgba(74,159,212,0.15);
    position: sticky;
    top: 0;
    z-index: 200;
    box-shadow: 0 0 0 0 rgba(8,22,40,0);
    transition: box-shadow 0.35s ease, border-color 0.35s ease;
  }
  .nav.is-scrolled {
    border-bottom-color: transparent;
    box-shadow: 0 6px 20px rgba(8,22,40,0.18);
  }
  @media (prefers-reduced-motion: reduce) {
    .nav { transition: none; }
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-height);
    gap: 1.5rem;
  }

  .nav__logo img {
    height: 60px;
    width: auto;
    display: block;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }
  .nav__logo:hover img { transform: scale(1.04); opacity: 0.9; }

  .nav__menu {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex: 1;
    justify-content: flex-end;
  }

  .nav__links {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0;
    flex-wrap: wrap;
  }

  .nav__link {
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--text-dark);
    text-decoration: none;
    padding: 0.45rem 0.7rem;
    border-radius: 7px;
    transition: all 0.2s ease;
    letter-spacing: 0.01em;
    white-space: nowrap;
    display: block;
  }
  .nav__link:hover, .nav__link.is-active {
    color: var(--ocean-blue);
    background: rgba(74,159,212,0.1);
  }

  /* Language switcher */
  .nav__lang { position: relative; }

  .nav__lang-trigger {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    font-size: 0.82rem;
    background: var(--soft-sky);
    border: 1px solid rgba(74,159,212,0.25);
    border-radius: 8px;
    padding: 0.42rem 0.8rem;
    cursor: pointer;
    color: var(--ocean-blue);
    transition: background 0.2s;
    white-space: nowrap;
  }
  .nav__lang-trigger:hover { background: rgba(74,159,212,0.18); }

  .nav__lang-menu {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    background: var(--white);
    border: 1px solid rgba(74,159,212,0.18);
    border-radius: var(--radius);
    list-style: none;
    box-shadow: var(--shadow-md);
    min-width: 105px;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 300;
  }
  .nav__lang-menu.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .nav__lang-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1rem;
    font-family: 'Nunito', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-dark);
    text-decoration: none;
    transition: background 0.15s;
  }
  .nav__lang-item:hover, .nav__lang-item.is-active {
    background: var(--soft-sky);
    color: var(--ocean-blue);
  }

  /* Left group: logo + address */
  .nav__left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Address link */
  .nav__address {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    color: var(--text-dark);
    padding: 0.4rem 0.65rem;
    border-radius: 8px;
    transition: var(--transition);
    white-space: nowrap;
  }
  .nav__address:hover {
    background: rgba(74, 159, 212, 0.1);
    color: var(--ocean-blue);
  }
  .nav__address-pin { flex-shrink: 0; }
  .nav__address-street {
    font-family: 'Nunito', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* Burger */
  .nav__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 8px;
    transition: background 0.2s;
  }
  .nav__burger:hover { background: var(--soft-sky); }
  .nav__burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ocean-blue);
    border-radius: 2px;
    transition: all 0.3s ease;
    transform-origin: center;
  }
  .nav__burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav__burger.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .nav__burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile */
  @media (max-width: 980px) {
    .nav__address-street { display: none; }
    .nav__link { font-size: 0.8rem; padding: 0.4rem 0.55rem; }
  }

  @media (max-width: 820px) {
    .nav__burger { display: flex; }
    .nav__logo img { height: 48px; }

    .nav__menu {
      position: absolute;
      top: var(--nav-height);
      left: 0; right: 0;
      background: var(--white);
      flex-direction: column;
      align-items: flex-start;
      padding: 1.25rem 1.5rem 1.5rem;
      gap: 1rem;
      border-bottom: 2px solid var(--soft-sky);
      box-shadow: var(--shadow-md);
      display: none;
    }
    .nav__menu.is-open { display: flex; }

    .nav__links {
      flex-direction: column;
      align-items: flex-start;
      width: 100%;
      gap: 0;
    }
    .nav__link { display: block; width: 100%; padding: 0.7rem 0.8rem; font-size: 0.95rem; }

    .nav__lang { width: auto; }
    .nav__lang-menu {
      top: auto;
      bottom: calc(100% + 8px);
      right: auto;
      left: 0;
    }
  }
</style>

<script>
  const burger  = document.getElementById('navBurger');
  const menu    = document.getElementById('navMenu');
  const langBtn = document.getElementById('langBtn');
  const langMenu= document.getElementById('langMenu');

  burger?.addEventListener('click', () => {
    const open = menu?.classList.toggle('is-open');
    burger.classList.toggle('is-open', open);
    burger.setAttribute('aria-expanded', String(open));
  });

  langBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = langMenu?.classList.toggle('is-open');
    langBtn.setAttribute('aria-expanded', String(open));
  });

  document.addEventListener('click', () => {
    langMenu?.classList.remove('is-open');
    langBtn?.setAttribute('aria-expanded', 'false');
  });

  // Write bm_lang cookie and navigate to the correct language URL
  langMenu?.querySelectorAll<HTMLAnchorElement>('a[data-lang]').forEach(a => {
    a.addEventListener('click', (e) => {
      const targetLang = a.getAttribute('data-lang') ?? 'en';
      document.cookie = `bm_lang=${targetLang}; path=/; max-age=604800; SameSite=Lax`;

      // Build target URL: strip current lang prefix, add new lang prefix
      const SUPPORTED = ['en','hr','de','si','it','pl','cz'];
      const path = location.pathname;
      const segs = path.split('/').filter(Boolean);
      const currentLangInUrl = segs.length > 0 && SUPPORTED.indexOf(segs[0]) !== -1 ? segs[0] : 'en';
      let slug = currentLangInUrl !== 'en' ? path.replace('/' + currentLangInUrl, '') || '/' : path;
      const targetUrl = targetLang === 'en' ? slug : '/' + targetLang + slug;

      e.preventDefault();
      location.href = targetUrl;
    });
  });

  const nav       = document.getElementById('siteNav');
  const seasonBar = document.getElementById('seasonBar');
  if (nav) {
    let lastY = 0;
    let ticking = false;
    const update = () => {
      const y = window.scrollY;
      nav.classList.toggle('is-scrolled', y > 4);
      if (seasonBar) {
        if (y > 50 && y > lastY) {
          seasonBar.classList.add('is-hidden');
        } else if (y < lastY || y <= 0) {
          seasonBar.classList.remove('is-hidden');
        }
      }
      lastY = y;
      ticking = false;
    };
    update();
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
  }
</script>
