---
const phone = '385981234567';
const message = encodeURIComponent('Hello! I\'m interested in booking Blue Moon Apartment.');
const href = `https://wa.me/${phone}?text=${message}`;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="whatsapp-fab"
  aria-label="Chat with us on WhatsApp"
  title="Chat on WhatsApp"
>
  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="26" height="26">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
  <span class="whatsapp-fab__label">Chat with us</span>
</a>

<style>
  .whatsapp-fab {
    position: fixed;
    bottom: 1.75rem;
    right: 1.75rem;
    z-index: 500;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: #25D366;
    color: white;
    border-radius: 50px;
    padding: 0.75rem 1.25rem 0.75rem 0.9rem;
    box-shadow: 0 4px 20px rgba(37,211,102,0.45);
    text-decoration: none;
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    font-size: 0.88rem;
    transition: all 0.3s ease;
    overflow: hidden;
    max-width: 180px;
  }

  .whatsapp-fab:hover {
    background: #20b858;
    box-shadow: 0 6px 28px rgba(37,211,102,0.55);
    transform: translateY(-3px);
  }

  .whatsapp-fab svg { flex-shrink: 0; }

  .whatsapp-fab__label {
    white-space: nowrap;
    color: white;
  }

  @media (max-width: 520px) {
    .whatsapp-fab {
      bottom: 1.25rem;
      right: 1.25rem;
      padding: 0.85rem;
      border-radius: 50%;
      max-width: none;
    }
    .whatsapp-fab__label { display: none; }
  }
</style>
