---
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  pageTitle: string;
  pageSubtitle?: string;
  label?: string;
  bgClass?: string;
  bgImage?: ImageMetadata;
  heroObjectPosition?: string;
}

const {
  title,
  description,
  pageTitle,
  pageSubtitle,
  label,
  bgClass = 'ph-sea',
  bgImage,
  heroObjectPosition = 'center',
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <header class="page-header">
    <div class={`page-header__bg ${bgImage ? '' : `img-ph ${bgClass}`} ar-hero`} aria-hidden="true">
      {bgImage
        ? <Image
            src={bgImage}
            alt=""
            widths={[800, 1280, 1920]}
            sizes="100vw"
            style={`width:100%; height:100%; object-fit:cover; object-position:${heroObjectPosition};`}
            loading="eager"
          />
        : <span class="ph-icon">📷</span>
      }
    </div>
    <div class="page-header__overlay"></div>
    <div class="page-header__content container">
      {label && <span class="section-label">{label}</span>}
      <h1>{pageTitle}</h1>
      {pageSubtitle && <p class="page-header__sub">{pageSubtitle}</p>}
    </div>
  </header>

  <slot />
</BaseLayout>

<style>
  .page-header {
    position: relative;
    overflow: hidden;
    min-height: 260px;
    display: flex;
    align-items: flex-end;
  }

  .page-header__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: 0 !important;
  }

  .page-header__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(8,22,40,0.65) 0%, rgba(8,22,40,0.2) 60%, transparent 100%);
  }

  .page-header__content {
    position: relative;
    z-index: 1;
    padding-bottom: 2.5rem;
    padding-top: 4rem;
    width: 100%;
  }

  .page-header__content .section-label {
    color: var(--sunset-gold);
    margin-bottom: 0.5rem;
    text-shadow: 0 1px 6px rgba(8,22,40,1), 0 0 16px rgba(8,22,40,1), 0 0 40px rgba(8,22,40,0.9);
  }

  .page-header__content h1 {
    color: var(--white);
    text-shadow: 0 2px 12px rgba(8,22,40,0.4);
    margin-bottom: 0.5rem;
  }

  .page-header__sub {
    color: rgba(255,255,255,0.85);
    font-size: 1.1rem;
    font-weight: 600;
    font-family: 'Nunito', sans-serif;
    text-shadow: 0 1px 6px rgba(8,22,40,0.3);
  }
</style>
