---
import '../../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/images/logo.svg" />
  <title>Admin | Blue Moon Apartment</title>
</head>
<body class="adm-body">
  <header class="adm-header">
    <div class="adm-header__inner">
      <a href="/" class="adm-header__brand">
        <img src="/images/nav-logo.svg" alt="Blue Moon Apartment" width="100" height="50" />
      </a>
      <span class="adm-header__title">Admin</span>
      <button class="btn btn-secondary adm-header__logout" id="logoutBtn" type="button">Sign out</button>
    </div>
  </header>

  <nav class="adm-tabnav">
    <div class="adm-tabnav__inner">
      <button class="adm-tabnav__tab adm-tabnav__tab--active" data-tab="booking" type="button">
        Booking
        <span class="adm-tabnav__badge" id="tabPendingBadge" hidden>0</span>
      </button>
      <button class="adm-tabnav__tab" data-tab="settings" type="button">Settings</button>
      <button class="adm-tabnav__tab" data-tab="cleaning" type="button">Cleaning Crew Data</button>
    </div>
  </nav>

  <main class="adm-main">
    <div id="loading" class="adm-loading">Loading…</div>
    <div id="content" hidden>

      <div id="panel-booking" class="adm-panel">

        <section class="adm-section">
          <div class="adm-section__head">
            <h2>Pending requests</h2>
            <span class="adm-count" id="pendingCount">0</span>
          </div>
          <div id="pendingList"></div>
        </section>

        <section class="adm-section">
          <div class="adm-section__head">
            <h2>Confirmed reservations</h2>
            <span class="adm-count" id="confirmedCount">0</span>
          </div>
          <div id="confirmedList"></div>
        </section>

        <section class="adm-section">
          <div class="adm-section__head">
            <h2>Other reservations</h2>
            <span class="adm-count" id="otherCount">0</span>
          </div>
          <p class="adm-section__hint">Declined and cancelled reservations are kept for audit but no longer hold any dates.</p>
          <div id="otherList"></div>
        </section>

      </div><!-- /panel-booking -->

      <div id="panel-settings" class="adm-panel" hidden>

        <section class="adm-section">
          <div class="adm-section__head">
            <h2>Manual blocks</h2>
          </div>
          <p class="adm-section__hint">Use this for off-platform bookings (Booking.com, owner stays, maintenance). Both dates are inclusive.</p>

          <form id="blockForm" class="adm-block-form">
            <div class="adm-form-row">
              <div class="form-group">
                <label for="blockFrom">From</label>
                <input type="date" id="blockFrom" name="from" required min="2026-06-01" max="2026-09-30" />
              </div>
              <div class="form-group">
                <label for="blockTo">To</label>
                <input type="date" id="blockTo" name="to" required min="2026-06-01" max="2026-09-30" />
              </div>
              <div class="form-group" style="flex:1;">
                <label for="blockNote">Note (optional)</label>
                <input type="text" id="blockNote" name="note" placeholder="e.g. Booking.com reservation" />
              </div>
              <button type="submit" class="btn btn-primary">Add block</button>
            </div>
            <p class="adm-form-error" id="blockError" hidden></p>
          </form>

          <div id="blocksList"></div>
        </section>

        <section class="adm-section">
          <div class="adm-section__head">
            <h2>Pricing (per night, EUR)</h2>
          </div>
          <p class="adm-section__hint">Changes apply to new reservation requests immediately. Already-confirmed reservations keep their original price.</p>
          <div id="pricingList"></div>
        </section>

        <section class="adm-section">
          <div class="adm-section__head">
            <h2>Booking settings</h2>
          </div>
          <p class="adm-section__hint">These settings apply immediately to all new booking requests.</p>
          <div id="settingsList"></div>
        </section>

      </div><!-- /panel-settings -->

      <div id="panel-cleaning" class="adm-panel" hidden>

        <section class="adm-section">
          <div class="adm-section__head">
            <h2>Add guest</h2>
          </div>
          <p class="adm-section__hint">Enter guest details manually. Nights is calculated automatically from the dates you select.</p>

          <form id="guestForm" class="adm-guest-form">
            <div class="adm-form-row">
              <div class="form-group" style="flex:2;">
                <label for="gf-name">Guest name *</label>
                <input type="text" id="gf-name" name="guest_name" required placeholder="Full name" />
              </div>
              <div class="form-group" style="flex:1;">
                <label for="gf-booking">Booking number</label>
                <input type="text" id="gf-booking" name="booking_number" placeholder="e.g. 1234567890" />
              </div>
            </div>
            <div class="adm-form-row">
              <div class="form-group">
                <label for="gf-checkin">Check-in *</label>
                <input type="date" id="gf-checkin" name="check_in" required />
              </div>
              <div class="form-group">
                <label for="gf-checkout">Check-out *</label>
                <input type="date" id="gf-checkout" name="check_out" required />
              </div>
              <div class="form-group">
                <label for="gf-nights">Nights</label>
                <input type="number" id="gf-nights" name="nights" min="1" readonly
                       style="background:var(--soft-sky);color:var(--text-muted);cursor:default;" />
              </div>
              <div class="form-group">
                <label for="gf-bdate">Booking date</label>
                <input type="date" id="gf-bdate" name="booking_date" />
              </div>
            </div>
            <div class="adm-form-row">
              <div class="form-group">
                <label for="gf-checkin-hour">Check-in hour</label>
                <input type="text" id="gf-checkin-hour" name="checkin_hour" placeholder="e.g. 15:00" />
              </div>
              <div class="form-group">
                <label for="gf-checkout-hour">Check-out hour</label>
                <input type="text" id="gf-checkout-hour" name="checkout_hour" placeholder="e.g. 10:00" />
              </div>
            </div>
            <div class="adm-form-row">
              <div class="form-group">
                <label for="gf-country">Country</label>
                <select id="gf-country" name="country">
                  <option value="">— select —</option>
                  <option>Croatia</option>
                  <option>Czechia</option>
                  <option>Germany</option>
                  <option>Italy</option>
                  <option>Poland</option>
                  <option>Slovakia</option>
                  <option>Slovenia</option>
                  <option>Switzerland</option>
                  <option>United Kingdom</option>
                  <option>Other</option>
                </select>
              </div>
              <div class="form-group">
                <label for="gf-total">Total guests *</label>
                <input type="number" id="gf-total" name="total_guests" min="1" value="1" required />
              </div>
              <div class="form-group">
                <label for="gf-adults">Adults *</label>
                <input type="number" id="gf-adults" name="adults" min="0" value="1" required />
              </div>
              <div class="form-group">
                <label for="gf-children">Children</label>
                <input type="number" id="gf-children" name="children" min="0" value="0" />
              </div>
            </div>
            <div class="adm-form-row">
              <div class="form-group" style="flex:1;">
                <label for="gf-cages">Children's ages</label>
                <input type="text" id="gf-cages" name="children_ages" placeholder="e.g. 3, 7" />
              </div>
              <div class="form-group" style="flex:1;">
                <label for="gf-email">Email</label>
                <input type="email" id="gf-email" name="email" />
              </div>
              <div class="form-group" style="flex:1;">
                <label for="gf-phone">Phone</label>
                <input type="tel" id="gf-phone" name="phone" />
              </div>
            </div>
            <div class="adm-form-row">
              <div class="form-group" style="flex:1;">
                <label for="gf-notes">Notes</label>
                <input type="text" id="gf-notes" name="notes" placeholder="Any special notes for the cleaning crew" />
              </div>
            </div>
            <div class="adm-form-row" style="margin-top:0.5rem;">
              <button type="submit" class="btn btn-primary">Add guest</button>
            </div>
            <p class="adm-form-error" id="guestError" hidden></p>
          </form>
        </section>

        <section class="adm-section">
          <div class="adm-section__head">
            <h2>Guest list</h2>
            <span class="adm-count" id="guestCount">0</span>
          </div>
          <div id="guestsList"></div>
        </section>

      </div><!-- /panel-cleaning -->

    </div>
  </main>

  <style is:global>
    .adm-body {
      background: var(--soft-sky);
      min-height: 100vh;
      margin: 0;
    }

    .adm-header {
      background: var(--white);
      border-bottom: 1px solid rgba(74,159,212,0.15);
      box-shadow: var(--shadow-xs);
    }
    .adm-header__inner {
      max-width: 1180px;
      margin: 0 auto;
      padding: 0.85rem 2rem;
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }
    .adm-header__brand img { display: block; height: 44px; width: auto; }
    .adm-header__title {
      flex: 1;
      font-family: 'Playfair Display', serif;
      font-weight: 700;
      color: var(--ocean-blue);
      font-size: 1.1rem;
    }
    .adm-header__logout { padding: 0.5rem 1rem; font-size: 0.82rem; }

    .adm-tabnav {
      background: var(--white);
      border-bottom: 2px solid rgba(74,159,212,0.15);
    }
    .adm-tabnav__inner {
      max-width: 1180px;
      margin: 0 auto;
      padding: 0 2rem;
      display: flex;
    }
    .adm-tabnav__tab {
      font-family: 'Nunito', sans-serif;
      font-size: 0.88rem;
      font-weight: 800;
      color: var(--text-muted);
      background: none;
      border: none;
      border-bottom: 3px solid transparent;
      margin-bottom: -2px;
      padding: 0.85rem 1.25rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 0.45rem;
      transition: color 0.15s, border-color 0.15s;
    }
    .adm-tabnav__tab:hover { color: var(--ocean-blue); }
    .adm-tabnav__tab--active {
      color: var(--ocean-blue);
      border-bottom-color: var(--ocean-blue);
    }
    .adm-tabnav__badge {
      background: var(--ocean-blue);
      color: var(--white);
      font-size: 0.68rem;
      font-weight: 800;
      padding: 0.1rem 0.45rem;
      border-radius: 999px;
      min-width: 18px;
      text-align: center;
      line-height: 1.5;
    }

    .adm-main { max-width: 1180px; margin: 0 auto; padding: 2rem; }

    .adm-loading {
      text-align: center;
      padding: 4rem;
      color: var(--text-muted);
      font-weight: 700;
    }

    .adm-section {
      background: var(--white);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-xs);
      padding: 1.5rem 1.75rem;
      margin-bottom: 1.5rem;
    }
    .adm-section__head {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }
    .adm-section__head h2 { font-size: 1.25rem; margin: 0; }
    .adm-section__hint { color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1rem; }

    .adm-count {
      background: var(--soft-sky);
      color: var(--ocean-blue);
      font-size: 0.78rem;
      font-weight: 800;
      padding: 0.15rem 0.6rem;
      border-radius: 999px;
    }

    .adm-empty {
      color: var(--text-muted);
      font-size: 0.88rem;
      font-style: italic;
      text-align: center;
      padding: 1rem;
    }

    .adm-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.86rem;
    }
    .adm-table th {
      text-align: left;
      font-size: 0.7rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--text-muted);
      font-weight: 800;
      padding: 0.5rem 0.75rem;
      border-bottom: 1px solid rgba(74,159,212,0.15);
    }
    .adm-table td {
      padding: 0.75rem;
      border-bottom: 1px solid rgba(74,159,212,0.08);
      vertical-align: top;
    }
    .adm-table tr:last-child td { border-bottom: none; }
    .adm-table strong { color: var(--text-dark); font-weight: 700; }

    .adm-status {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.15rem 0.55rem;
      border-radius: 999px;
    }
    .adm-status--pending   { background: #f7e8c4; color: #8a6d2a; }
    .adm-status--confirmed { background: #c6e8f7; color: var(--ocean-blue); }
    .adm-status--declined  { background: #f1dada; color: #a64141; }
    .adm-status--cancelled { background: #d4d9de; color: #6a7989; }

    .adm-actions { display: flex; gap: 0.4rem; flex-wrap: wrap; align-items: flex-start; }
    .adm-btn {
      font-family: 'Nunito', sans-serif;
      font-weight: 700;
      font-size: 0.78rem;
      padding: 0.4rem 0.8rem;
      border-radius: 8px;
      border: 1px solid transparent;
      cursor: pointer;
      transition: background 0.15s, color 0.15s;
    }
    .adm-btn--approve { background: var(--ocean-blue); color: var(--white); }
    .adm-btn--approve:hover { background: #1452a0; }
    .adm-btn--decline { background: var(--white); color: #a64141; border-color: #f1dada; }
    .adm-btn--decline:hover { background: #f1dada; }
    .adm-btn--cancel  { background: var(--white); color: #a64141; border-color: #f1dada; }
    .adm-btn--cancel:hover  { background: #f1dada; }
    .adm-btn--deposit { background: #e8f5e9; color: #2e7d32; border-color: #a5d6a7; }
    .adm-btn--deposit:hover { background: #c8e6c9; }
    .adm-btn--deposit-resend { background: var(--white); color: #6a7989; border-color: #d4d9de; }
    .adm-btn--deposit-resend:hover { background: #d4d9de; }
    .adm-btn--remove  { background: var(--white); color: #a64141; border-color: #f1dada; }
    .adm-btn--remove:hover  { background: #f1dada; }
    .adm-btn--sm { padding: 0.25rem 0.6rem; font-size: 0.74rem; }

    .adm-block-form { margin-bottom: 1rem; }
    .adm-guest-form { margin-bottom: 1rem; }
    .adm-guest-form .adm-form-row + .adm-form-row { margin-top: 0.75rem; }
    .adm-guest-edit-row td { background: var(--white); padding: 0.75rem 0.75rem 1rem; border-top: 2px solid var(--sky-blue); }
    .adm-guest-edit-form .adm-form-row + .adm-form-row { margin-top: 0.6rem; }
    .adm-form-row {
      display: flex;
      align-items: end;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .adm-form-row .form-group { display: flex; flex-direction: column; gap: 0.3rem; }
    .adm-form-row label {
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--text-muted);
    }
    .adm-form-row input,
    .adm-form-row select {
      font-family: 'Nunito', sans-serif;
      font-size: 0.9rem;
      background: var(--soft-sky);
      border: 2px solid transparent;
      border-radius: var(--radius);
      padding: 0.55rem 0.85rem;
      outline: none;
      color: var(--text-dark);
    }
    .adm-form-row input:focus,
    .adm-form-row select:focus { border-color: var(--sky-blue); background: var(--white); }
    .adm-form-row .btn { padding: 0.6rem 1.5rem; font-size: 0.85rem; }
    .adm-form-error { color: #a64141; font-size: 0.82rem; font-weight: 700; margin-top: 0.5rem; }

    .adm-pricing-row {
      display: grid;
      grid-template-columns: 120px 1fr auto auto;
      gap: 1rem;
      align-items: center;
      padding: 0.75rem 0;
      border-bottom: 1px solid rgba(74,159,212,0.1);
    }
    .adm-pricing-row:last-child { border-bottom: none; }
    .adm-pricing-row__month { font-weight: 800; color: var(--ocean-blue); }
    .adm-pricing-row__updated { color: var(--text-muted); font-size: 0.78rem; }
    .adm-pricing-row__input {
      font-family: 'Nunito', sans-serif;
      font-size: 0.95rem;
      font-weight: 700;
      background: var(--soft-sky);
      border: 2px solid transparent;
      border-radius: var(--radius);
      padding: 0.5rem 0.85rem;
      outline: none;
      width: 110px;
      text-align: right;
    }
    .adm-pricing-row__input:focus { border-color: var(--sky-blue); background: var(--white); }
    .adm-pricing-row__btn {
      background: var(--ocean-blue);
      color: var(--white);
      border: none;
      border-radius: 8px;
      padding: 0.5rem 1rem;
      font-weight: 800;
      cursor: pointer;
    }
    .adm-pricing-row__btn:hover { background: #1452a0; }
    .adm-pricing-row__btn--saved { background: #4caf50; }

    .adm-settings-row {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
      padding: 0.75rem 0;
    }
    .adm-settings-row__label {
      font-weight: 800;
      color: var(--ocean-blue);
      margin-bottom: 0.2rem;
    }
    .adm-settings-row__hint { color: var(--text-muted); font-size: 0.78rem; }
    .adm-settings-row__input {
      font-family: 'Nunito', sans-serif;
      font-size: 0.95rem;
      font-weight: 700;
      background: var(--soft-sky);
      border: 2px solid transparent;
      border-radius: var(--radius);
      padding: 0.5rem 0.85rem;
      outline: none;
      width: 80px;
      text-align: right;
    }
    .adm-settings-row__input:focus { border-color: var(--sky-blue); background: var(--white); }

    @media (max-width: 720px) {
      .adm-main { padding: 1rem; }
      .adm-tabnav__inner { padding: 0 1rem; }
      .adm-section { padding: 1rem; }
      .adm-form-row { flex-direction: column; align-items: stretch; }
      .adm-pricing-row { grid-template-columns: 1fr 1fr; }
      .adm-pricing-row__updated { display: none; }
      .adm-table { font-size: 0.78rem; }
      .adm-table th, .adm-table td { padding: 0.4rem 0.45rem; }
    }
  </style>

  <script>
    type BookingSettings = { minAdvanceDays: number };
    type Reservation = {
      id: string;
      created_at: number;
      status: 'pending' | 'confirmed' | 'declined' | 'cancelled';
      full_name: string; email: string; phone: string | null; language: string | null;
      address: string | null; source: string | null;
      guests: number; children_ages: string | null;
      check_in: string; check_out: string; nights: number; total_eur: number;
      message: string | null; decided_at: number | null; deposit_confirmation_sent_at: number | null;
    };
    type ManualBlock = { id: string; created_at: number; from_date: string; to_date: string; note: string | null };
    type PricingRule = { month: number; rate_eur: number; updated_at: number };
    type CleaningGuest = {
      id: string; guest_name: string; booking_number: string | null; country: string | null;
      check_in: string; check_out: string; booking_date: string | null;
      total_guests: number; adults: number; children: number; children_ages: string | null;
      nights: number; email: string | null; phone: string | null; notes: string | null;
      checkin_hour: string | null; checkout_hour: string | null;
    };

    const loading = document.getElementById('loading')!;
    const content = document.getElementById('content')!;
    const logoutBtn = document.getElementById('logoutBtn') as HTMLButtonElement;

    let editingGuestId: string | null = null;
    let currentGuests: CleaningGuest[] = [];

    const COUNTRIES = ['Croatia','Czechia','Germany','Italy','Poland','Slovakia','Slovenia','Switzerland','United Kingdom','Other'];

    function countryOptions(selected: string | null): string {
      return `<option value="">— select —</option>` +
        COUNTRIES.map(c => `<option${selected === c ? ' selected' : ''}>${esc(c)}</option>`).join('');
    }

    function renderGuestTable(guests: CleaningGuest[]): string {
      if (guests.length === 0) return '<p class="adm-empty">No guests entered yet.</p>';
      const rows = guests.map(g => {
        const isEditing = editingGuestId === g.id;
        const editRow = isEditing ? `
          <tr class="adm-guest-edit-row">
            <td colspan="8">
              <div class="adm-guest-edit-form">
                <div class="adm-form-row">
                  <div class="form-group" style="flex:2;">
                    <label>Guest name *</label>
                    <input type="text" id="ef-name-${g.id}" value="${esc(g.guest_name)}" />
                  </div>
                  <div class="form-group" style="flex:1;">
                    <label>Booking number</label>
                    <input type="text" id="ef-booking-${g.id}" value="${esc(g.booking_number ?? '')}" />
                  </div>
                </div>
                <div class="adm-form-row">
                  <div class="form-group">
                    <label>Check-in *</label>
                    <input type="date" id="ef-checkin-${g.id}" value="${g.check_in}" onchange="__calcEditNights('${g.id}')" />
                  </div>
                  <div class="form-group">
                    <label>Check-out *</label>
                    <input type="date" id="ef-checkout-${g.id}" value="${g.check_out}" onchange="__calcEditNights('${g.id}')" />
                  </div>
                  <div class="form-group">
                    <label>Nights</label>
                    <input type="number" id="ef-nights-${g.id}" value="${g.nights}" min="1" readonly style="background:var(--soft-sky);color:var(--text-muted);cursor:default;" />
                  </div>
                  <div class="form-group">
                    <label>Booking date</label>
                    <input type="date" id="ef-bdate-${g.id}" value="${g.booking_date ?? ''}" />
                  </div>
                </div>
                <div class="adm-form-row">
                  <div class="form-group">
                    <label>Check-in hour</label>
                    <input type="text" id="ef-checkin-hour-${g.id}" value="${esc(g.checkin_hour ?? '')}" placeholder="e.g. 15:00" />
                  </div>
                  <div class="form-group">
                    <label>Check-out hour</label>
                    <input type="text" id="ef-checkout-hour-${g.id}" value="${esc(g.checkout_hour ?? '')}" placeholder="e.g. 10:00" />
                  </div>
                </div>
                <div class="adm-form-row">
                  <div class="form-group">
                    <label>Country</label>
                    <select id="ef-country-${g.id}">${countryOptions(g.country)}</select>
                  </div>
                  <div class="form-group">
                    <label>Total guests *</label>
                    <input type="number" id="ef-total-${g.id}" value="${g.total_guests}" min="1" />
                  </div>
                  <div class="form-group">
                    <label>Adults *</label>
                    <input type="number" id="ef-adults-${g.id}" value="${g.adults}" min="0" />
                  </div>
                  <div class="form-group">
                    <label>Children</label>
                    <input type="number" id="ef-children-${g.id}" value="${g.children}" min="0" />
                  </div>
                </div>
                <div class="adm-form-row">
                  <div class="form-group" style="flex:1;">
                    <label>Children's ages</label>
                    <input type="text" id="ef-cages-${g.id}" value="${esc(g.children_ages ?? '')}" />
                  </div>
                  <div class="form-group" style="flex:1;">
                    <label>Email</label>
                    <input type="email" id="ef-email-${g.id}" value="${esc(g.email ?? '')}" />
                  </div>
                  <div class="form-group" style="flex:1;">
                    <label>Phone</label>
                    <input type="tel" id="ef-phone-${g.id}" value="${esc(g.phone ?? '')}" />
                  </div>
                </div>
                <div class="adm-form-row">
                  <div class="form-group" style="flex:1;">
                    <label>Notes</label>
                    <input type="text" id="ef-notes-${g.id}" value="${esc(g.notes ?? '')}" />
                  </div>
                </div>
                <div class="adm-form-row" style="margin-top:0.5rem;gap:0.5rem;">
                  <button class="btn btn-primary" style="font-size:0.85rem;padding:0.6rem 1.25rem;" onclick="__saveGuest('${g.id}')">Save changes</button>
                  <button class="adm-btn" style="background:var(--white);border:1px solid #d4d9de;" onclick="__cancelEdit()">Cancel</button>
                </div>
                <p class="adm-form-error" id="ef-error-${g.id}" hidden></p>
              </div>
            </td>
          </tr>` : '';
        return `
          <tr>
            <td><strong>${esc(g.guest_name)}</strong></td>
            <td>${fmtDate(g.check_in)}</td>
            <td>${fmtDate(g.check_out)}</td>
            <td>${g.nights}</td>
            <td>${g.total_guests}${g.children > 0 ? ` (${g.children} ch.)` : ''}</td>
            <td>${g.country ? esc(g.country) : '<span style="color:var(--text-light,#b0bec5);">—</span>'}</td>
            <td>${g.check_in.substring(0, 4)}</td>
            <td style="white-space:nowrap;">
              <button class="adm-btn adm-btn--sm${isEditing ? '' : ' adm-btn--remove'}" style="${isEditing ? 'background:var(--soft-sky);color:var(--ocean-blue);border-color:rgba(74,159,212,0.3);' : ''}" onclick="__editGuest('${g.id}')">Edit</button>
              <button class="adm-btn adm-btn--sm adm-btn--remove" onclick="__removeGuest('${g.id}')">Remove</button>
            </td>
          </tr>
          ${editRow}`;
      }).join('');
      return `<table class="adm-table"><thead><tr>
        <th>Guest</th><th>Check-in</th><th>Check-out</th>
        <th>Nights</th><th>Guests</th><th>Country</th><th>Season</th><th></th>
      </tr></thead><tbody>${rows}</tbody></table>`;
    }

    // ── Tabs ────────────────────────────────────────────────────────────────
    type TabName = 'booking' | 'settings' | 'cleaning';
    const tabBtns = document.querySelectorAll<HTMLButtonElement>('.adm-tabnav__tab');
    const panels  = {
      booking:  document.getElementById('panel-booking')!,
      settings: document.getElementById('panel-settings')!,
      cleaning: document.getElementById('panel-cleaning')!,
    };
    const tabPendingBadge = document.getElementById('tabPendingBadge')!;

    function switchTab(name: TabName) {
      tabBtns.forEach(b => b.classList.toggle('adm-tabnav__tab--active', b.dataset.tab === name));
      (Object.keys(panels) as TabName[]).forEach(k => { panels[k].hidden = k !== name; });
      const hash = name === 'settings' ? '#settings' : name === 'cleaning' ? '#cleaning' : location.pathname;
      history.replaceState(null, '', hash);
    }

    tabBtns.forEach(b => b.addEventListener('click', () => switchTab(b.dataset.tab as TabName)));

    const initialTab: TabName =
      location.hash === '#settings' ? 'settings' :
      location.hash === '#cleaning' ? 'cleaning' : 'booking';
    switchTab(initialTab);
    // ────────────────────────────────────────────────────────────────────────

    const monthName = (m: number) => ({6: 'June', 7: 'July', 8: 'August', 9: 'September'} as const)[m as 6|7|8|9];
    const fmtDate = (iso: string) => {
      const [y, mo, d] = iso.split('-').map(Number);
      return new Date(y, mo - 1, d).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
    };
    const fmtTs = (sec: number) => new Date(sec * 1000).toLocaleString('en-GB');
    const fmtEur = (n: number) => `€${n.toLocaleString('en-GB')}`;
    const depositEur = (total: number) => Math.round(total * 0.3);
    const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

    async function api<T>(path: string, init?: RequestInit): Promise<T> {
      const res = await fetch(path, {
        ...init,
        headers: { 'Content-Type': 'application/json', ...(init?.headers ?? {}) },
        credentials: 'same-origin',
      });
      if (res.status === 401) {
        window.location.href = '/admin/login';
        throw new Error('not authenticated');
      }
      const data = await res.json() as T & { ok?: boolean; error?: string };
      if ((data as any).ok === false) throw new Error((data as any).error ?? 'Request failed');
      return data;
    }

    function tableRows(reservations: Reservation[], actions: (r: Reservation) => string): string {
      if (reservations.length === 0) return '<p class="adm-empty">None.</p>';
      const rows = reservations.map(r => `
        <tr>
          <td><strong>${esc(r.full_name)}</strong><br><a href="mailto:${esc(r.email)}">${esc(r.email)}</a>${r.phone ? `<br>${esc(r.phone)}` : ''}</td>
          <td>${fmtDate(r.check_in)} → ${fmtDate(r.check_out)}<br><span style="color:var(--text-muted);font-size:0.78rem;">${r.nights} night${r.nights !== 1 ? 's' : ''}, ${r.guests} guest${r.guests !== 1 ? 's' : ''}</span></td>
          <td><strong>${fmtEur(r.total_eur)}</strong><br><span style="color:var(--text-muted);font-size:0.72rem;">Dep: ${fmtEur(depositEur(r.total_eur))} &middot; Arr: ${fmtEur(r.total_eur - depositEur(r.total_eur))}</span></td>
          <td><span class="adm-status adm-status--${r.status}">${r.status}</span><br><span style="color:var(--text-muted);font-size:0.72rem;">${fmtTs(r.created_at)}</span></td>
          <td><div class="adm-actions">${actions(r)}</div></td>
        </tr>
      `).join('');
      return `<table class="adm-table"><thead><tr><th>Guest</th><th>Stay</th><th>Total</th><th>Status</th><th></th></tr></thead><tbody>${rows}</tbody></table>`;
    }

    async function decide(id: string, action: 'approve' | 'decline' | 'cancel') {
      if (action === 'cancel' && !confirm('Delete this reservation? Dates will be released.')) return;
      try {
        await api(`/api/admin/reservations/${id}/decision`, {
          method: 'POST',
          body: JSON.stringify({ action }),
        });
        await refresh();
      } catch (e) {
        alert(e instanceof Error ? e.message : 'Action failed');
      }
    }
    (window as any).__decide = decide;

    async function sendDepositConfirmation(id: string) {
      if (!confirm('Send deposit received confirmation to the guest?')) return;
      try {
        await api(`/api/admin/reservations/${id}/deposit-received`, { method: 'POST' });
        await refresh();
      } catch (e) {
        alert(e instanceof Error ? e.message : 'Failed to send email');
      }
    }
    (window as any).__sendDepositConfirmation = sendDepositConfirmation;

    async function removeBlock(id: string) {
      if (!confirm('Remove this manual block?')) return;
      try {
        await api(`/api/admin/blocks/${id}`, { method: 'DELETE' });
        await refresh();
      } catch (e) {
        alert(e instanceof Error ? e.message : 'Action failed');
      }
    }
    (window as any).__removeBlock = removeBlock;

    async function removeGuest(id: string) {
      if (!confirm('Remove this guest entry?')) return;
      try {
        await api(`/api/admin/cleaning-guests/${id}`, { method: 'DELETE' });
        if (editingGuestId === id) editingGuestId = null;
        await refresh();
      } catch (e) {
        alert(e instanceof Error ? e.message : 'Action failed');
      }
    }
    (window as any).__removeGuest = removeGuest;

    function editGuest(id: string) {
      editingGuestId = id;
      document.getElementById('guestsList')!.innerHTML = renderGuestTable(currentGuests);
    }
    (window as any).__editGuest = editGuest;

    function cancelEdit() {
      editingGuestId = null;
      document.getElementById('guestsList')!.innerHTML = renderGuestTable(currentGuests);
    }
    (window as any).__cancelEdit = cancelEdit;

    function calcEditNights(id: string) {
      const ci = (document.getElementById(`ef-checkin-${id}`) as HTMLInputElement)?.value;
      const co = (document.getElementById(`ef-checkout-${id}`) as HTMLInputElement)?.value;
      const nightsEl = document.getElementById(`ef-nights-${id}`) as HTMLInputElement;
      if (ci && co && co > ci) {
        nightsEl.value = String(Math.round((new Date(co).getTime() - new Date(ci).getTime()) / 86400000));
      } else {
        nightsEl.value = '';
      }
    }
    (window as any).__calcEditNights = calcEditNights;

    async function saveGuest(id: string) {
      const errEl = document.getElementById(`ef-error-${id}`) as HTMLElement | null;
      if (errEl) errEl.hidden = true;
      const get = (suffix: string) =>
        (document.getElementById(`ef-${suffix}-${id}`) as HTMLInputElement | HTMLSelectElement | null)?.value ?? '';
      const body = {
        guest_name:     get('name').trim(),
        booking_number: get('booking').trim() || null,
        country:        get('country') || null,
        check_in:       get('checkin'),
        check_out:      get('checkout'),
        booking_date:   get('bdate') || null,
        total_guests:   Number(get('total')),
        adults:         Number(get('adults')),
        children:       Number(get('children')),
        children_ages:  get('cages').trim() || null,
        nights:         Number(get('nights')),
        email:          get('email').trim() || null,
        phone:          get('phone').trim() || null,
        notes:          get('notes').trim() || null,
        checkin_hour:   get('checkin-hour').trim() || null,
        checkout_hour:  get('checkout-hour').trim() || null,
      };
      try {
        await api(`/api/admin/cleaning-guests/${id}`, {
          method: 'PUT',
          body: JSON.stringify(body),
        });
        editingGuestId = null;
        await refresh();
      } catch (e) {
        if (errEl) {
          errEl.textContent = e instanceof Error ? e.message : 'Save failed';
          errEl.hidden = false;
        } else {
          alert(e instanceof Error ? e.message : 'Save failed');
        }
      }
    }
    (window as any).__saveGuest = saveGuest;

    async function saveMinAdvanceDays() {
      const input = document.getElementById('setting-min-advance-days') as HTMLInputElement;
      const btn   = document.getElementById('setting-min-advance-btn') as HTMLButtonElement;
      const days  = Number(input.value);
      if (!Number.isInteger(days) || days < 0 || days > 30) { alert('Enter a valid number (0–30)'); return; }
      try {
        await api('/api/admin/settings', {
          method: 'POST',
          body: JSON.stringify({ minAdvanceDays: days }),
        });
        btn.classList.add('adm-pricing-row__btn--saved');
        btn.textContent = 'Saved ✓';
        setTimeout(() => {
          btn.classList.remove('adm-pricing-row__btn--saved');
          btn.textContent = 'Save';
        }, 1800);
        await refresh();
      } catch (e) {
        alert(e instanceof Error ? e.message : 'Save failed');
      }
    }
    (window as any).__saveMinAdvanceDays = saveMinAdvanceDays;

    async function savePricing(month: number) {
      const input = document.getElementById(`pr-rate-${month}`) as HTMLInputElement;
      const btn   = document.getElementById(`pr-btn-${month}`) as HTMLButtonElement;
      const rate  = Number(input.value);
      if (!Number.isFinite(rate) || rate < 0) { alert('Enter a valid rate'); return; }
      try {
        await api('/api/admin/pricing', {
          method: 'POST',
          body: JSON.stringify({ month, rate_eur: rate }),
        });
        btn.classList.add('adm-pricing-row__btn--saved');
        btn.textContent = 'Saved ✓';
        setTimeout(() => {
          btn.classList.remove('adm-pricing-row__btn--saved');
          btn.textContent = 'Save';
        }, 1800);
        await refresh();
      } catch (e) {
        alert(e instanceof Error ? e.message : 'Save failed');
      }
    }
    (window as any).__savePricing = savePricing;

    async function refresh() {
      const [resData, blockData, priceData, settingsData, cleaningData] = await Promise.all([
        api<{ reservations: Reservation[] }>('/api/admin/reservations'),
        api<{ blocks: ManualBlock[] }>('/api/admin/blocks'),
        api<{ pricing: PricingRule[] }>('/api/admin/pricing'),
        api<BookingSettings>('/api/admin/settings'),
        api<{ guests: CleaningGuest[] }>('/api/admin/cleaning-guests'),
      ]);

      const reservations = resData.reservations;
      const pending   = reservations.filter(r => r.status === 'pending');
      const confirmed = reservations.filter(r => r.status === 'confirmed');
      const other     = reservations.filter(r => r.status === 'declined' || r.status === 'cancelled');

      document.getElementById('pendingCount')!.textContent   = String(pending.length);
      document.getElementById('confirmedCount')!.textContent = String(confirmed.length);
      document.getElementById('otherCount')!.textContent     = String(other.length);

      tabPendingBadge.textContent = String(pending.length);
      tabPendingBadge.hidden = pending.length === 0;

      document.getElementById('pendingList')!.innerHTML = tableRows(pending, r => `
        <button class="adm-btn adm-btn--approve" onclick="__decide('${r.id}','approve')">Approve</button>
        <button class="adm-btn adm-btn--decline" onclick="__decide('${r.id}','decline')">Decline</button>
      `);
      document.getElementById('confirmedList')!.innerHTML = tableRows(confirmed, r => `
        <div style="display:flex;flex-direction:column;align-items:flex-start;gap:0.15rem;">
          <button class="adm-btn ${r.deposit_confirmation_sent_at ? 'adm-btn--deposit-resend' : 'adm-btn--deposit'}" onclick="__sendDepositConfirmation('${r.id}')">${r.deposit_confirmation_sent_at ? 'Resend deposit confirmation' : 'Send deposit confirmation'}</button>
          ${r.deposit_confirmation_sent_at ? `<span style="font-size:0.68rem;color:var(--text-muted);">&#10003; Email sent ${fmtTs(r.deposit_confirmation_sent_at)}</span>` : ''}
        </div>
        <button class="adm-btn adm-btn--cancel" onclick="__decide('${r.id}','cancel')">Delete reservation</button>
      `);
      document.getElementById('otherList')!.innerHTML = tableRows(other, () => '');

      const blocks = blockData.blocks;
      const blocksHtml = blocks.length === 0
        ? '<p class="adm-empty">No manual blocks.</p>'
        : `<table class="adm-table"><thead><tr><th>From</th><th>To</th><th>Note</th><th></th></tr></thead><tbody>${
            blocks.map(b => `
              <tr>
                <td>${fmtDate(b.from_date)}</td>
                <td>${fmtDate(b.to_date)}</td>
                <td>${b.note ? esc(b.note) : '<span style="color:var(--text-light);">—</span>'}</td>
                <td><button class="adm-btn adm-btn--remove" onclick="__removeBlock('${b.id}')">Remove</button></td>
              </tr>
            `).join('')
          }</tbody></table>`;
      document.getElementById('blocksList')!.innerHTML = blocksHtml;

      const pricingByMonth = new Map<number, PricingRule>();
      for (const p of priceData.pricing) pricingByMonth.set(p.month, p);
      const pricingHtml = [6, 7, 8, 9].map(m => {
        const p = pricingByMonth.get(m);
        const rate = p?.rate_eur ?? 0;
        const updated = p ? fmtTs(p.updated_at) : '—';
        return `
          <div class="adm-pricing-row">
            <div class="adm-pricing-row__month">${monthName(m)}</div>
            <div class="adm-pricing-row__updated">Last updated: ${updated}</div>
            <div style="display:flex;align-items:center;gap:0.4rem;">€<input type="number" id="pr-rate-${m}" class="adm-pricing-row__input" value="${rate}" min="0" max="10000" /></div>
            <button class="adm-pricing-row__btn" id="pr-btn-${m}" onclick="__savePricing(${m})">Save</button>
          </div>
        `;
      }).join('');
      document.getElementById('pricingList')!.innerHTML = pricingHtml;

      document.getElementById('settingsList')!.innerHTML = `
        <div class="adm-settings-row">
          <div style="flex:1;">
            <div class="adm-settings-row__label">Minimum advance booking days</div>
            <div class="adm-settings-row__hint">Guests must book this many days before their check-in date. 0 = same-day booking allowed.</div>
          </div>
          <input type="number" id="setting-min-advance-days" class="adm-settings-row__input" value="${settingsData.minAdvanceDays}" min="0" max="30" />
          <button class="adm-pricing-row__btn" id="setting-min-advance-btn" onclick="__saveMinAdvanceDays()">Save</button>
        </div>
      `;

      currentGuests = cleaningData.guests;
      document.getElementById('guestCount')!.textContent = String(currentGuests.length);
      document.getElementById('guestsList')!.innerHTML = renderGuestTable(currentGuests);
    }

    logoutBtn.addEventListener('click', async () => {
      try { await fetch('/api/admin/logout', { method: 'POST', credentials: 'same-origin' }); }
      finally { window.location.href = '/admin/login'; }
    });

    const blockForm = document.getElementById('blockForm') as HTMLFormElement;
    const blockError = document.getElementById('blockError') as HTMLElement;
    blockForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      blockError.hidden = true;
      const fd = new FormData(blockForm);
      try {
        await api('/api/admin/blocks', {
          method: 'POST',
          body: JSON.stringify({
            from: String(fd.get('from')),
            to:   String(fd.get('to')),
            note: String(fd.get('note') ?? ''),
          }),
        });
        blockForm.reset();
        await refresh();
      } catch (e) {
        blockError.textContent = e instanceof Error ? e.message : 'Failed to add block';
        blockError.hidden = false;
      }
    });

    function calcNights() {
      const ci = (document.getElementById('gf-checkin') as HTMLInputElement).value;
      const co = (document.getElementById('gf-checkout') as HTMLInputElement).value;
      const nightsInput = document.getElementById('gf-nights') as HTMLInputElement;
      if (ci && co && co > ci) {
        const diff = (new Date(co).getTime() - new Date(ci).getTime()) / 86400000;
        nightsInput.value = String(Math.round(diff));
      } else {
        nightsInput.value = '';
      }
    }
    document.getElementById('gf-checkin')!.addEventListener('change', calcNights);
    document.getElementById('gf-checkout')!.addEventListener('change', calcNights);

    const guestForm  = document.getElementById('guestForm') as HTMLFormElement;
    const guestError = document.getElementById('guestError') as HTMLElement;
    guestForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      guestError.hidden = true;
      const fd = new FormData(guestForm);
      const body = {
        guest_name:     String(fd.get('guest_name')    ?? ''),
        booking_number: String(fd.get('booking_number') ?? '') || null,
        country:        String(fd.get('country')        ?? '') || null,
        check_in:       String(fd.get('check_in')       ?? ''),
        check_out:      String(fd.get('check_out')      ?? ''),
        booking_date:   String(fd.get('booking_date')   ?? '') || null,
        total_guests:   Number(fd.get('total_guests')   ?? 1),
        adults:         Number(fd.get('adults')         ?? 1),
        children:       Number(fd.get('children')       ?? 0),
        children_ages:  String(fd.get('children_ages')  ?? '') || null,
        nights:         Number(fd.get('nights')         ?? 0),
        email:          String(fd.get('email')          ?? '') || null,
        phone:          String(fd.get('phone')          ?? '') || null,
        notes:          String(fd.get('notes')          ?? '') || null,
        checkin_hour:   String(fd.get('checkin_hour')   ?? '') || null,
        checkout_hour:  String(fd.get('checkout_hour')  ?? '') || null,
      };
      try {
        await api('/api/admin/cleaning-guests', {
          method: 'POST',
          body: JSON.stringify(body),
        });
        guestForm.reset();
        await refresh();
      } catch (e) {
        guestError.textContent = e instanceof Error ? e.message : 'Failed to add guest';
        guestError.hidden = false;
      }
    });

    refresh()
      .then(() => { loading.style.display = 'none'; content.hidden = false; })
      .catch(() => { /* api() already redirected */ });
  </script>
</body>
</html>
