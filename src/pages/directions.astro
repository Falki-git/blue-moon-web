---
import { Image } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';
import heroBg from '../assets/gallery/outside.jpg';
import findAptImg from '../assets/gallery/how to get to the apartment.jpg';
import parkingImg from '../assets/gallery/outdoor.jpg';
---

<PageLayout
  title="Directions | Blue Moon Apartment, Mandre, Island of Pag"
  description="How to reach Blue Moon Apartment in Mandre, island of Pag, Croatia. Directions by car from Zadar and Zagreb, by ferry, and parking information on arrival."
  pageTitle="How to Find Us"
  pageSubtitle="Riječka ulica 30, Mandre, Island of Pag, Croatia"
  label="Directions"
  bgClass="ph-town"
  bgImage={heroBg}
  heroObjectPosition="center 72%"
>

  <!-- ═══ ROUTES ═══ -->
  <section class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom:3rem;">
        <span class="section-label">Getting Here</span>
        <h2>Routes to Mandre</h2>
      </div>

      <div class="routes-grid">

        <!-- Route 1: Zagreb -->
        <div class="route-card card">
          <div class="route-card__header">
            <span class="route-icon">🚗</span>
            <div>
              <h3>From Zagreb</h3>
              <span class="route-time">~3.5 hours · ~280 km</span>
            </div>
          </div>
          <ol class="route-steps">
            <li>
              <span class="step-num">1</span>
              <p>From Zagreb, take the <strong>A1 motorway</strong> heading south towards Split.</p>
            </li>
            <li>
              <span class="step-num">2</span>
              <p>Exit at <strong>Otok Pag / Posedarje</strong> and follow signs towards <strong>Otok Pag</strong>.</p>
            </li>
            <li>
              <span class="step-num">3</span>
              <p>Cross the <strong>Pag Bridge</strong> onto the island.</p>
            </li>
            <li>
              <span class="step-num">4</span>
              <p>Follow the signs towards <strong>Novalja</strong>, then turn left to <strong>Kolan</strong> and on to <strong>Mandre</strong>.</p>
            </li>
            <li>
              <span class="step-num">5</span>
              <p>Enter Mandre. The apartment is at <strong>Riječka ulica 30, Mandre</strong>.</p>
            </li>
          </ol>
          <a href="https://www.google.com/maps/dir/?api=1&destination=Blue+Moon+Apartment&destination_place_id=ChIJjWwKavA3YkcRtIxHt59t0pQ" target="_blank" rel="noopener" class="btn btn-sky btn-sm route-btn">Navigate with Google Maps →</a>
        </div>

        <!-- Route 2: Ferry -->
        <div class="route-card card">
          <div class="route-card__header">
            <span class="route-icon">⛴️</span>
            <div>
              <h3>By Ferry</h3>
              <span class="route-time">Shorter route if coming from Rijeka or beyond</span>
            </div>
          </div>
          <ol class="route-steps">
            <li>
              <span class="step-num">1</span>
              <p>Head to <strong>Prizna</strong> on the mainland coast — the ferry port across from <strong>Žigljen</strong> on the island of Pag.</p>
            </li>
            <li>
              <span class="step-num">2</span>
              <p>Take the <strong>Jadrolinija car ferry</strong> from Prizna to <strong>Žigljen</strong> on the island of Pag. The crossing takes approximately 15 minutes. Ferries run frequently in summer.</p>
            </li>
            <li>
              <span class="step-num">3</span>
              <p>From Žigljen (near Novalja), drive <strong>south</strong> through Novalja and Kolan towards <strong>Mandre</strong>. Approximately 20 minutes from the ferry port.</p>
            </li>
          </ol>
          <div style="display:flex; gap:0.75rem; flex-wrap:wrap;">
            <a href="https://www.jadrolinija.hr/en/" target="_blank" rel="noopener" class="btn btn-sky btn-sm route-btn">Jadrolinija ferry schedule →</a>
            <a href="https://www.google.com/maps/dir/?api=1&destination=Blue+Moon+Apartment&destination_place_id=ChIJjWwKavA3YkcRtIxHt59t0pQ&waypoints=Trajekt+Prizna" target="_blank" rel="noopener" class="btn btn-sky btn-sm route-btn">Navigate via Ferry →</a>
          </div>
        </div>

        <!-- Route 3: Airport -->
        <div class="route-card card">
          <div class="route-card__header">
            <span class="route-icon">✈️</span>
            <div>
              <h3>Via Zadar Airport</h3>
              <span class="route-time">~75 km from airport · ~1 hour drive</span>
            </div>
          </div>
          <ol class="route-steps">
            <li>
              <span class="step-num">1</span>
              <p><strong>Zadar Airport (ZAD)</strong> has many seasonal European connections including Ryanair and easyJet routes. Rent a car at the airport — a car is useful for island exploration.</p>
            </li>
            <li>
              <span class="step-num">2</span>
              <p>From the airport, head towards <strong>Zemunik Donji</strong>, then continue to <strong>Suhovare</strong>.</p>
            </li>
            <li>
              <span class="step-num">3</span>
              <p>Follow the road towards the <strong>Pag Bridge (Paški Most)</strong> and cross onto the island.</p>
            </li>
            <li>
              <span class="step-num">4</span>
              <p>Continue north along the island towards <strong>Novalja</strong>, then turn left to <strong>Kolan</strong> and on to <strong>Mandre</strong>.</p>
            </li>
          </ol>
          <a href="https://www.google.com/maps/dir/?api=1&origin=Zadar+Airport&destination=Blue+Moon+Apartment&destination_place_id=ChIJjWwKavA3YkcRtIxHt59t0pQ" target="_blank" rel="noopener" class="btn btn-sky btn-sm route-btn">Directions from Airport →</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ FINDING THE APARTMENT ═══ -->
  <section class="section" style="background:var(--soft-sky);">
    <div class="container">
      <div class="find-apt-grid">

        <div>
          <Image
            src={findAptImg}
            alt="Blue Moon Apartment entrance and building"
            widths={[400, 700, 1100]}
            sizes="(max-width: 960px) 100vw, 50vw"
            style="width:100%; height:auto; border-radius:var(--radius-lg); display:block;"
          />
        </div>

        <div class="find-apt-content">
          <span class="section-label">Finding Us</span>
          <h2>The Apartment</h2>
          <p class="find-apt-address">
            <svg width="14" height="18" viewBox="0 0 14 20" fill="none" aria-hidden="true" style="flex-shrink:0; margin-top:2px;"><path d="M7 0C3.134 0 0 3.134 0 7c0 5.25 7 13 7 13s7-7.75 7-13C14 3.134 10.866 0 7 0z" stroke="currentColor" stroke-width="1.4"/><circle cx="7" cy="7" r="2.4" stroke="currentColor" stroke-width="1.4"/></svg>
            Riječka ulica 30, Mandre, Island of Pag, Croatia
          </p>
          <ol class="find-apt-steps">
            <li>Enter Mandre. As you drive into the town you'll pass the <strong>Lorenco store</strong> on your left.</li>
            <li>Turn <strong>left onto Široka ulica</strong>.</li>
            <li>Take the <strong>third right</strong>, then the <strong>second right</strong> onto <strong>Riječka ulica</strong>.</li>
            <li>The apartment is at <strong>Riječka ulica 30</strong>. Outdoor parking and a private garage are available on site.</li>
          </ol>
          <div class="find-apt-ctas">
            <a href="https://www.google.com/maps/dir/?api=1&destination=Blue+Moon+Apartment&destination_place_id=ChIJjWwKavA3YkcRtIxHt59t0pQ" target="_blank" rel="noopener" class="btn btn-primary">Navigate with Google Maps →</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ PARKING ═══ -->
  <section class="section" style="background:var(--warm-sand);">
    <div class="container">
      <div class="parking-grid">
        <div>
          <span class="section-label">On Arrival</span>
          <h2>🅿️ Parking at the Apartment</h2>
          <p>Blue Moon Apartment includes private parking for your complete peace of mind — no searching for spots or paying daily fees.</p>

          <div class="parking-options">
            <div class="parking-option">
              <span class="parking-option__icon">🅿️</span>
              <div>
                <h4>Outdoor Parking Space</h4>
                <p>A dedicated private parking space is available directly next to the building — suitable for all standard vehicles.</p>
              </div>
            </div>
            <div class="parking-option">
              <span class="parking-option__icon">🏠</span>
              <div>
                <h4>Private Garage</h4>
                <p>A private garage is available for one vehicle. Please note the size restrictions:</p>
                <ul class="garage-specs">
                  <li>Max width: <strong>2.60 m</strong></li>
                  <li>Max height: <strong>2.40 m</strong></li>
                </ul>
                <p style="margin-top:0.5rem; font-size:0.85rem; color:var(--text-muted);">Standard SUVs and family cars fit comfortably. Taller vans or minibuses may not fit — please check your vehicle dimensions in advance.</p>
              </div>
            </div>
          </div>

          <div class="highlight-box" style="margin-top:1.5rem;">
            <strong>📍 Address:</strong> Riječka ulica 30, Mandre, Island of Pag, Croatia.
          </div>
        </div>
        <div>
          <Image src={parkingImg} alt="Building &amp; Parking" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" style="width:100%; height:auto; aspect-ratio:4/3; object-fit:cover; object-position:right center; border-radius:var(--radius); display:block;" />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MAP ═══ -->
  <section class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom:2rem;">
        <span class="section-label">Map</span>
        <h2>Mandre on the Map</h2>
        <p style="color:var(--text-muted); max-width:520px; margin:0.75rem auto 0;">We're located on the island of Pag, on Croatia's northern Dalmatian coast — about 75 km south of Zadar.</p>
      </div>
      <div class="big-map">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2800!2d14.9219219!3d44.4761043!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x476237f06a0a6c8d%3A0x94d26d9fb7478cb4!2sBlue%20Moon%20Apartment!5e0!3m2!1sen!2shr!4v1714000000000!5m2!1sen!2shr"
          width="100%"
          height="420"
          style="border:0; border-radius:var(--radius-lg); display:block;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Blue Moon Apartment location in Mandre, Island of Pag, Croatia"
        ></iframe>
      </div>
      <div class="map-ctas">
        <a href="https://www.google.com/maps/dir/?api=1&destination=Blue+Moon+Apartment&destination_place_id=ChIJjWwKavA3YkcRtIxHt59t0pQ" target="_blank" rel="noopener" class="btn btn-primary">Navigate with  Google Maps →</a>
        <a href="/contact" class="btn btn-secondary">Ask Us for Directions</a>
      </div>
    </div>
  </section>

  <!-- ═══ NEARBY ═══ -->
  <section class="section" style="background:var(--soft-sky);">
    <div class="container">
      <div class="text-center" style="margin-bottom:2rem;">
        <span class="section-label">Once You're Here</span>
        <h2>Distances from the Apartment</h2>
      </div>
      <div class="nearby-grid">
        <div class="nearby-item"><span class="nearby-dist">200 m</span><span class="nearby-label">🏖️ Beach (2 min walk)</span></div>
        <div class="nearby-item"><span class="nearby-dist">Across<br/>the street</span><span class="nearby-label">🛒 Grocery store</span></div>
        <div class="nearby-item"><span class="nearby-dist">5 min</span><span class="nearby-label">🐟 Fish market</span></div>
        <div class="nearby-item"><span class="nearby-dist">5 min</span><span class="nearby-label">💊 Pharmacy</span></div>
        <div class="nearby-item"><span class="nearby-dist">5 min</span><span class="nearby-label">☕ Promenade cafés</span></div>
        <div class="nearby-item"><span class="nearby-dist">5 min</span><span class="nearby-label">🛝 Children's playground</span></div>
        <div class="nearby-item"><span class="nearby-dist">20 min</span><span class="nearby-label">🏛️ Pag town</span></div>
        <div class="nearby-item"><span class="nearby-dist">20 min</span><span class="nearby-label">🎵 Zrće Beach</span></div>
        <div class="nearby-item"><span class="nearby-dist">1 hr</span><span class="nearby-label">🌆 Zadar</span></div>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  /* Finding the apartment */
  .find-apt-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem;
    align-items: center;
  }
  .find-apt-content h2 { margin: 0.5rem 0 1rem; }
  .find-apt-address {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-weight: 700;
    color: var(--ocean-blue);
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }
  .find-apt-steps {
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    margin-bottom: 2rem;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .find-apt-steps li::marker { color: var(--sky-blue); font-weight: 800; }
  .find-apt-steps strong { color: var(--text-dark); }
  .find-apt-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 960px) {
    .find-apt-grid { grid-template-columns: 1fr; gap: 2rem; }
  }

  /* Distance strip */
  .distance-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    background: var(--white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    padding: 1.25rem 2rem;
    overflow: hidden;
  }
  .dist-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 1.5rem;
  }
  .dist-from { font-size: 0.9rem; font-weight: 700; color: var(--text-dark); }
  .dist-arrow { color: var(--sky-blue); font-weight: 700; }
  .dist-time  { font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 700; color: var(--ocean-blue); }
  .dist-sep   { width: 1px; height: 32px; background: rgba(74,159,212,0.2); margin: 0 0.25rem; }

  /* Routes */
  .routes-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .routes-grid .route-card:last-child {
    grid-column: 1 / -1;
    max-width: calc(50% - 1rem);
    justify-self: center;
  }

  .route-card { padding: 2rem; display: flex; flex-direction: column; }
  .route-card > :last-child { margin-top: auto; }
  .route-card__header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(74,159,212,0.15);
  }
  .route-icon { font-size: 2.2rem; flex-shrink: 0; }
  .route-card__header h3 { margin: 0 0 0.25rem; font-size: 1.25rem; }
  .route-time {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--sky-blue);
    display: block;
  }

  .route-steps {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    margin-bottom: 1.75rem;
  }
  .route-steps li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }
  .step-num {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--ocean-blue);
    color: white;
    font-size: 0.72rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .route-steps p { font-size: 0.88rem; color: var(--text-dark); line-height: 1.6; }
  .route-steps strong { color: var(--ocean-blue); }

  .route-btn { align-self: flex-start; }

  /* Parking */
  .parking-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .parking-grid h2 { margin-bottom: 1rem; }
  .parking-grid > div > p { color: var(--text-muted); }

  .parking-options {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 1.75rem;
  }
  .parking-option {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: var(--white);
    border-radius: var(--radius);
    padding: 1.25rem;
    box-shadow: var(--shadow-xs);
  }
  .parking-option__icon { font-size: 2rem; flex-shrink: 0; }
  .parking-option h4 { font-family:'Nunito',sans-serif; font-size:0.9rem; font-weight:800; color:var(--ocean-blue); margin-bottom:0.35rem; }
  .parking-option p  { font-size:0.85rem; color:var(--text-muted); }

  .garage-specs {
    list-style: none;
    margin-top: 0.4rem;
    display: flex;
    gap: 1rem;
  }
  .garage-specs li { font-size:0.85rem; color:var(--text-dark); }
  .garage-specs strong { color: var(--ocean-blue); }

  /* Map */
  .big-map { position: relative; }

  .map-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 1.75rem;
    flex-wrap: wrap;
  }

  /* Nearby */
  .nearby-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    max-width: 780px;
    margin: 0 auto;
  }
  .nearby-item {
    background: var(--white);
    border-radius: var(--radius);
    padding: 1.25rem;
    text-align: center;
    box-shadow: var(--shadow-xs);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }
  .nearby-dist {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--ocean-blue);
    line-height: 1.2;
  }
  .nearby-label {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text-dark);
    text-align: center;
  }

  @media (max-width: 860px) {
    .routes-grid { grid-template-columns: 1fr; }
    .routes-grid .route-card:last-child { grid-column: auto; max-width: 100%; justify-self: stretch; }
    .parking-grid { grid-template-columns: 1fr; gap: 2rem; }
    .distance-strip { flex-direction: column; gap: 0.25rem; }
    .dist-sep { width: 80px; height: 1px; margin: 0; }
  }
  @media (max-width: 560px) {
    .nearby-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
