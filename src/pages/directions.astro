---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Directions | Blue Moon Apartment, Mandre, Island of Pag"
  description="How to reach Blue Moon Apartment in Mandre, island of Pag, Croatia. Directions by car from Zadar and Zagreb, by ferry, and parking information on arrival."
  pageTitle="How to Find Us"
  pageSubtitle="Mandre, Island of Pag, Croatia"
  label="Directions"
  bgClass="ph-town"
  bgImage="/images/gallery/how%20to%20get%20to%20the%20apartment.jpg"
>

  <!-- ═══ DISTANCE OVERVIEW ═══ -->
  <section class="section-sm" style="background:var(--soft-sky);">
    <div class="container">
      <div class="distance-strip">
        <div class="dist-item">
          <span class="dist-from">🏙️ Zadar</span>
          <span class="dist-arrow">→</span>
          <span class="dist-time">~1 hour</span>
        </div>
        <div class="dist-sep" aria-hidden="true"></div>
        <div class="dist-item">
          <span class="dist-from">🏛️ Zagreb</span>
          <span class="dist-arrow">→</span>
          <span class="dist-time">~3.5 hours</span>
        </div>
        <div class="dist-sep" aria-hidden="true"></div>
        <div class="dist-item">
          <span class="dist-from">✈️ Zadar Airport</span>
          <span class="dist-arrow">→</span>
          <span class="dist-time">~75 km</span>
        </div>
        <div class="dist-sep" aria-hidden="true"></div>
        <div class="dist-item">
          <span class="dist-from">🏖️ Beach</span>
          <span class="dist-arrow">→</span>
          <span class="dist-time">200 m walk</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ ROUTES ═══ -->
  <section class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom:3rem;">
        <span class="section-label">Getting Here</span>
        <h2>Routes to Mandre</h2>
      </div>

      <div class="routes-grid">

        <!-- Route 1 -->
        <div class="route-card card">
          <div class="route-card__header">
            <span class="route-icon">🚗</span>
            <div>
              <h3>From Zadar</h3>
              <span class="route-time">~1 hour · ~75 km</span>
            </div>
          </div>
          <ol class="route-steps">
            <li>
              <span class="step-num">1</span>
              <p>From Zadar, take the main coastal road towards <strong>Nin</strong> and then <strong>Posedarje</strong>.</p>
            </li>
            <li>
              <span class="step-num">2</span>
              <p>Cross the <strong>Paški most (Pag Bridge)</strong> — a striking structure connecting the mainland to the island of Pag. No toll.</p>
            </li>
            <li>
              <span class="step-num">3</span>
              <p>After the bridge, follow the island road southward through <strong>Pag town</strong>. Continue north towards <strong>Novalja</strong>.</p>
            </li>
            <li>
              <span class="step-num">4</span>
              <p>Before reaching Novalja, turn <strong>left towards Kolan</strong>, then follow signs to <strong>Mandre</strong>. The village is clearly signposted.</p>
            </li>
            <li>
              <span class="step-num">5</span>
              <p>Enter Mandre. You will receive the exact address and parking instructions with your booking confirmation.</p>
            </li>
          </ol>
          <a href="https://maps.google.com/?q=Mandre,+Island+of+Pag,+Croatia&saddr=Zadar,+Croatia" target="_blank" rel="noopener" class="btn btn-sky btn-sm route-btn">Open in Google Maps →</a>
        </div>

        <!-- Route 2 -->
        <div class="route-card card">
          <div class="route-card__header">
            <span class="route-icon">🏎️</span>
            <div>
              <h3>From Zagreb</h3>
              <span class="route-time">~3.5 hours · ~280 km</span>
            </div>
          </div>
          <ol class="route-steps">
            <li>
              <span class="step-num">1</span>
              <p>From Zagreb, take the <strong>A1 motorway</strong> heading south towards Split.</p>
            </li>
            <li>
              <span class="step-num">2</span>
              <p>Exit at <strong>Zadar North</strong> or <strong>Zadar East</strong>. Follow signs towards Zadar city and then the <strong>island of Pag</strong>.</p>
            </li>
            <li>
              <span class="step-num">3</span>
              <p>Head towards <strong>Posedarje</strong> and cross the <strong>Pag Bridge</strong> onto the island.</p>
            </li>
            <li>
              <span class="step-num">4</span>
              <p>Follow the island road through Pag town, continue north, then turn left to <strong>Kolan</strong> and on to <strong>Mandre</strong>.</p>
            </li>
          </ol>
          <a href="https://maps.google.com/?q=Mandre,+Island+of+Pag,+Croatia&saddr=Zagreb,+Croatia" target="_blank" rel="noopener" class="btn btn-sky btn-sm route-btn">Open in Google Maps →</a>
        </div>

        <!-- Route 3 -->
        <div class="route-card card">
          <div class="route-card__header">
            <span class="route-icon">⛴️</span>
            <div>
              <h3>By Ferry (from the North)</h3>
              <span class="route-time">Shorter route if coming from Rijeka or beyond</span>
            </div>
          </div>
          <ol class="route-steps">
            <li>
              <span class="step-num">1</span>
              <p>Head to <strong>Prizna</strong> on the mainland coast — a small ferry port south of Karlobag on the Adriatic Highway.</p>
            </li>
            <li>
              <span class="step-num">2</span>
              <p>Take the <strong>Jadrolinija car ferry</strong> from Prizna to <strong>Žigljen</strong> on the island of Pag. The crossing takes approximately 15 minutes. Ferries run frequently in summer.</p>
            </li>
            <li>
              <span class="step-num">3</span>
              <p>From Žigljen (near Novalja), drive <strong>south</strong> through Novalja and Kolan towards <strong>Mandre</strong>. Approximately 20 minutes from the ferry port.</p>
            </li>
          </ol>
          <a href="https://www.jadrolinija.hr" target="_blank" rel="noopener" class="btn btn-sky btn-sm route-btn">Jadrolinija ferry schedule →</a>
        </div>

        <!-- Route 4 -->
        <div class="route-card card">
          <div class="route-card__header">
            <span class="route-icon">✈️</span>
            <div>
              <h3>Via Zadar Airport</h3>
              <span class="route-time">~75 km from airport · ~1 hour drive</span>
            </div>
          </div>
          <ol class="route-steps">
            <li>
              <span class="step-num">1</span>
              <p><strong>Zadar Airport (ZAD)</strong> is the most convenient airport for Mandre, with many seasonal European connections including Ryanair and easyJet routes.</p>
            </li>
            <li>
              <span class="step-num">2</span>
              <p>Rent a car at the airport (recommended — a car is useful for island exploration). The drive to Mandre follows the same route as from Zadar city.</p>
            </li>
            <li>
              <span class="step-num">3</span>
              <p><strong>Split Airport (SPU)</strong> is an alternative, ~2 hours away. <strong>Rijeka Airport (RJK)</strong> is another option, ~2.5 hours via the Prizna ferry.</p>
            </li>
          </ol>
          <a href="https://maps.google.com/?q=Mandre,+Island+of+Pag,+Croatia&saddr=Zadar+Airport,+Croatia" target="_blank" rel="noopener" class="btn btn-sky btn-sm route-btn">Directions from Airport →</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ PARKING ═══ -->
  <section class="section" style="background:var(--warm-sand);">
    <div class="container">
      <div class="parking-grid">
        <div>
          <span class="section-label">On Arrival</span>
          <h2>🅿️ Parking at the Apartment</h2>
          <p>Blue Moon Apartment includes private parking for your complete peace of mind — no searching for spots or paying daily fees.</p>

          <div class="parking-options">
            <div class="parking-option">
              <span class="parking-option__icon">🅿️</span>
              <div>
                <h4>Outdoor Parking Space</h4>
                <p>A dedicated private parking space is available directly next to the building — suitable for all standard vehicles.</p>
              </div>
            </div>
            <div class="parking-option">
              <span class="parking-option__icon">🏠</span>
              <div>
                <h4>Private Garage</h4>
                <p>A private garage is available for one vehicle. Please note the size restrictions:</p>
                <ul class="garage-specs">
                  <li>Max width: <strong>2.60 m</strong></li>
                  <li>Max height: <strong>2.40 m</strong></li>
                </ul>
                <p style="margin-top:0.5rem; font-size:0.85rem; color:var(--text-muted);">Standard SUVs and family cars fit comfortably. Taller vans or minibuses may not fit — please check your vehicle dimensions in advance.</p>
              </div>
            </div>
          </div>

          <div class="highlight-box" style="margin-top:1.5rem;">
            <strong>📬 Exact address and parking details</strong> will be provided in your booking confirmation email once your stay is confirmed.
          </div>
        </div>
        <div>
          <img src="/images/gallery/how%20to%20get%20to%20the%20apartment.jpg" alt="Building &amp; Parking" style="width:100%; aspect-ratio:4/3; object-fit:cover; border-radius:var(--radius); display:block;" />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MAP ═══ -->
  <section class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom:2rem;">
        <span class="section-label">Map</span>
        <h2>Mandre on the Map</h2>
        <p style="color:var(--text-muted); max-width:520px; margin:0.75rem auto 0;">We're located on the island of Pag, on Croatia's northern Dalmatian coast — about 75 km south of Zadar.</p>
      </div>
      <div class="big-map">
        <div class="img-ph ph-sea" style="height:420px; border-radius:var(--radius-lg);">
          <span class="ph-icon">🗺️</span>
          <span class="ph-label">Map placeholder — embed Google Maps iframe here</span>
        </div>
        <div class="map-note">
          Replace the placeholder above with a Google Maps embed iframe pointing to Mandre, Island of Pag.
          Example: <code>&lt;iframe src="https://www.google.com/maps/embed?pb=..." ...&gt;&lt;/iframe&gt;</code>
        </div>
      </div>
      <div class="map-ctas">
        <a href="https://maps.google.com/?q=Mandre,+Island+of+Pag,+Croatia" target="_blank" rel="noopener" class="btn btn-primary">Open in Google Maps →</a>
        <a href="/contact" class="btn btn-secondary">Ask Us for Directions</a>
      </div>
    </div>
  </section>

  <!-- ═══ NEARBY ═══ -->
  <section class="section" style="background:var(--soft-sky);">
    <div class="container">
      <div class="text-center" style="margin-bottom:2rem;">
        <span class="section-label">Once You're Here</span>
        <h2>Distances from the Apartment</h2>
      </div>
      <div class="nearby-grid">
        <div class="nearby-item"><span class="nearby-dist">200 m</span><span class="nearby-label">🏖️ Beach (2 min walk)</span></div>
        <div class="nearby-item"><span class="nearby-dist">Across<br/>the street</span><span class="nearby-label">🛒 Grocery store</span></div>
        <div class="nearby-item"><span class="nearby-dist">5 min</span><span class="nearby-label">🐟 Fish market</span></div>
        <div class="nearby-item"><span class="nearby-dist">5 min</span><span class="nearby-label">💊 Pharmacy</span></div>
        <div class="nearby-item"><span class="nearby-dist">5 min</span><span class="nearby-label">☕ Promenade cafés</span></div>
        <div class="nearby-item"><span class="nearby-dist">5 min</span><span class="nearby-label">🛝 Children's playground</span></div>
        <div class="nearby-item"><span class="nearby-dist">20 min</span><span class="nearby-label">🏛️ Pag town</span></div>
        <div class="nearby-item"><span class="nearby-dist">20 min</span><span class="nearby-label">🎵 Zrće Beach</span></div>
        <div class="nearby-item"><span class="nearby-dist">1 hr</span><span class="nearby-label">🌆 Zadar</span></div>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  /* Distance strip */
  .distance-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    background: var(--white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    padding: 1.25rem 2rem;
    overflow: hidden;
  }
  .dist-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 1.5rem;
  }
  .dist-from { font-size: 0.9rem; font-weight: 700; color: var(--text-dark); }
  .dist-arrow { color: var(--sky-blue); font-weight: 700; }
  .dist-time  { font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 700; color: var(--ocean-blue); }
  .dist-sep   { width: 1px; height: 32px; background: rgba(74,159,212,0.2); margin: 0 0.25rem; }

  /* Routes */
  .routes-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .route-card { padding: 2rem; }
  .route-card__header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(74,159,212,0.15);
  }
  .route-icon { font-size: 2.2rem; flex-shrink: 0; }
  .route-card__header h3 { margin: 0 0 0.25rem; font-size: 1.25rem; }
  .route-time {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--sky-blue);
    display: block;
  }

  .route-steps {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    margin-bottom: 1.75rem;
  }
  .route-steps li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }
  .step-num {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--ocean-blue);
    color: white;
    font-size: 0.72rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .route-steps p { font-size: 0.88rem; color: var(--text-dark); line-height: 1.6; }
  .route-steps strong { color: var(--ocean-blue); }

  .route-btn { align-self: flex-start; }

  /* Parking */
  .parking-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .parking-grid h2 { margin-bottom: 1rem; }
  .parking-grid > div > p { color: var(--text-muted); }

  .parking-options {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 1.75rem;
  }
  .parking-option {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: var(--white);
    border-radius: var(--radius);
    padding: 1.25rem;
    box-shadow: var(--shadow-xs);
  }
  .parking-option__icon { font-size: 2rem; flex-shrink: 0; }
  .parking-option h4 { font-family:'Nunito',sans-serif; font-size:0.9rem; font-weight:800; color:var(--ocean-blue); margin-bottom:0.35rem; }
  .parking-option p  { font-size:0.85rem; color:var(--text-muted); }

  .garage-specs {
    list-style: none;
    margin-top: 0.4rem;
    display: flex;
    gap: 1rem;
  }
  .garage-specs li { font-size:0.85rem; color:var(--text-dark); }
  .garage-specs strong { color: var(--ocean-blue); }

  /* Map */
  .big-map { position: relative; }
  .map-note {
    margin-top: 0.75rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    background: var(--warm-sand);
    border-radius: var(--radius);
    padding: 0.75rem 1rem;
    border-left: 3px solid var(--sunset-gold);
  }
  .map-note code {
    background: rgba(26,95,173,0.08);
    color: var(--ocean-blue);
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    font-size: 0.75rem;
  }

  .map-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 1.75rem;
    flex-wrap: wrap;
  }

  /* Nearby */
  .nearby-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    max-width: 780px;
    margin: 0 auto;
  }
  .nearby-item {
    background: var(--white);
    border-radius: var(--radius);
    padding: 1.25rem;
    text-align: center;
    box-shadow: var(--shadow-xs);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }
  .nearby-dist {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--ocean-blue);
    line-height: 1.2;
  }
  .nearby-label {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text-dark);
    text-align: center;
  }

  @media (max-width: 860px) {
    .routes-grid { grid-template-columns: 1fr; }
    .parking-grid { grid-template-columns: 1fr; gap: 2rem; }
    .distance-strip { flex-direction: column; gap: 0.25rem; }
    .dist-sep { width: 80px; height: 1px; margin: 0; }
  }
  @media (max-width: 560px) {
    .nearby-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
