---
import { Image } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';
import heroBg from '../assets/gallery/outdoor.jpg';
import hostPic from '../assets/gallery/host picture.jpg';
import terrace3 from '../assets/gallery/terrace-3.jpg';
---

<PageLayout
  title="About Us | Blue Moon Apartment, Mandre"
  description="Meet Goran Falkoni, your host at Blue Moon Apartment in Mandre, island of Pag. Personal, attentive hospitality for your family holiday."
  pageTitle="Your Host"
  pageSubtitle="A warm welcome from Mandre, island of Pag"
  label="About Us"
  bgClass="ph-sea"
  bgImage={heroBg}
>

  <!-- ═══ HOST INTRO ═══ -->
  <section class="section">
    <div class="container">
      <div class="host-grid">

        <div class="host-photo-col">
          <div class="host-photo-wrap">
            <Image src={hostPic} alt="Goran Falkoni" widths={[300, 600]} sizes="(max-width: 640px) 70vw, 320px" class="host-photo" style="width:100%; height:auto; aspect-ratio:1/1; object-fit:cover; border-radius:50%; display:block;" />
            <div class="host-badge">
              <span class="host-badge__icon">⭐</span>
              <div>
                <strong>Superhost</strong>
                <span>Trusted by families since 2023</span>
              </div>
            </div>
          </div>
        </div>

        <div class="host-text-col">
          <span class="section-label">Your Host</span>
          <h2>Hi, I'm Goran Falkoni</h2>
          <p class="host-intro">I'm delighted to welcome you to Blue Moon Apartment.</p>

          <p>[Placeholder — add a few sentences here about your personal connection to Mandre. For example: how long you've been coming to the island, what the place means to you, and why you decided to create this space for families to enjoy.]</p>

          <p style="margin-top:1rem;">[Placeholder — a sentence or two about your family, what you love about hosting, and the kind of experience you want guests to have. For example: your favourite thing about watching families discover the island, or a personal memory that captures what Mandre means to you.]</p>

          <p style="margin-top:1rem;">My goal is simple: to make sure your family has the most relaxing, memorable holiday possible. I'm always available to answer questions, share local tips, and make your stay seamless — from the moment you send your first message to the day you reluctantly pack up and head home.</p>

          <div class="host-values">
            <div class="host-value">
              <span class="host-value__icon">💬</span>
              <div>
                <strong>Always reachable</strong>
                <span>I respond to messages within a few hours, usually much faster.</span>
              </div>
            </div>
            <div class="host-value">
              <span class="host-value__icon">🗺️</span>
              <div>
                <strong>Local knowledge</strong>
                <span>Ask me anything — restaurants, beaches, boat trips, hidden spots.</span>
              </div>
            </div>
            <div class="host-value">
              <span class="host-value__icon">🏡</span>
              <div>
                <strong>Care for the details</strong>
                <span>The apartment is maintained to the standard I'd want for my own family.</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ THE APARTMENT STORY ═══ -->
  <section class="section" style="background:var(--soft-sky);">
    <div class="container">
      <div class="story-grid">
        <div>
          <Image src={terrace3} alt="The Terrace" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" style="width:100%; height:auto; aspect-ratio:4/3; object-fit:cover; border-radius:var(--radius); display:block;" />
        </div>
        <div>
          <span class="section-label">The Story</span>
          <h2>Why Blue Moon?</h2>
          <p>[Placeholder — this is a great place for the story behind the apartment's name and creation. For example: when you renovated it, what vision you had for it, and why "Blue Moon" captures the spirit of the place — the moon over the Adriatic, the rare magic of perfect summer nights on the terrace.]</p>
          <p style="margin-top:1rem;">What I do know is that every guest who has sat on that terrace with the hot tub on, watching the sun set over the Adriatic while the kids sleep inside — they always say it was worth every moment of the journey to get here.</p>
          <p style="margin-top:1rem;">That's what Blue Moon is about.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ WHAT GUESTS SAY ABOUT GORAN ═══ -->
  <section class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom:2.5rem;">
        <span class="section-label">Host Reviews</span>
        <h2>What Guests Say About Goran</h2>
      </div>
      <div class="grid-3 host-reviews">
        <div class="host-review card">
          <div class="stars">★★★★★</div>
          <blockquote>"Goran was available from the moment we inquired. He answered every question patiently, gave us brilliant tips about where to eat and which beaches to visit with the kids. Exceptional host."</blockquote>
          <footer><strong>Tomasz W.</strong> <span>🇵🇱 Poland</span></footer>
        </div>
        <div class="host-review card">
          <div class="stars">★★★★★</div>
          <blockquote>"We had a small issue with the air conditioning on arrival and Goran resolved it within the hour. That kind of responsiveness is rare. We felt completely taken care of throughout our stay."</blockquote>
          <footer><strong>Familie Bauer</strong> <span>🇩🇪 Germany</span></footer>
        </div>
        <div class="host-review card">
          <div class="stars">★★★★★</div>
          <blockquote>"Goran met us on arrival, showed us everything, and left us a little welcome note with local tips. Small touches that made a huge difference. Can't wait to come back."</blockquote>
          <footer><strong>Marija K.</strong> <span>🇭🇷 Croatia</span></footer>
        </div>
      </div>
      <div class="text-center" style="margin-top:2.5rem;">
        <a href="/reviews" class="btn btn-primary">Read all guest reviews →</a>
      </div>
    </div>
  </section>

  <!-- ═══ GET IN TOUCH ═══ -->
  <section class="section" style="background:var(--warm-sand);">
    <div class="container">
      <div class="contact-cta-block">
        <div>
          <span class="section-label">Say Hello</span>
          <h2>Get in Touch with Goran</h2>
          <p>Whether you have a question about the apartment, want to check availability, or just want to know more about Mandre before you decide — I'm happy to hear from you.</p>
        </div>
        <div class="contact-cta-block__links">
          <a href="mailto:info@bluemoonapartment.com" class="contact-link">
            <span class="contact-link__icon">📧</span>
            <div>
              <strong>Email</strong>
              <span>info@bluemoonapartment.com</span>
            </div>
          </a>
          <a href="https://wa.me/385914691204" target="_blank" rel="noopener" class="contact-link contact-link--whatsapp">
            <span class="contact-link__icon">💬</span>
            <div>
              <strong>WhatsApp</strong>
              <span>+385 98 123 4567</span>
            </div>
          </a>
          <a href="/contact" class="btn btn-primary" style="align-self:flex-start; margin-top:0.5rem;">Send an Inquiry →</a>
        </div>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  .host-grid {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 5rem;
    align-items: start;
  }

  .host-photo-wrap { position: relative; }

  .host-photo {
    max-width: 280px;
    margin: 0 auto;
    border: 5px solid var(--white);
    box-shadow: var(--shadow-lg);
  }

  .host-badge {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--white);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    margin-top: 1.25rem;
    box-shadow: var(--shadow-sm);
    max-width: 280px;
    margin-left: auto;
    margin-right: auto;
  }
  .host-badge__icon { font-size: 1.8rem; flex-shrink: 0; }
  .host-badge div   { display: flex; flex-direction: column; gap: 0.1rem; }
  .host-badge strong { font-size: 0.9rem; color: var(--ocean-blue); }
  .host-badge span   { font-size: 0.78rem; color: var(--text-muted); }

  .host-intro {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--ocean-blue);
    font-style: italic;
    margin-bottom: 1rem;
  }

  .host-text-col h2  { margin-bottom: 0.5rem; }
  .host-text-col p   { color: var(--text-muted); }

  .host-values {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2rem;
  }
  .host-value {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 1rem 1.25rem;
    background: var(--soft-sky);
    border-radius: var(--radius);
  }
  .host-value__icon { font-size: 1.4rem; flex-shrink: 0; }
  .host-value div   { display: flex; flex-direction: column; gap: 0.15rem; }
  .host-value strong { font-size: 0.9rem; font-weight: 800; color: var(--ocean-blue); }
  .host-value span   { font-size: 0.85rem; color: var(--text-muted); }

  /* Story */
  .story-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .story-grid h2 { margin-bottom: 1rem; }
  .story-grid p  { color: var(--text-muted); }

  /* Host reviews */
  .host-review {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .host-review .stars    { color: var(--sunset-gold); }
  .host-review blockquote {
    font-size: 0.9rem;
    font-style: italic;
    color: var(--text-dark);
    line-height: 1.7;
    flex: 1;
  }
  .host-review footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-top: 1px solid rgba(74,159,212,0.12);
    padding-top: 0.75rem;
  }
  .host-review footer strong { font-size: 0.88rem; color: var(--ocean-blue); }
  .host-review footer span   { font-size: 0.8rem; color: var(--text-muted); }

  /* Contact CTA block */
  .contact-cta-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .contact-cta-block h2 { margin-bottom: 1rem; }
  .contact-cta-block p  { color: var(--text-muted); }

  .contact-cta-block__links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--white);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    box-shadow: var(--shadow-xs);
    text-decoration: none;
    transition: all 0.25s ease;
    border: 2px solid transparent;
  }
  .contact-link:hover {
    border-color: var(--sky-blue);
    transform: translateX(4px);
    box-shadow: var(--shadow-sm);
  }
  .contact-link--whatsapp:hover { border-color: #25D366; }
  .contact-link__icon { font-size: 1.75rem; flex-shrink: 0; }
  .contact-link div   { display: flex; flex-direction: column; gap: 0.1rem; }
  .contact-link strong { font-size: 0.9rem; color: var(--ocean-blue); font-weight: 800; }
  .contact-link span   { font-size: 0.85rem; color: var(--text-muted); }

  @media (max-width: 960px) {
    .host-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .host-photo { max-width: 220px; }
    .host-badge { max-width: 220px; }
    .story-grid { grid-template-columns: 1fr; gap: 2rem; }
    .contact-cta-block { grid-template-columns: 1fr; gap: 2rem; }
    .host-reviews { grid-template-columns: 1fr !important; }
  }
</style>
