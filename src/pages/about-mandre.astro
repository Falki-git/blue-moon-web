---
import { Image } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';
import heroBg from '../assets/gallery/about-mandre/about-mandre.jpg';
import mandre1 from '../assets/gallery/about-mandre/mandre-1.jpg';
import mandre2 from '../assets/gallery/about-mandre/mandre-2.jpg';
import mandre3 from '../assets/gallery/about-mandre/mandre-3.jpg';
import mandre4 from '../assets/gallery/about-mandre/mandre-4.jpg';
import mandre5 from '../assets/gallery/about-mandre/mandre-5.jpg';
import beaches1 from '../assets/gallery/about-mandre/beaches-1.jpg';
import beaches2 from '../assets/gallery/about-mandre/beaches-2.jpg';
import beaches3 from '../assets/gallery/about-mandre/beaches-3.jpg';
import beaches4 from '../assets/gallery/about-mandre/beaches-4.jpg';
import beaches5 from '../assets/gallery/about-mandre/beaches-5.jpg';
import beaches6 from '../assets/gallery/about-mandre/beaches-6.jpg';
import family1 from '../assets/gallery/about-mandre/family-1.jpg';
import family2 from '../assets/gallery/about-mandre/family-2.jpg';
import family3 from '../assets/gallery/about-mandre/family-3.png';
import family4 from '../assets/gallery/about-mandre/family-4.png';
import family5 from '../assets/gallery/about-mandre/family-5.jpg';
import family6 from '../assets/gallery/about-mandre/family-6.jpg';
import pagCheese from '../assets/gallery/about-mandre/pag-cheese.jpg';
import pagLamb from '../assets/gallery/about-mandre/pag-lamb.jpg';
import lifeOnMars1 from '../assets/gallery/about-mandre/life-on-mars-1.jpg';
import lifeOnMars2 from '../assets/gallery/about-mandre/life-on-mars-2.jpg';
import boatExcursion1 from '../assets/gallery/about-mandre/boat-excursion-1.jpg';
import silba from '../assets/gallery/about-mandre/silba.jpg';
import krka from '../assets/gallery/about-mandre/krka.jpg';
import plitvice from '../assets/gallery/about-mandre/plitvice.jpg';
---

<PageLayout
  title="About Mandre | Blue Moon Apartment, Island of Pag"
  description="Discover Mandre — a small, quiet family-friendly town on the island of Pag, Croatia. Blue Flag beaches, children's playgrounds, local delicacies, and day trips."
  pageTitle="Discover Mandre"
  pageSubtitle="A hidden gem on the island of Pag, Croatia"
  label="About Mandre"
  bgClass="ph-town"
  bgImage={heroBg}
  heroObjectPosition="center 54.7%"
>

  <!-- ═══ THE TOWN ═══ -->
  <section class="section">
    <div class="container">
      <div class="mandre-grid">
        <div>
          <span class="section-label">The Town</span>
          <h2>Mandre — Small Town, Big Soul</h2>
          <p>Mandre is a small, quiet tourist town nestled in a sheltered cove on the western shore of the island of Pag. It has exactly what a perfect Adriatic escape calls for: clean sea, friendly locals, a relaxed pace, and a promenade where families gather in the evenings under the Adriatic sky.</p>
          <p style="margin-top:1rem;">Unlike the busier destinations on the island, Mandre has managed to remain authentic and peaceful. There's no industry, no noise, and no crowds — just the gentle rhythm of island life. For families seeking a genuine Croatian holiday, this is it.</p>
        </div>
        <div>
          <div class="carousel" id="mandre-carousel">
            <div class="carousel__track">
              <div class="carousel__slide"><Image src={mandre1} alt="Mandre town" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={mandre2} alt="Mandre town" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={mandre3} alt="Mandre town" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={mandre4} alt="Mandre town" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={mandre5} alt="Mandre town" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
            </div>
            <button class="carousel__btn carousel__btn--prev" aria-label="Previous image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 1L1 8L8 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button class="carousel__btn carousel__btn--next" aria-label="Next image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L8 8L1 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="carousel__dots">
              <button class="carousel__dot carousel__dot--active" aria-label="Slide 1"></button>
              <button class="carousel__dot" aria-label="Slide 2"></button>
              <button class="carousel__dot" aria-label="Slide 3"></button>
              <button class="carousel__dot" aria-label="Slide 4"></button>
              <button class="carousel__dot" aria-label="Slide 5"></button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ BEACHES ═══ -->
  <section class="section" style="background:var(--soft-sky);">
    <div class="container">
      <div class="mandre-grid mandre-grid--reverse">
        <div>
          <div class="carousel" id="beaches-carousel">
            <div class="carousel__track">
              <div class="carousel__slide"><Image src={beaches1} alt="Mandre beach" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={beaches2} alt="Mandre beach" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={beaches3} alt="Mandre beach" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={beaches4} alt="Mandre beach" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={beaches5} alt="Mandre beach" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={beaches6} alt="Mandre beach" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
            </div>
            <button class="carousel__btn carousel__btn--prev" aria-label="Previous image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 1L1 8L8 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button class="carousel__btn carousel__btn--next" aria-label="Next image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L8 8L1 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="carousel__dots">
              <button class="carousel__dot carousel__dot--active" aria-label="Slide 1"></button>
              <button class="carousel__dot" aria-label="Slide 2"></button>
              <button class="carousel__dot" aria-label="Slide 3"></button>
              <button class="carousel__dot" aria-label="Slide 4"></button>
              <button class="carousel__dot" aria-label="Slide 5"></button>
              <button class="carousel__dot" aria-label="Slide 6"></button>
            </div>
          </div>
        </div>
        <div>
          <span class="section-label">Crystal Clear Waters</span>
          <h2>🏖️ The Beaches</h2>
          <p>The entire shore of Mandre is lined with small beaches and coves, making it easy to find your perfect spot. The crown jewel is <strong>Mala Mandra beach</strong> — located right in the town centre, it has proudly held the prestigious <strong>Blue Flag</strong> since 2006, a mark of exceptionally clean water and well-maintained facilities.</p>
          <p style="margin-top:1rem;">Several larger pebble beaches are also within easy reach, offering more space for families to spread out. With a short boat ride, you can discover secluded coves and the breathtaking shores of the nearby uninhabited islands of Maun and Škrda.</p>
          <div class="beach-tag">🏳️ Blue Flag Beach since 2006</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FOR FAMILIES ═══ -->
  <section class="section">
    <div class="container">
      <div class="mandre-grid">
        <div>
          <span class="section-label">Family Friendly</span>
          <h2>👨‍👩‍👧‍👦 Made for Families</h2>
          <p>Mandre is one of those rare places where children and parents are equally happy. The town is compact, safe, and wonderfully walkable — kids can run freely along the promenade while parents enjoy a coffee at a seafront café.</p>
          <ul class="mandre-list">
            <li>
              <span class="mandre-list__icon">🛝</span>
              <span><strong>Two children's playgrounds</strong> — one in the town centre near Konzum, one near the larger pebble beach.</span>
            </li>
            <li>
              <span class="mandre-list__icon">⚽</span>
              <span><strong>Mini football field</strong> — just a few minutes' walk from the apartment.</span>
            </li>
            <li>
              <span class="mandre-list__icon">🚲</span>
              <span><strong>Bike &amp; e-scooter friendly</strong> — the promenade and surrounding roads are ideal for cycling with children.</span>
            </li>
            <li>
              <span class="mandre-list__icon">🎶</span>
              <span><strong>Summer events</strong> — themed evenings with music, local food and drinks are organised almost daily on the promenade throughout summer.</span>
            </li>
          </ul>
        </div>
        <div>
          <div class="carousel" id="family-carousel">
            <div class="carousel__track">
              <div class="carousel__slide"><Image src={family1} alt="Mandre family activities" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={family2} alt="Mandre family activities" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={family3} alt="Mandre family activities" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={family4} alt="Mandre family activities" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={family5} alt="Mandre family activities" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={family6} alt="Mandre family activities" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
            </div>
            <button class="carousel__btn carousel__btn--prev" aria-label="Previous image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 1L1 8L8 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button class="carousel__btn carousel__btn--next" aria-label="Next image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L8 8L1 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="carousel__dots">
              <button class="carousel__dot carousel__dot--active" aria-label="Slide 1"></button>
              <button class="carousel__dot" aria-label="Slide 2"></button>
              <button class="carousel__dot" aria-label="Slide 3"></button>
              <button class="carousel__dot" aria-label="Slide 4"></button>
              <button class="carousel__dot" aria-label="Slide 5"></button>
              <button class="carousel__dot" aria-label="Slide 6"></button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ GETTING AROUND ═══ -->
  <section class="section" style="background:var(--warm-sand);">
    <div class="container">
      <div class="text-center" style="margin-bottom:2.5rem;">
        <span class="section-label">Convenience</span>
        <h2>🛒 Getting Around &amp; Daily Life</h2>
      </div>
      <div class="convenience-grid">
        <div class="convenience-item">
          <span class="convenience-icon">🏪</span>
          <h4>Right Across the Street</h4>
          <p>A small market store is conveniently located directly across from the apartment — ideal for quick grocery shopping without getting in the car.</p>
        </div>
        <div class="convenience-item">
          <span class="convenience-icon">🐟</span>
          <h4>5-Minute Walk</h4>
          <p>A second market store, fish market, and pharmacy are all within a 5-minute walk — everything for a self-catering holiday.</p>
        </div>
        <div class="convenience-item">
          <span class="convenience-icon">🚗</span>
          <h4>2-Minute Drive</h4>
          <p>A larger market store is located at the town entrance, just a short drive uphill — perfect for a bigger weekly shop.</p>
        </div>
        <div class="convenience-item">
          <span class="convenience-icon">🛒</span>
          <h4>20-Minute Drive</h4>
          <p>Full supermarkets are available in the larger nearby towns. A great excuse to explore more of the island on the way!</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ LOCAL FLAVOURS ═══ -->
  <section class="section">
    <div class="container">
      <div class="mandre-grid">
        <div>
          <span class="section-label">Taste of Pag</span>
          <h2>🧀 Local Delicacies</h2>
          <p>The island of Pag is world-famous for its extraordinary culinary heritage. Two products in particular are legendary, and you absolutely must try them during your stay:</p>
          <div class="food-card">
            <div class="food-card__emoji">🧀</div>
            <div>
              <h4>Paški Sir — Pag Cheese</h4>
              <p>This hard sheep's cheese is produced from the milk of Pag sheep who graze on the island's unique salt-swept pastures, grazed by the Bura wind. The result is an extraordinarily complex, aromatic cheese — one of Europe's finest. You'll find it in local shops, restaurants, and at island producers.</p>
            </div>
          </div>
          <div class="food-card" style="margin-top:1rem;">
            <div class="food-card__emoji">🍖</div>
            <div>
              <h4>Paška Janjetina — Pag Lamb</h4>
              <p>Slow-roasted over an open fire, Pag lamb is melt-in-your-mouth tender, with a unique flavour imparted by the same salty island herbs the animals graze on. Available at local restaurants, it's a must-order dish for any visitor to the island.</p>
            </div>
          </div>
        </div>
        <div>
          <div class="carousel" id="food-carousel">
            <div class="carousel__track">
              <div class="carousel__slide"><Image src={pagCheese} alt="Paški sir — Pag cheese" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide"><Image src={pagLamb} alt="Paški janjetina — Pag lamb" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
            </div>
            <button class="carousel__btn carousel__btn--prev" aria-label="Previous image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 1L1 8L8 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button class="carousel__btn carousel__btn--next" aria-label="Next image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L8 8L1 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="carousel__dots">
              <button class="carousel__dot carousel__dot--active" aria-label="Slide 1"></button>
              <button class="carousel__dot" aria-label="Slide 2"></button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ OUR PICKS ═══ -->
  <section class="section" style="background:var(--soft-sky);">
    <div class="container">
      <div class="text-center" style="margin-bottom:2.5rem;">
        <span class="section-label">Insider Tips</span>
        <h2>🗺️ Our Picks</h2>
        <p style="color:var(--text-muted); max-width:560px; margin:0.75rem auto 0;">Personal recommendations from your host — updated each season.</p>
      </div>
      <div class="picks-grid">
        <div class="pick-card card">
          <div class="pick-num">01</div>
          <h4>Best Restaurant</h4>
          <p>Head to Konoba Prtorić, just outside Mandre on the road to Šimuni — they serve some of the finest lamb on the island. Reservations are a must in peak season.</p>
        </div>
        <div class="pick-card card">
          <div class="pick-num">02</div>
          <h4>Best Beach for Kids</h4>
          <p>The small pebbled beach directly below the Morska Vila souvenir shop is ideal for families — pick up cold drinks or ice cream at the shop above, and there's a children's playground nearby. A large beach is just a short walk along the shore if you need more space.</p>
        </div>
        <div class="pick-card card">
          <div class="pick-num">03</div>
          <h4>Best Pag Cheese</h4>
          <p>Make the short drive to the Gligora dairy in Kolan for a factory tour and cheese tasting — the best way to find your favourite Paški sir and bring some home. Local private shops in Mandre also carry excellent selections.</p>
        </div>
        <div class="pick-card card">
          <div class="pick-num">04</div>
          <h4>Best Evening Walk</h4>
          <p>Walk along the promenade toward the marina at golden hour, then continue past the boats until you reach Meddy — a small spot serving the best homemade ice cream in Mandre.</p>
        </div>
        <div class="pick-card card">
          <div class="pick-num">05</div>
          <h4>Best Boat Trip</h4>
          <p>Find M/B Otac Luka at the marina and ask about their island day trips — a perfect full day out on the water to nearby Olib or Silba, both car-free islands with crystal-clear sea.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ DAY TRIPS ═══ -->
  <section class="section">
    <div class="container">
      <div class="mandre-grid">
        <div>
          <span class="section-label">Explore More</span>
          <h2>🧭 Day Trips &amp; Excursions</h2>
          <p>Mandre's location makes it an ideal base for exploring some of Croatia's most spectacular natural and cultural highlights.</p>
          <ul class="trip-list">
            <li>
              <strong>🔴 Life on Mars Trail</strong>
              <span>Described as the most beautiful and unique trail in Croatia — a short drive from the apartment.</span>
            </li>
            <li>
              <strong>⛵ Islands of Silba &amp; Olib</strong>
              <span>Organised boat trips available from Luka Mandre — car-free islands of extraordinary charm.</span>
            </li>
            <li>
              <strong>🏞️ Krka &amp; Plitvička Jezera National Parks</strong>
              <span>Two of Croatia's most spectacular parks within reach — Krka (~90 min) for waterfalls and swimming, Plitvice (~2 hrs) for breathtaking turquoise lakes. Guided excursions available for both.</span>
            </li>
          </ul>
        </div>
        <div>
          <div class="carousel" id="daytrips-carousel">
            <div class="carousel__track">
              <div class="carousel__slide" data-caption="Life on Mars Trail"><Image src={lifeOnMars1} alt="Life on Mars Trail" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide" data-caption="Life on Mars Trail"><Image src={lifeOnMars2} alt="Life on Mars Trail" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide" data-caption="Boat excursion from Luka Mandre"><Image src={boatExcursion1} alt="Boat excursion from Luka Mandre" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide" data-caption="Island of Silba"><Image src={silba} alt="Island of Silba" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide" data-caption="Krka National Park"><Image src={krka} alt="Krka National Park" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
              <div class="carousel__slide" data-caption="Plitvice Lakes National Park"><Image src={plitvice} alt="Plitvice Lakes National Park" widths={[400, 700, 1100]} sizes="(max-width: 900px) 100vw, 50vw" /></div>
            </div>
            <button class="carousel__btn carousel__btn--prev" aria-label="Previous image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 1L1 8L8 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button class="carousel__btn carousel__btn--next" aria-label="Next image">
              <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L8 8L1 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="carousel__dots">
              <button class="carousel__dot carousel__dot--active" aria-label="Slide 1"></button>
              <button class="carousel__dot" aria-label="Slide 2"></button>
              <button class="carousel__dot" aria-label="Slide 3"></button>
              <button class="carousel__dot" aria-label="Slide 4"></button>
              <button class="carousel__dot" aria-label="Slide 5"></button>
              <button class="carousel__dot" aria-label="Slide 6"></button>
            </div>
            <div class="carousel__caption">Life on Mars trail</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ AROUND THE ISLAND ═══ -->
  <section class="section" style="background:var(--soft-sky);">
    <div class="container">
      <div class="text-center" style="margin-bottom:2.5rem;">
        <span class="section-label">Beyond Mandre</span>
        <h2>🏝️ Around the Island &amp; Further</h2>
      </div>
      <div class="distances-grid">
        <div class="distance-card">
          <div class="distance-time">20 min</div>
          <h4>Pag Town</h4>
          <p>The historic capital of the island. Old town, salt pans, lace-makers, and great local restaurants.</p>
        </div>
        <div class="distance-card">
          <div class="distance-time">20 min</div>
          <h4>Zrće Beach</h4>
          <p>Croatia's most famous party beach near Novalja. A great evening option if the adults want a night out — Mandre remains peaceful.</p>
        </div>
        <div class="distance-card">
          <div class="distance-time">1 hr</div>
          <h4>Zadar</h4>
          <p>The mainland city of Zadar, reachable via the Pag Bridge. UNESCO old town, Sea Organ, Museum of Ancient Glass.</p>
        </div>
        <div class="distance-card">
          <div class="distance-time">~3.5 hrs</div>
          <h4>Zagreb</h4>
          <p>Croatia's vibrant capital — a worth-it day trip if you're staying for a week or more.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Map placeholder -->
  <section class="section-sm" style="background:var(--warm-sand);">
    <div class="container">
      <div class="text-center" style="margin-bottom:1.5rem;">
        <span class="section-label">Find Us</span>
        <h2>Mandre on the Map</h2>
      </div>
      <div class="map-placeholder">
        <iframe
          src="https://maps.google.com/maps?q=Mandre,+Island+of+Pag,+Croatia&z=14&output=embed"
          width="100%"
          height="320"
          style="border:0; border-radius:var(--radius-lg); display:block;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mandre, Island of Pag, Croatia"
        ></iframe>
        <div class="map-placeholder__actions">
