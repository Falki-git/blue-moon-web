    border: none;
    cursor: pointer;
    padding: 0;
    transition: background var(--transition);
  }
  .carousel__dot--active { background: white; }
  .carousel__caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.5rem 1rem;
    background: rgba(0, 0, 0, 0.45);
