---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTranslations } from '../i18n/utils';

const lang = Astro.currentLocale ?? 'en';
const T = getTranslations(lang);
const prefix = lang === 'en' ? '' : `/${lang}`;
---

<BaseLayout
  title={T.notFound.metaTitle}
  description={T.notFound.metaDescription}
  lang={lang}
>

  <section class="notfound">
    <div class="notfound__bg" aria-hidden="true"></div>
    <div class="container notfound__content">
      <div class="notfound__moon" aria-hidden="true">
        <img src="/images/logo.svg" alt="" width="200" style="height:auto;" />
      </div>
      <h1 class="notfound__code">404</h1>
      <h2 class="notfound__title">{T.notFound.heading}</h2>
      <p class="notfound__text">
        {T.notFound.body}
      </p>
      <div class="notfound__links">
        <a href={`${prefix}/`} class="btn btn-primary">{T.notFound.backHome}</a>
        <a href={`${prefix}/booking`} class="btn btn-sky">{T.notFound.checkAvailability}</a>
      </div>

      <div class="notfound__quicklinks">
        <p>{T.notFound.orGoTo}</p>
        <ul>
          <li><a href={`${prefix}/apartment`}>{T.nav.apartment}</a></li>
          <li><a href={`${prefix}/pricelist`}>{T.nav.pricelist}</a></li>
          <li><a href={`${prefix}/gallery`}>{T.nav.gallery}</a></li>
          <li><a href={`${prefix}/about-mandre`}>{T.nav.aboutMandre}</a></li>
          <li><a href={`${prefix}/contact`}>{T.nav.contact}</a></li>
          <li><a href={`${prefix}/directions`}>{T.nav.directions}</a></li>
        </ul>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  (function () {
    const supported = ['hr', 'de', 'si', 'it', 'pl', 'cz'];
    // Only the fully-translated language has content here; others fall back to English text
    // but will still get correct link prefixes.
    const i18n: Record<string, { heading: string; body: string; backHome: string; checkAvailability: string; orGoTo: string }> = {
      hr: {
        heading: 'Izgubili ste se pod zvijezdama?',
        body: 'Stranica koju tražite kao da je otplovila poput broda po Jadranu. Ne brinite — apartman je i dalje tu i čeka vas.',
        backHome: '← Natrag na početnu',
        checkAvailability: 'Provjeri slobodne termine',
        orGoTo: 'Ili idite izravno na:',
      },
    };

    const seg = location.pathname.split('/').filter(Boolean);
    const lang = supported.includes(seg[0]) ? seg[0] : '';
    if (!lang) return;

    const prefix = '/' + lang;

    // Fix every internal link so it carries the lang prefix
    document.querySelectorAll<HTMLAnchorElement>('a[href^="/"]').forEach(a => {
      const href = a.getAttribute('href')!;
      if (href !== prefix && !href.startsWith(prefix + '/')) {
        a.setAttribute('href', prefix + href);
      }
    });

    // Swap 404 page text if a translation exists for this lang
    const t = i18n[lang];
    if (!t) return;

    const title = document.querySelector('.notfound__title');
    const body  = document.querySelector('.notfound__text');
    const btns  = document.querySelectorAll<HTMLAnchorElement>('.notfound__links a');
    const orGoTo = document.querySelector('.notfound__quicklinks p');

    if (title)   title.textContent   = t.heading;
    if (body)    body.textContent    = t.body;
    if (btns[0]) btns[0].textContent = t.backHome;
    if (btns[1]) btns[1].textContent = t.checkAvailability;
    if (orGoTo)  orGoTo.textContent  = t.orGoTo;
  })();
</script>

<style>
  .notfound {
    position: relative;
    min-height: calc(100vh - 200px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 4rem 0;
  }

  .notfound__bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, var(--soft-sky) 0%, var(--white) 50%, var(--warm-sand) 100%);
    z-index: 0;
  }
  .notfound__bg::before {
    content: '';
    position: absolute;
    top: -100px;
    right: -100px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(74,159,212,0.08) 0%, transparent 70%);
    border-radius: 50%;
  }
  .notfound__bg::after {
    content: '';
    position: absolute;
    bottom: -80px;
    left: -80px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(232,168,42,0.08) 0%, transparent 70%);
    border-radius: 50%;
  }

  .notfound__content {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    max-width: 620px;
    margin: 0 auto;
  }

  .notfound__moon img {
    opacity: 0.85;
    filter: drop-shadow(0 8px 32px rgba(74,159,212,0.25));
    animation: floatMoon 4s ease-in-out infinite;
  }

  @keyframes floatMoon {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-12px); }
  }

  .notfound__code {
    font-family: 'Playfair Display', serif;
    font-size: clamp(5rem, 15vw, 9rem);
    font-weight: 900;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 3px var(--ocean-blue);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .notfound__title {
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    color: var(--ocean-blue);
    margin: 0;
  }

  .notfound__text {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 480px;
  }

  .notfound__links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .notfound__quicklinks {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(74,159,212,0.2);
    width: 100%;
  }
  .notfound__quicklinks p {
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.85rem;
  }
  .notfound__quicklinks ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4rem 1.5rem;
  }
  .notfound__quicklinks a {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--sky-blue);
    text-decoration: none;
    transition: color 0.2s;
  }
  .notfound__quicklinks a:hover { color: var(--ocean-blue); }
</style>
