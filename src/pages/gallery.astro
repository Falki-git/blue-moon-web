---
import { Image } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';
import heroBg from '../assets/gallery/Blue Moon cover picture.jpg';

const galleryImages = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/gallery/*.{jpg,jpeg,png}',
  { eager: true }
);
const img = (filename: string) =>
  galleryImages[`../assets/gallery/${filename}`]?.default;

const photos = [
  // ── Terrace & Jacuzzi ──
  { id: 1,  cat: 'terrace',  cls: 'ph-terrace',  label: 'Terrace with Jacuzzi',   size: 'large',  src: img('jacuzzi.png') },
  { id: 2,  cat: 'terrace',  cls: 'ph-terrace',  label: 'Terrace',                size: 'medium', src: img('terrace-1.jpg') },
  { id: 3,  cat: 'terrace',  cls: 'ph-terrace',  label: 'Terrace',                size: 'medium', src: img('terrace-2.jpg') },
  { id: 4,  cat: 'terrace',  cls: 'ph-terrace',  label: 'Terrace',                size: 'medium', src: img('terrace-3.jpg') },
  { id: 5,  cat: 'terrace',  cls: 'ph-terrace',  label: 'Terrace',                size: 'medium', src: img('terrace-4.jpg') },
  { id: 6,  cat: 'terrace',  cls: 'ph-terrace',  label: 'Terrace',                size: 'medium', src: img('terrace-5.jpg') },
  { id: 7,  cat: 'terrace',  cls: 'ph-terrace',  label: 'Terrace',                size: 'medium', src: img('terrace-6.jpg') },
  { id: 8,  cat: 'terrace',  cls: 'ph-terrace',  label: 'Terrace',                size: 'medium', src: img('terrace-7.jpg') },
  { id: 9,  cat: 'terrace',  cls: 'ph-terrace',  label: 'Terrace',                size: 'medium', src: img('terrace-8.jpg') },
  { id: 10, cat: 'terrace',  cls: 'ph-terrace',  label: 'Terrace',                size: 'medium', src: img('terrace-9.jpg') },
  { id: 11, cat: 'terrace',  cls: 'ph-terrace',  label: 'Terrace',                size: 'medium', src: img('terrace-10.jpg') },
  { id: 12, cat: 'terrace',  cls: 'ph-terrace',  label: 'Terrace',                size: 'medium', src: img('terrace-11.jpg') },
  { id: 13, cat: 'terrace',  cls: 'ph-terrace',  label: 'Terrace Panorama',       size: 'large',  src: img('terrace-12.jpg') },
  // ── Living Room ──
  { id: 14, cat: 'living',   cls: 'ph-interior', label: 'Living Room',            size: 'large',  src: img('livingroom-1.jpg') },
  { id: 15, cat: 'living',   cls: 'ph-interior', label: 'Living Room',            size: 'medium', src: img('livingroom-2.jpg') },
  { id: 16, cat: 'living',   cls: 'ph-interior', label: 'Living Room',            size: 'medium', src: img('livingroom-3.jpg') },
  { id: 17, cat: 'living',   cls: 'ph-interior', label: 'Dining Area',            size: 'medium', src: img('livingroom-4.jpg') },
  { id: 18, cat: 'living',   cls: 'ph-interior', label: 'Living Room',            size: 'medium', src: img('livingroom-5.jpg') },
  { id: 19, cat: 'living',   cls: 'ph-interior', label: 'Living Room',            size: 'medium', src: img('livingroom-6.jpg') },
  { id: 20, cat: 'living',   cls: 'ph-interior', label: 'Open-Plan Living',       size: 'medium', src: img('livingroom-7.jpg') },
  { id: 21, cat: 'living',   cls: 'ph-interior', label: 'Hallway',               size: 'medium', src: img('hallway-1.jpg') },
  { id: 22, cat: 'living',   cls: 'ph-interior', label: 'Hallway',               size: 'medium', src: img('hallway-2.jpg') },
  { id: 23, cat: 'living',   cls: 'ph-interior', label: 'Hallway',               size: 'medium', src: img('hallway-3.jpg') },
  // ── Kitchen ──
  { id: 24, cat: 'kitchen',  cls: 'ph-kitchen',  label: 'Kitchen',               size: 'large',  src: img('kitchen1-1.jpg') },
  { id: 25, cat: 'kitchen',  cls: 'ph-kitchen',  label: 'Kitchen',               size: 'medium', src: img('kitchen1-2.jpg') },
  { id: 26, cat: 'kitchen',  cls: 'ph-kitchen',  label: 'Kitchen — Detail',      size: 'medium', src: img('kitchen1-3.jpg') },
  // ── Bedroom 1 ──
  { id: 27, cat: 'bedroom',  cls: 'ph-bedroom',  label: 'Bedroom 1',             size: 'large',  src: img('bedroom1-1.jpg'), subgroupLabel: 'Bedroom 1' },
  { id: 28, cat: 'bedroom',  cls: 'ph-bedroom',  label: 'Bedroom 1',             size: 'medium', src: img('bedroom1-2.jpg') },
  { id: 29, cat: 'bedroom',  cls: 'ph-bedroom',  label: 'Bedroom 1',             size: 'medium', src: img('bedroom1-3.jpg') },
