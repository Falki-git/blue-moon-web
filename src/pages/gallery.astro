  { id: 'all',      label: 'All Photos' },
  { id: 'living',   label: 'Living Area' },
  { id: 'kitchen',  label: 'Kitchen' },
  { id: 'bedroom',  label: 'Bedrooms' },
  { id: 'bathroom', label: 'Bathrooms' },
