---
import PageLayout from '../layouts/PageLayout.astro';
import heroBg from '../assets/gallery/terrace-5.jpg';

const reviews = [
  {
    id: 1,
    name: 'Müller Family',
    country: 'Germany',
    flag: '🇩🇪',
    type: 'Family with 2 children',
    rating: 5,
    date: 'August 2024',
    title: 'Magic evenings on the terrace',
    text: 'The terrace hot tub at sunset was pure magic. Our kids loved the beach every single day — Mala Mandra is perfect for small children. The apartment is spacious, spotlessly clean, and has everything you need. Goran was an excellent host, always available and full of great tips. We\'ll be back next summer without question!',
    highlights: ['Terrace & Hot Tub', 'Beach location', 'Host responsiveness'],
    booking: 'Booking.com',
  },
  {
    id: 2,
    name: 'Novak & Kovač Families',
    country: 'Slovenia',
    flag: '🇸🇮',
    type: 'Two families with children',
    rating: 5,
    date: 'July 2024',
    title: 'Perfect for two families together',
    text: 'We travelled as two families — four adults and three kids — and the apartment worked brilliantly for all of us. Two bedrooms, two bathrooms means no chaos in the mornings! Mandre is a hidden gem: quiet, clean, beautiful. Goran met us on arrival and showed us everything personally. The grocery store across the street is so convenient.',
    highlights: ['Great for groups', 'Two bathrooms', 'Quiet location'],
    booking: 'Direct',
  },
  {
    id: 3,
    name: 'Kowalski Family',
    country: 'Poland',
    flag: '🇵🇱',
    type: 'Family holiday',
    rating: 5,
    date: 'September 2024',
    title: 'September is the best kept secret',
    text: 'We came in September and it was absolutely perfect. The sea was still warm, the beaches were quiet, and the town felt peaceful and local. The apartment is even more beautiful in person — the views from the terrace are simply breathtaking. The kitchen had everything we needed for cooking. Highly recommend the shoulder season for families who prefer a calmer holiday.',
    highlights: ['September season', 'Beautiful views', 'Well-equipped kitchen'],
    booking: 'Booking.com',
  },
  {
    id: 4,
    name: 'Familie Bauer',
    country: 'Germany',
    flag: '🇩🇪',
    type: 'Couple with young children',
    rating: 5,
    date: 'July 2024',
    title: 'Exceptional from start to finish',
    text: 'From the first message to our departure day, everything was handled impeccably. The apartment itself is stunning — modern, bright, and that hot tub on the terrace is something else entirely. Our kids loved the playground near the centre and the promenade in the evenings. We tried Paški sir at a local restaurant on Goran\'s recommendation — incredible! Thank you for a wonderful holiday.',
    highlights: ['Host communication', 'Hot Tub', 'Local tips'],
    booking: 'Direct',
  },
  {
    id: 5,
    name: 'Rossi Family',
    country: 'Italy',
    flag: '🇮🇹',
    type: 'Family with 3 children',
    rating: 5,
    date: 'August 2024',
    title: 'Best family holiday in years',
    text: 'We have been coming to Croatia for years but Mandre is now our favourite place. So peaceful compared to more touristy spots. The apartment is generous in size — our three children had plenty of space to play. The beach is 2 minutes on foot and the water is incredible. We went on the boat trip to Silba that Goran recommended and it was the highlight of the whole holiday.',
    highlights: ['Space for large family', 'Beach proximity', 'Boat trips'],
    booking: 'Booking.com',
  },
  {
    id: 6,
    name: 'Marija K.',
    country: 'Croatia',
    flag: '🇭🇷',
    type: 'Family break',
    rating: 5,
    date: 'June 2024',
    title: 'A gem on our own island',
    text: 'As a Croatian myself, I know how hard it is to find truly quality accommodation at a fair price. Blue Moon is the real deal. Beautifully renovated, tasteful, everything works perfectly. Goran left us a welcome note with personal tips which was a lovely touch. June was an excellent time — beaches not crowded, the town beautiful and calm. We will definitely return.',
    highlights: ['Quality & value', 'June season', 'Personal touches'],
    booking: 'Direct',
  },
  {
    id: 7,
    name: 'Novák Family',
    country: 'Czech Republic',
    flag: '🇨🇿',
    type: 'Family with 2 children',
    rating: 5,
    date: 'August 2024',
    title: 'The Hot Tub Made Our Holiday',
    text: 'After a long day at the beach, the kids fell asleep early and we had the terrace and hot tub to ourselves. With the sunset view and a glass of local wine, it was honestly one of the most relaxing evenings we can remember. The apartment is in a perfect quiet location — you can hear nothing but the sea. Everything was immaculate on arrival.',
    highlights: ['Evening Hot Tub', 'Quiet location', 'Cleanliness'],
    booking: 'Booking.com',
  },
  {
    id: 8,
    name: 'Kowalczyk &amp; Wiśniewska Families',
    country: 'Poland',
    flag: '🇵🇱',
    type: 'Two families with young children',
    rating: 5,
    date: 'July 2024',
    title: 'Would give 6 stars if we could',
    text: 'We have stayed in many apartments across Croatia and this is the best by far. The standard of renovation is hotel-quality. Goran is a rare host — genuinely caring and knowledgeable. He sent us a detailed welcome message with everything we needed to know before we even arrived. Mandre is a perfect family destination and this apartment is the perfect base.',
    highlights: ['Premium quality', 'Host care', 'Pre-arrival info'],
    booking: 'Direct',
  },
];

const avgRating = (reviews.reduce((s, r) => s + r.rating, 0) / reviews.length).toFixed(1);
---

<PageLayout
  title="Guest Reviews | Blue Moon Apartment, Mandre"
  description="Read what guests say about Blue Moon Apartment in Mandre, island of Pag. Consistently 5-star family reviews praising the host, location, hot tub terrace, and cleanliness."
  pageTitle="What Our Guests Say"
  pageSubtitle="Honest reviews from families who stayed with us"
  label="Guest Reviews"
  bgClass="ph-sea"
  bgImage={heroBg}
>

  <!-- ═══ SUMMARY BAR ═══ -->
  <section class="section-sm" style="background:var(--soft-sky);">
    <div class="container">
      <div class="rating-summary">
        <div class="rating-summary__score">
          <span class="rating-summary__num">{avgRating}</span>
          <div>
            <div class="stars" style="font-size:1.4rem;">★★★★★</div>
            <span class="rating-summary__count">{reviews.length} verified reviews</span>
          </div>
        </div>
        <div class="rating-bars">
          <div class="rating-bar">
            <span>Cleanliness</span>
            <div class="bar"><div class="bar__fill" style="width:100%"></div></div>
            <span class="bar__label">5.0</span>
          </div>
          <div class="rating-bar">
            <span>Location</span>
            <div class="bar"><div class="bar__fill" style="width:98%"></div></div>
            <span class="bar__label">4.9</span>
          </div>
          <div class="rating-bar">
            <span>Host</span>
            <div class="bar"><div class="bar__fill" style="width:100%"></div></div>
            <span class="bar__label">5.0</span>
          </div>
          <div class="rating-bar">
            <span>Value</span>
            <div class="bar"><div class="bar__fill" style="width:96%"></div></div>
            <span class="bar__label">4.8</span>
          </div>
        </div>
        <div class="rating-summary__cta">
          <p>Join our happy guests.</p>
          <a href="/contact" class="btn btn-primary btn-sm">Book Your Stay →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ REVIEWS GRID ═══ -->
  <section class="section">
    <div class="container">
      <div class="reviews-masonry">
        {reviews.map(review => (
          <article class="review-full card">
            <header class="review-full__header">
              <div class="review-full__stars">{'★'.repeat(review.rating)}</div>
              <div class="review-full__meta">
                <span class="review-full__badge">{review.booking}</span>
              </div>
            </header>
            <h3 class="review-full__title">"{review.title}"</h3>
            <blockquote class="review-full__text">{review.text}</blockquote>
            <div class="review-full__highlights">
              {review.highlights.map(h => (
                <span class="highlight-chip">{h}</span>
              ))}
            </div>
            <footer class="review-full__footer">
              <div class="review-full__author">
                <strong>{review.name}</strong>
                <span>{review.flag} {review.country} · {review.type}</span>
              </div>
              <span class="review-full__date">{review.date}</span>
            </footer>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ LEAVE A REVIEW ═══ -->
  <section class="section-sm" style="background:var(--soft-sky); text-align:center;">
    <div class="container">
      <h2 style="margin-bottom:0.75rem;">Stayed with us?</h2>
      <p style="color:var(--text-muted); margin-bottom:1.75rem; max-width:480px; margin-left:auto; margin-right:auto;">We'd love to hear about your experience. Your review helps other families find their perfect holiday.</p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="https://www.booking.com/hotel/hr/blue-moon-apartment-mandre.hr.html" target="_blank" rel="noopener" class="btn btn-primary">Leave a Review on Booking.com →</a>
        <a href="/contact" class="btn btn-secondary">Contact Us</a>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  /* Rating summary */
  .rating-summary {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 3rem;
    align-items: center;
    padding: 2rem 2.5rem;
    background: var(--white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .rating-summary__score {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .rating-summary__num {
    font-family: 'Playfair Display', serif;
    font-size: 4rem;
    font-weight: 700;
    color: var(--ocean-blue);
    line-height: 1;
  }
  .rating-summary__count {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text-muted);
    display: block;
    margin-top: 0.2rem;
  }

  .rating-bars {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    min-width: 280px;
  }
  .rating-bar {
    display: grid;
    grid-template-columns: 80px 1fr 30px;
    align-items: center;
    gap: 0.75rem;
  }
  .rating-bar > span:first-child {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text-dark);
    text-align: right;
  }
  .bar {
    height: 7px;
    background: rgba(74,159,212,0.18);
    border-radius: 50px;
    overflow: hidden;
  }
  .bar__fill {
    height: 100%;
    background: var(--sky-blue);
    border-radius: 50px;
  }
  .bar__label {
    font-size: 0.78rem;
    font-weight: 800;
    color: var(--ocean-blue);
  }

  .rating-summary__cta { text-align: center; }
  .rating-summary__cta p {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    font-style: italic;
  }

  /* Masonry-style grid */
  .reviews-masonry {
    columns: 3;
    column-gap: 1.5rem;
  }

  .review-full {
    break-inside: avoid;
    padding: 1.75rem;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .review-full__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .review-full__stars {
    color: var(--sunset-gold);
    font-size: 1rem;
    letter-spacing: 0.05em;
  }
  .review-full__badge {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--soft-sky);
    color: var(--sky-blue);
    padding: 0.2rem 0.6rem;
    border-radius: 50px;
  }

  .review-full__title {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--ocean-blue);
    font-style: italic;
  }

  .review-full__text {
    font-size: 0.9rem;
    color: var(--text-dark);
    line-height: 1.75;
    font-style: normal;
  }

  .review-full__highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .highlight-chip {
    font-size: 0.72rem;
    font-weight: 800;
    color: var(--sky-blue);
    background: rgba(74,159,212,0.1);
    padding: 0.25rem 0.65rem;
    border-radius: 50px;
    letter-spacing: 0.02em;
  }

  .review-full__footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    border-top: 1px solid rgba(74,159,212,0.12);
    padding-top: 0.85rem;
    gap: 0.5rem;
  }
  .review-full__author { display: flex; flex-direction: column; gap: 0.15rem; }
  .review-full__author strong { font-size: 0.9rem; color: var(--ocean-blue); }
  .review-full__author span   { font-size: 0.78rem; color: var(--text-muted); }
  .review-full__date {
    font-size: 0.75rem;
    color: var(--text-light);
    white-space: nowrap;
  }

  @media (max-width: 960px) {
    .rating-summary { grid-template-columns: 1fr; gap: 1.5rem; text-align: center; }
    .rating-summary__score { justify-content: center; }
    .rating-bar > span:first-child { text-align: left; }
    .reviews-masonry { columns: 2; }
  }
  @media (max-width: 580px) {
    .reviews-masonry { columns: 1; }
    .rating-bars { min-width: unset; }
  }
</style>
