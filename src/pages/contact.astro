---
import PageLayout from '../layouts/PageLayout.astro';
import heroImg from '../assets/gallery/hot-tub-2.jpg';
---

<PageLayout
  title="Contact | Blue Moon Apartment, Mandre"
  description="Get in touch with Goran at Blue Moon Apartment, Mandre, island of Pag. Email, WhatsApp, or fill in the form — we respond within 24 hours."
  pageTitle="Get In Touch"
  pageSubtitle="Questions about the apartment, the area, or your stay — we're happy to help"
  label="Contact"
  bgImage={heroImg}
  heroObjectPosition="center 20%"
  showHeroLogo={true}
>

  <section class="section-sm" style="background: var(--warm-sand);">
    <div class="container">
      <div class="contact-cta">
        <div class="contact-cta__msg">
          <strong>Already know your dates?</strong>
          <span> See live availability and request a reservation directly.</span>
        </div>
        <a href="/booking" class="btn btn-primary">Book directly →</a>
      </div>
    </div>
  </section>

  <section class="section" id="contactSection">
    <div class="container">
      <div class="contact-layout">

        <!-- ─── LEFT: Contact info ─────────────────────────── -->
        <aside class="contact-info">
          <div class="contact-info__inner">
            <span class="section-label">Reach Us</span>
            <h2>Let's plan your holiday</h2>
            <p>Whether you want to check availability, have questions about the apartment, or just want to know more about Mandre — we're here to help. Send us a message and we'll get back to you as soon as possible.</p>

            <ul class="contact-methods">
              <li class="contact-method">
                <span class="contact-method__icon">
                  <svg width="22" height="18" viewBox="0 0 24 20" fill="currentColor" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22 0H2C.9 0 0 .9 0 2v16c0 1.1.9 2 2 2h20c1.1 0 2-.9 2-2V2c0-1.1-.9-2-2-2zm0 4l-10 7L2 4V2l10 7 10-7v2z"/>
                  </svg>
                </span>
                <div>
                  <strong>Email</strong>
                  <a href="mailto:bluemoon.mandre@gmail.com">bluemoon.mandre@gmail.com</a>
                </div>
              </li>
              <li class="contact-method">
                <span class="contact-method__icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                </span>
                <div>
                  <strong>WhatsApp</strong>
                  <a href="https://wa.me/385914691204" target="_blank" rel="noopener">+385 91 469 1204</a>
                </div>
              </li>
              <li class="contact-method">
                <span class="contact-method__icon">
                  <svg width="14" height="21" viewBox="0 0 336 496" fill="currentColor" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                    <path d="M167.946 0C75.0262 0 0 75.2072 0 167.97C0 197.138 7.44304 224.582 20.4906 248.493L167.954 495.702L315.417 248.493C328.464 224.582 335.907 197.138 335.907 167.97C335.907 75.2035 260.879 0 167.961 0H167.946ZM166.078 97.6169C166.702 97.6011 167.319 97.6169 167.946 97.6169C208.086 97.6169 240.624 130.201 240.624 170.395C240.624 210.589 208.085 243.172 167.946 243.172C127.807 243.172 95.2683 210.589 95.2683 170.395C95.2683 130.829 126.806 98.6139 166.078 97.6169Z"/>
                  </svg>
                </span>
                <div>
                  <strong>Location</strong>
                  <a href="https://www.google.com/maps/dir/?api=1&destination=Blue+Moon+Apartment&destination_place_id=ChIJjWwKavA3YkcRtIxHt59t0pQ" target="_blank" rel="noopener">Riječka ulica 30, Mandre, Island of Pag, Croatia</a>
                </div>
              </li>
              <li class="contact-method">
                <span class="contact-method__icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm0 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10zm.5-17H11v7l6.25 3.75.75-1.23-5.5-3.27V5z"/>
                  </svg>
                </span>
                <div>
                  <strong>Response Time</strong>
                  <span>We respond within 24 hours, usually much faster.</span>
                </div>
              </li>
              <li class="contact-method">
                <span class="contact-method__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41L5.99 4.58zm12.37 12.37c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0 .39-.39.39-1.03 0-1.41l-1.06-1.06zm1.06-10.96c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06zM7.05 18.36c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06z"/>
                  </svg>
                </span>
                <div>
                  <strong>Season</strong>
                  <span>Open 1 June – 30 September 2026</span>
                </div>
              </li>
            </ul>

            <!-- Host values -->
            <div class="host-values-group">
              <span class="host-values-group__label">Why book direct?</span>
              <div class="host-value">
                <span class="host-value__icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                    <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
                  </svg>
                </span>
                <div>
                  <strong>Always reachable</strong>
                  <span>We respond within a few hours, usually much faster.</span>
                </div>
              </div>
              <div class="host-value">
                <span class="host-value__icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                    <path d="M20.5 3l-.16.03L15 5.1 9 3 3.36 4.9c-.21.07-.36.25-.36.48V20.5c0 .28.22.5.5.5l.16-.03L9 18.9l6 2.1 5.64-1.9c.21-.07.36-.25.36-.48V3.5c0-.28-.22-.5-.5-.5zM15 19l-6-2.11V5l6 2.11V19z"/>
                  </svg>
                </span>
                <div>
                  <strong>Local knowledge</strong>
                  <span>Restaurants, beaches, boat trips, hidden spots — just ask.</span>
                </div>
              </div>
              <div class="host-value">
                <span class="host-value__icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                    <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
                  </svg>
                </span>
                <div>
                  <strong>Care for the details</strong>
                  <span>Maintained to the standard we'd want for our own family.</span>
                </div>
              </div>
            </div>

            <div class="contact-also-find">
              <p>Also find us on:</p>
              <a href="https://www.booking.com/hotel/hr/blue-moon-apartment-mandre.hr.html" target="_blank" rel="noopener" class="booking-badge">
                <svg viewBox="0 0 100 20" width="80" height="16" aria-label="Booking.com"><rect width="100" height="20" fill="#003580" rx="3"/><text x="50" y="14" text-anchor="middle" font-family="sans-serif" font-size="10" font-weight="bold" fill="white">booking.com</text></svg>
              </a>
            </div>
          </div>
        </aside>

        <!-- ─── RIGHT: Form ────────────────────────────────── -->
        <div class="contact-form-wrap">
          <div class="contact-form-card">
            <h3>Contact us</h3>
            <p class="form-intro">Tell us your dates, number of guests, and any questions. We'll confirm availability and send you all the details.</p>

            <form
              class="contact-form"
              id="contactForm"
              novalidate
            >
              <!-- Honeypot -->
              <p class="hidden" aria-hidden="true">
                <label>Don't fill this out: <input name="bot-field" /></label>
              </p>

              <div class="form-row">
                <div class="form-group">
                  <label for="fullName">Full Name <span class="required">*</span></label>
                  <input type="text" id="fullName" name="fullName" placeholder="Jane & John Smith" required autocomplete="name" />
                  <span class="form-error" aria-live="polite"></span>
                </div>
                <div class="form-group">
                  <label for="email">Email Address <span class="required">*</span></label>
                  <input type="email" id="email" name="email" placeholder="your@email.com" required autocomplete="email" />
                  <span class="form-error" aria-live="polite"></span>
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="phone">Phone Number <span class="optional">(optional)</span></label>
                  <input type="tel" id="phone" name="phone" placeholder="+49 123 456 789" autocomplete="tel" />
                </div>
                <div class="form-group">
                  <label for="language">Preferred Language</label>
                  <select id="language" name="language">
                    <option value="en">🇬🇧 English</option>
                    <option value="hr">🇭🇷 Croatian</option>
                    <option value="de">🇩🇪 German</option>
                    <option value="si">🇸🇮 Slovenian</option>
                    <option value="it">🇮🇹 Italian</option>
                    <option value="pl">🇵🇱 Polish</option>
                    <option value="cz">🇨🇿 Czech</option>
                  </select>
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="checkin">Check-in Date <span class="required">*</span></label>
                  <input type="date" id="checkin" name="checkin" required min="2026-06-01" max="2026-09-27" />
                  <span class="form-error" aria-live="polite"></span>
                </div>
                <div class="form-group">
                  <label for="checkout">Check-out Date <span class="required">*</span></label>
                  <input type="date" id="checkout" name="checkout" required min="2026-06-06" max="2026-09-30" />
                  <span class="form-error" aria-live="polite"></span>
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="guests">Number of Guests <span class="required">*</span></label>
                  <input type="number" id="guests" name="guests" min="1" max="6" value="2" required />
                  <span class="form-hint">Maximum 6 guests (including children)</span>
                </div>
                <div class="form-group">
                  <label for="children">Children (ages)</label>
                  <input type="text" id="children" name="children" placeholder="e.g. 4 and 7 years old" />
                </div>
              </div>

              <div class="form-group">
                <label for="message">Message / Special Requests</label>
                <textarea id="message" name="message" rows="4" placeholder="Tell us anything — questions about the apartment, arrival time, special requests, or anything else you'd like to know about Mandre..."></textarea>
              </div>

              <div class="cf-turnstile-wrap">
                <div class="cf-turnstile" data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY}></div>
              </div>

              <div class="form-group form-group--submit">
                <button type="submit" class="btn btn-primary btn-submit" id="submitBtn">
                  <span class="btn-label">Send Message</span>
                  <span class="btn-loading" aria-hidden="true" style="display:none;">Sending…</span>
                  <svg class="btn-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                </button>
                <p class="form-privacy">
                  🔒 Your details are used only to respond to your message and will not be shared with third parties.
                </p>
                <p class="form-submit-error" id="formSubmitError" hidden></p>
              </div>

            </form>

            <!-- Success message -->
            <div class="form-success" id="formSuccess" hidden role="alert" aria-live="polite">
              <span class="form-success__icon">🎉</span>
              <h3>Message sent!</h3>
              <p>Thank you — we'll get back to you within 24 hours. In the meantime, feel free to explore <a href="/about-mandre">Mandre</a> or <a href="/gallery">our gallery</a>.</p>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="section" style="background:var(--soft-sky);">
    <div class="container">
      <div class="text-center" style="margin-bottom:2.5rem;">
        <span class="section-label">Common Questions</span>
        <h2>Before You Inquire</h2>
      </div>
      <div class="faq-grid">
        <div class="faq-item">
          <h4>How do I confirm a booking?</h4>
          <p>Send a message with your dates. We'll confirm availability and send you a booking confirmation. A 30% deposit secures your reservation.</p>
        </div>
        <div class="faq-item">
          <h4>What payment methods do you accept?</h4>
          <p>Bank transfer only. We'll provide all payment details after confirming your dates.</p>
        </div>
        <div class="faq-item">
          <h4>Is there a minimum stay?</h4>
          <p>Yes — a minimum of 5 nights applies in all seasons.</p>
        </div>
        <div class="faq-item">
          <h4>Do you allow pets?</h4>
          <p>Unfortunately pets are not permitted in the apartment. We're sorry for the inconvenience.</p>
        </div>
        <div class="faq-item">
          <h4>Is the garage suitable for my car?</h4>
          <p>The garage accommodates vehicles up to 2.60m wide and 2.40m high. A standard outdoor parking space is also available.</p>
        </div>
        <div class="faq-item">
          <h4>Can you accommodate early check-in?</h4>
          <p>We'll do our best! Early check-in and late check-out are subject to availability. Just let us know.</p>
        </div>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  .contact-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.75rem;
    box-shadow: var(--shadow-xs);
    border-left: 4px solid var(--ocean-blue);
  }
  .contact-cta__msg strong { color: var(--ocean-blue); font-size: 1rem; }
  .contact-cta__msg span   { color: var(--text-muted); font-size: 0.9rem; }
  .contact-cta .btn { white-space: nowrap; flex-shrink: 0; }
  @media (max-width: 640px) {
    .contact-cta { flex-direction: column; align-items: stretch; text-align: center; }
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3.5rem;
    align-items: start;
  }

  .contact-info__inner {
    background: var(--soft-sky);
    border-radius: var(--radius-lg);
    padding: 2.25rem;
  }
  .contact-info__inner h2 { margin: 0.5rem 0 0.85rem; font-size: 1.5rem; }
  .contact-info__inner > p { color: var(--text-muted); font-size: 0.92rem; margin-bottom: 1.75rem; }

  .contact-methods {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.75rem;
  }
  .contact-method {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    background: var(--white);
    border-radius: var(--radius);
    padding: 0.85rem 1rem;
    box-shadow: var(--shadow-xs);
  }
  .contact-method__icon { font-size: 1.3rem; flex-shrink: 0; margin-top: 1px; }
  .contact-method div   { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
  .contact-method strong { font-size: 0.8rem; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-muted); }
  .contact-method a, .contact-method span { font-size: 0.9rem; font-weight: 600; color: var(--ocean-blue); overflow-wrap: break-word; min-width: 0; }
  .contact-method a { text-decoration: none; transition: color 0.2s; }
  .contact-method a:hover { color: var(--sky-blue); }

  .host-values-group {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
    background: var(--white);
    border-radius: var(--radius);
    border-left: 3px solid var(--sky-blue);
    padding: 1rem 1.1rem;
    box-shadow: var(--shadow-xs);
  }
  .host-values-group__label {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sky-blue);
    margin-bottom: 0.25rem;
  }
  .host-value {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
  }
  .host-value__icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 1px; }
  .host-value div   { display: flex; flex-direction: column; gap: 0.05rem; }
  .host-value strong { font-size: 0.82rem; font-weight: 800; color: var(--ocean-blue); }
  .host-value span   { font-size: 0.8rem; color: var(--text-muted); }

  .contact-also-find {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .contact-also-find p {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .booking-badge {
    display: flex;
    align-items: center;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .booking-badge:hover { opacity: 0.8; }

  /* Form */
  .contact-form-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    box-shadow: var(--shadow-md);
  }
  .contact-form-card h3 { margin-bottom: 0.35rem; }
  .form-intro { color: var(--text-muted); font-size: 0.9rem; margin-bottom: 2rem; }

  .contact-form { display: flex; flex-direction: column; gap: 1.25rem; }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-size: 0.82rem;
    font-weight: 800;
    color: var(--text-dark);
    letter-spacing: 0.03em;
  }
  .required { color: var(--ocean-blue); }
  .optional  { color: var(--text-light); font-weight: 600; font-size: 0.78rem; }

  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    font-family: 'Nunito', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-dark);
    background: var(--soft-sky);
    border: 2px solid transparent;
    border-radius: var(--radius);
    padding: 0.75rem 1rem;
    transition: border-color 0.2s, background 0.2s;
    outline: none;
    width: 100%;
  }
  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    border-color: var(--sky-blue);
    background: var(--white);
  }
  .contact-form input.is-error,
  .contact-form select.is-error {
    border-color: #e05c5c;
  }
  .contact-form input::placeholder,
  .contact-form textarea::placeholder { color: var(--text-light); font-weight: 500; }
  .contact-form textarea { resize: vertical; min-height: 100px; }
  .contact-form select { cursor: pointer; }

  .form-hint {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-style: italic;
  }
  .form-error {
    font-size: 0.75rem;
    color: #e05c5c;
    font-weight: 700;
    min-height: 1rem;
  }

  .form-group--submit { gap: 0.85rem; }

  .form-submit-error {
    font-size: 0.82rem;
    color: #e05c5c;
    font-weight: 700;
    text-align: center;
    line-height: 1.5;
  }

  .btn-submit {
    width: 100%;
    justify-content: center;
    font-size: 1rem;
    padding: 1rem 2rem;
  }

  .form-privacy {
    font-size: 0.78rem;
    color: var(--text-muted);
    text-align: center;
    line-height: 1.5;
  }

  .hidden { display: none !important; }

  /* Success */
  .form-success {
    text-align: center;
    padding: 3rem 2rem;
  }
  .form-success__icon { font-size: 3.5rem; display: block; margin-bottom: 1rem; }
  .form-success h3 { color: var(--ocean-blue); margin-bottom: 0.75rem; }
  .form-success p  { color: var(--text-muted); }
  .form-success a  { color: var(--sky-blue); font-weight: 700; }

  /* FAQ */
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .faq-item {
    background: var(--white);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow-xs);
    border-left: 3px solid var(--sky-blue);
  }
  .faq-item h4 { font-family:'Nunito',sans-serif; font-size:0.9rem; font-weight:800; color:var(--ocean-blue); margin-bottom:0.5rem; }
  .faq-item p  { font-size:0.88rem; color:var(--text-muted); }

  @media (max-width: 960px) {
    .contact-layout { grid-template-columns: 1fr; }
    /* Prevent grid children from forcing the grid wider than its container */
    .contact-layout > * { min-width: 0; }
  }
  /* Prevent the Turnstile iframe (fixed ~300px) from overflowing its container */
  .cf-turnstile-wrap { overflow: hidden; border-radius: var(--radius); }

  @media (max-width: 640px) {
    .form-row { grid-template-columns: 1fr; }
    .contact-form-card { padding: 1.5rem; }
    .faq-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form        = document.getElementById('contactForm') as HTMLFormElement | null;
  const submitBtn   = document.getElementById('submitBtn') as HTMLButtonElement | null;
  const formSuccess = document.getElementById('formSuccess') as HTMLElement | null;
  const checkinInput  = document.getElementById('checkin')  as HTMLInputElement | null;
  const checkoutInput = document.getElementById('checkout') as HTMLInputElement | null;

  // Set min dates
  if (checkinInput) {
    checkinInput.min = '2026-06-01';
    checkinInput.max = '2026-09-27';
  }

  // Keep checkout min = checkin + 5 days
  checkinInput?.addEventListener('change', () => {
    if (!checkinInput.value || !checkoutInput) return;
    const checkinDate = new Date(checkinInput.value);
    checkinDate.setDate(checkinDate.getDate() + 5);
    const minCheckout = checkinDate.toISOString().split('T')[0];
    checkoutInput.min = minCheckout;
    if (checkoutInput.value && checkoutInput.value < minCheckout) {
      checkoutInput.value = minCheckout;
    }
  });

  // Simple client-side validation
  function validateField(input: HTMLInputElement) {
    const errorEl = input.parentElement?.querySelector('.form-error');
    if (input.required && !input.value.trim()) {
      input.classList.add('is-error');
      if (errorEl) errorEl.textContent = 'This field is required.';
      return false;
    }
    if (input.type === 'email' && input.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value)) {
      input.classList.add('is-error');
      if (errorEl) errorEl.textContent = 'Please enter a valid email address.';
      return false;
    }
    input.classList.remove('is-error');
    if (errorEl) errorEl.textContent = '';
    return true;
  }

  const formSubmitError = document.getElementById('formSubmitError') as HTMLElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const inputs = form.querySelectorAll<HTMLInputElement>('input[required], select[required]');
    let valid = true;
    inputs.forEach(input => { if (!validateField(input)) valid = false; });
    if (!valid) return;

    const label   = submitBtn?.querySelector('.btn-label') as HTMLElement | null;
    const loading = submitBtn?.querySelector('.btn-loading') as HTMLElement | null;
    if (label)            label.style.display   = 'none';
    if (loading)          loading.style.display = 'inline';
    if (submitBtn)        submitBtn.disabled     = true;
    if (formSubmitError)  formSubmitError.hidden = true;

    try {
      const fd = new FormData(form);
      const payload: Record<string, string> = {};
      fd.forEach((val, key) => { payload[key] = String(val); });

      const res  = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json() as { ok: boolean; error?: string };

      if (data.ok) {
        form.style.display = 'none';
        if (formSuccess) formSuccess.hidden = false;
        document.getElementById('contactSection')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } else {
        throw new Error(data.error ?? 'Something went wrong.');
      }
    } catch (e: unknown) {
      const msg = e instanceof Error ? e.message : 'Something went wrong.';
      if (label)   label.style.display   = 'inline';
      if (loading) loading.style.display = 'none';
      if (submitBtn) submitBtn.disabled  = false;
      (window as any).turnstile?.reset();
      if (formSubmitError) {
        formSubmitError.textContent = `${msg} If the problem persists, email us at bluemoon.mandre@gmail.com`;
        formSubmitError.hidden = false;
      }
    }
  });
</script>

<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
